/* ═══ History — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.history-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

.history-hero::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.history-hero::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.history-hero-glow {
  position: absolute;
  right: -80rpx;
  top: -78rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46, 158, 143, 0.12), rgba(46, 158, 143, 0));
}

.history-hero .hero-title,
.history-hero .hero-sub,
.history-hero .hero-view-capsule {
  position: relative;
  z-index: 1;
}

.history-hero .hero-title {
  color: #fffefb;
  font-size: 38rpx;
  font-weight: 800;
}

.history-hero .hero-sub {
  color: rgba(255, 254, 251, 0.55);
  font-size: 24rpx;
}

.history-hero .hero-view-capsule {
  margin-top: 14rpx;
  background: rgba(91, 122, 107, 0.08);
  border: 1rpx solid rgba(91, 122, 107, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.history-hero .hero-view-capsule__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5b7a6b;
  opacity: 0.5;
  box-shadow: none;
}

.history-hero .hero-view-capsule__text {
  color: #b0a99f;
  font-size: 22rpx;
  font-weight: 500;
}

/* ═══ Days filter ═══ */
.days-filter-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.days-label {
  font-size: 24rpx;
  color: #6b645c;
}

.days-picker {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
}

.days-picker-text {
  font-size: 24rpx;
  color: #1c1917;
  font-weight: 600;
}

.empty-wrap {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx dashed rgba(28, 25, 23, 0.08);
}

.history-list-card {
  border-radius: 24rpx;
  overflow: hidden;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.history-hint {
  margin: 14rpx 16rpx 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(91, 122, 107, 0.06);
  border: 1rpx solid rgba(91, 122, 107, 0.1);
}

.history-hint-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #5b7a6b;
}

.history-list {
  background: #fffefb;
}

.history-row {
  margin: 0 16rpx;
  padding: 20rpx 6rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.04);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  transition: transform 140ms ease, filter 140ms ease;
}

.history-row:last-child {
  border-bottom: none;
}

.history-row:active {
  transform: translateY(1rpx) scale(0.995);
  filter: brightness(0.98);
}

.history-row-main {
  flex: 1;
  min-width: 0;
}

.history-row-side {
  flex-shrink: 0;
}

.history-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1917;
  line-height: 1.25;
}

.history-time {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6b645c;
}
