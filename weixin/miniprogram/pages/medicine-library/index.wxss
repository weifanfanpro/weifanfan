/* ═══ Medicine Library — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Hero ═══ */
.brand-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { bottom: 20rpx; left: 50rpx; }

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.brand-hero .hero-title,
.brand-hero .hero-sub {
  position: relative;
  z-index: 2;
}

.brand-hero .hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.brand-hero .hero-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.5;
}

/* ═══ Search Card ═══ */
.search-card {
  position: relative;
  overflow: hidden;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: rgba(74, 157, 255, 0.04);
  border: 1rpx solid rgba(74, 157, 255, 0.1);
  font-size: 28rpx;
  color: #1A3A5C;
  box-sizing: border-box;
}

.search-input-placeholder {
  color: #8BA4C7;
}

.filter-row {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.filter-row--switch {
  align-items: center;
  justify-content: space-between;
}

.filter-label {
  font-size: 26rpx;
  color: #3D5A80;
}

.filter-pill {
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(74, 157, 255, 0.06);
  border: 1rpx solid rgba(74, 157, 255, 0.12);
  color: #4A9DFF;
  font-weight: 500;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-actions {
  margin-top: 16rpx;
}

/* ═══ Toggle ═══ */
.toggle {
  position: relative;
  width: 88rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #D1E5FF;
  transition: background 200ms ease;
  flex-shrink: 0;
}

.toggle--on {
  background: #4A9DFF;
}

.toggle-dot {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.15);
  transition: transform 200ms ease;
}

.toggle--on .toggle-dot {
  transform: translateX(40rpx);
}

/* ═══ Loading Dots ═══ */
.loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0;
}

.loading-dots--small {
  padding: 16rpx 0;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4A9DFF;
  animation: dotBounce 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-text {
  text-align: center;
  font-size: 24rpx;
  color: #8BA4C7;
  padding-bottom: 16rpx;
}

/* ═══ Empty State ═══ */
.empty-wrap {
  margin-top: 32rpx;
  padding: 0 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.empty-buddy { margin-bottom: 24rpx; }

.empty-pill-body {
  position: relative;
  width: 80rpx;
  height: 104rpx;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.2);
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-pill-left {
  position: absolute; left: 0; top: 0; width: 50%; height: 100%;
  background: #FFFFFF;
}

.empty-pill-right {
  position: absolute; right: 0; top: 0; width: 50%; height: 100%;
  background: #4A9DFF;
}

.empty-pill-eye {
  position: absolute;
  width: 20rpx; height: 22rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 30rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0,0,0,0.06);
}

.empty-pill-left .empty-pill-eye { left: 10rpx; }
.empty-pill-right .empty-pill-eye { right: 10rpx; }

.empty-pill-pupil {
  position: absolute;
  width: 10rpx; height: 12rpx;
  background: #2B5EA7;
  border-radius: 50%;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
}

.empty-pill-mouth {
  position: absolute;
  bottom: 28rpx; left: 50%;
  transform: translateX(-50%);
  width: 18rpx; height: 8rpx;
  border-bottom: 3rpx solid #2B5EA7;
  border-radius: 0 0 50% 50%;
  z-index: 3;
}

.empty-title {
  font-size: 28rpx;
  color: #8BA4C7;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

/* ═══ List Card ═══ */
.lib-list-card {
  position: relative;
  padding: 0;
  overflow: hidden;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.lib-row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(74, 157, 255, 0.06);
  transition: background 150ms ease;
}

.lib-row:last-child {
  border-bottom: none;
}

.lib-row-main {
  flex: 1;
  min-width: 0;
}

.lib-row-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A5C;
  line-height: 1.4;
}

.lib-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A5C;
}

.lib-row-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #3D5A80;
  line-height: 1.5;
  word-break: break-word;
}

/* CSS Chevron */
.css-chevron {
  flex-shrink: 0;
  margin-left: 12rpx;
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid #B0C4DE;
  border-right: 2rpx solid #B0C4DE;
  transform: rotate(45deg);
}

.medicine-rich {
  display: inline-block;
  max-width: 100%;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
}

.end-hint {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.muted {
  color: #8BA4C7;
}

.small {
  font-size: 22rpx;
}

/* ═══ Ghost Button ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn--ghost {
  background: transparent;
  border: 1rpx solid rgba(74, 157, 255, 0.15);
}

.btn--small { height: 64rpx; }

.btn-text { font-size: 30rpx; font-weight: 700; color: #FFFFFF; }

.btn-text--ghost {
  color: #4A9DFF;
  font-size: 26rpx;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
  .empty-pill-body { animation: none; }
  .loading-dot { animation: none; }
}
