/* ═══ AI Chat Consult Medicine Detail — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.scrollarea {
  height: 100vh;
  box-sizing: border-box;
}

.content {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.empty-wrap {
  margin-top: 64rpx;
}

.search-card {
  position: relative;
  overflow: hidden;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.search-card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.12);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.12);
  pointer-events: none;
  z-index: 1;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.filter-row--switch {
  align-items: center;
  justify-content: space-between;
}

.filter-label {
  font-size: 26rpx;
  color: #6b645c;
}

.filter-pill {
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(46, 158, 143, 0.06);
  color: #6b645c;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-actions {
  margin-top: 16rpx;
}

.lib-list-card {
  position: relative;
  padding: 0;
  overflow: hidden;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.lib-row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.05);
  transition: background 150ms ease;
}

.lib-row:last-child {
  border-bottom: none;
}

.lib-row-main {
  flex: 1;
  min-width: 0;
}

.lib-row-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
  line-height: 1.4;
}

.lib-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
}

.lib-row-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b645c;
  line-height: 1.5;
  word-break: break-word;
}

.lib-row-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
  font-size: 40rpx;
  color: #b0a99f;
  font-weight: 300;
}

.medicine-rich {
  display: inline-block;
  max-width: 100%;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0 16rpx;
}

.end-hint {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.muted {
  color: #b0a99f;
}

.small {
  font-size: 22rpx;
}

.es-hl {
  color: #2E9E8F;
  font-style: normal;
  font-weight: 700;
}

.es-frag {
  margin-top: 6rpx;
}
