<view class="page anim-in">
  <custom-navbar title="智药助理" showBack="{true}" />
  <scroll-view class="scrollarea" scroll-y type="list" enhanced="{{true}}" bounces="{{true}}">
    <view class="page-padding safe-bottom content">
      <!-- 蓝色渐变 Hero -->
      <view class="brand-hero reminder-hero">
        <view class="hero-cloud hero-cloud--1"></view>
        <view class="hero-cloud hero-cloud--2"></view>
        <view class="hero-star hero-star--1"></view>
        <view class="hero-star hero-star--2"></view>
        <view class="hero-cross hero-cross--1"></view>
        <view class="reminder-hero-top">
          <view class="hero-chip">提醒模板</view>
          <view class="hero-time">{{pageTimeText}}</view>
        </view>
        <view class="hero-title">设置提醒</view>
        <view class="hero-sub">
          <text wx:if="{{drugName}}">{{drugName}}</text>
          <text wx:elif="{{medicineId}}">加载中…</text>
          <text wx:else>未命名药品</text>
        </view>
        <view class="hero-view-capsule reminder-view-capsule">
          <view class="hero-view-capsule__dot"></view>
          <text class="hero-view-capsule__text">当前视角：{{viewLabel}}</text>
        </view>
      </view>

      <!-- ═══ Section 1: 用药规则 ═══ -->
      <view class="editorial-head">
        <view class="editorial-head-main">用药规则</view>
        <view class="editorial-head-tag">Rule</view>
      </view>
      <view class="editorial-head-sub">基础参数、频次与进食关系</view>
      <view class="card reminder-card tap-scale editorial-module">
        <view class="app-cell-group">
          <!-- 用药方式 -->
          <view class="app-cell">
            <text class="app-cell-title">用药方式</text>
            <input class="app-cell-input" value="{{usageMethodText}}" placeholder="例如：口服 / 外用 / 滴眼…" bindinput="onUsageMethodTextChange" />
          </view>
          <!-- 每日次数 -->
          <view class="app-cell app-cell--arrow" bindtap="openDailyFreqPopup">
            <text class="app-cell-title">每日次数</text>
            <text class="app-cell-note">{{dailyFrequency}} 次/日</text>
          </view>
          <!-- 用药时间 -->
          <block wx:for="{{timeList}}" wx:for-item="t" wx:for-index="idx">
            <block wx:if="{{idx < dailyFrequency}}">
              <picker mode="time" value="{{t}}" bindchange="onTimeChange" data-idx="{{idx}}">
                <view class="app-cell app-cell--arrow">
                  <text class="app-cell-title">{{dailyFrequency === 1 ? '用药时间' : '第 ' + (idx + 1) + ' 次时间'}}</text>
                  <text class="app-cell-note">{{t}}</text>
                </view>
              </picker>
            </block>
          </block>
          <!-- 用量 -->
          <view class="app-cell">
            <text class="app-cell-title">用量</text>
            <input class="app-cell-input" value="{{doseText}}" placeholder="例如：每次 2 片 / 每次适量" bindinput="onDoseTextChange" />
          </view>
          <!-- 药品总量 -->
          <view wx:if="{{isQuantifiable}}" class="app-cell">
            <text class="app-cell-title">药品总量</text>
            <input class="app-cell-input" value="{{totalAmountText}}" placeholder="例如：总量 30 片 / 2 瓶 / 10g" bindinput="onTotalAmountTextChange" />
          </view>
          <!-- 饭前/饭后/空腹 -->
          <view class="app-cell app-cell--arrow" bindtap="openMealPopup">
            <text class="app-cell-title">饭前/饭后/空腹</text>
            <text class="app-cell-note">{{mealTimingLabel}}</text>
          </view>
        </view>
      </view>

      <!-- ═══ Section 2: 重复周期 ═══ -->
      <view class="editorial-head">
        <view class="editorial-head-main">重复周期</view>
        <view class="editorial-head-tag">Cycle</view>
      </view>
      <view class="editorial-head-sub">控制提醒节奏与星期分布</view>
      <view class="card reminder-card tap-scale editorial-module">
        <view class="app-cell-group">
          <view class="app-cell">
            <view class="radio-group radio-group--row">
              <view class="radio-pill {{repeatMode === 'everyday' ? 'radio-pill--active' : ''}}" bindtap="onRepeatModeChange" data-value="everyday">
                <text class="radio-pill-text">每天</text>
              </view>
              <view class="radio-pill {{repeatMode === 'weekday' ? 'radio-pill--active' : ''}}" bindtap="onRepeatModeChange" data-value="weekday">
                <text class="radio-pill-text">周一到周五</text>
              </view>
              <view class="radio-pill {{repeatMode === 'custom' ? 'radio-pill--active' : ''}}" bindtap="onRepeatModeChange" data-value="custom">
                <text class="radio-pill-text">自定义星期</text>
              </view>
            </view>
          </view>
          <view wx:if="{{repeatMode === 'custom'}}" class="app-cell app-cell--col">
            <text class="app-cell-title">选择星期</text>
            <view class="weekday-wrap">
              <view class="weekday-grid">
                <view
                  wx:for="{{weekdayOptions}}"
                  wx:key="value"
                  class="weekday-pill {{weekdaySelected[item.value] ? 'weekday-pill--active' : ''}}"
                  data-value="{{item.value}}"
                  bindtap="onToggleCustomWeekday"
                >
                  {{item.label}}
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- ═══ Section 3: 提醒方式 ═══ -->
      <view class="editorial-head">
        <view class="editorial-head-main">提醒方式</view>
        <view class="editorial-head-tag">Notify</view>
      </view>
      <view class="editorial-head-sub">多通道提醒，按你的习惯组合</view>
      <view class="card reminder-card tap-scale editorial-module">
        <view class="app-cell-group">
          <view class="app-cell">
            <text class="app-cell-title">微信服务通知</text>
            <view class="toggle {{notify.wechat ? 'toggle--on' : ''}}" catchtap="noop" bindtap="onNotifyToggle" data-key="wechat">
              <view class="toggle-dot"></view>
            </view>
          </view>
          <view class="app-cell">
            <text class="app-cell-title">电话提醒</text>
            <view class="toggle {{phoneNotifyFake ? 'toggle--on' : ''}}" catchtap="noop" bindtap="onPhoneNotifyFakeTap">
              <view class="toggle-dot"></view>
            </view>
          </view>
          <view class="app-cell">
            <text class="app-cell-title">响铃提醒</text>
            <view class="toggle {{notify.ring ? 'toggle--on' : ''}}" catchtap="noop" bindtap="onNotifyToggle" data-key="ring">
              <view class="toggle-dot"></view>
            </view>
          </view>
          <view class="app-cell">
            <text class="app-cell-title">震动</text>
            <view class="toggle {{notify.vibrate ? 'toggle--on' : ''}}" catchtap="noop" bindtap="onNotifyToggle" data-key="vibrate">
              <view class="toggle-dot"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- ═══ Section 4: 手机日历 ═══ -->
      <view class="editorial-head">
        <view class="editorial-head-main">手机日历</view>
        <view class="editorial-head-tag">Calendar</view>
      </view>
      <view class="editorial-head-sub">同步系统级提醒，确保不错过</view>
      <view class="card calendar-card reminder-card tap-scale editorial-module editorial-module--feature">
        <view class="calendar-hint">
          按当前页面上的用药时间与重复规则，写入本机系统日历；到点由系统日历通知（请在系统设置中开启日历通知与铃声）。须在本页点击同步；修改用药方案后请到系统日历中手动删除旧事件。
        </view>
        <view class="btn btn--secondary tap-scale {{calendarSyncing || !calendarSyncSupported ? 'btn--disabled' : ''}}" bindtap="onSyncToPhoneCalendar">
          <text class="btn-text btn-text--secondary">{{calendarSyncing ? '正在写入…' : (calendarSyncSupported ? '同步到手机日历' : '当前环境不支持')}}</text>
        </view>
      </view>

      <!-- ═══ Section 5: AI 合理性检查 ═══ -->
      <view class="editorial-head">
        <view class="editorial-head-main">AI 合理性检查</view>
        <view class="editorial-head-tag">Insight</view>
      </view>
      <view class="editorial-head-sub">从公开资料评估方案合理性</view>
      <view class="card ai-check-card reminder-card tap-scale editorial-module editorial-module--feature">
        <view class="ai-check-hint">
          将使用深度思考与联网检索，从公开资料角度评估当前设置（仅供参考，不能替代医生与说明书）。
        </view>
        <view class="btn btn--secondary tap-scale {{aiCheckLoading ? 'btn--disabled' : ''}}" bindtap="onAiCheck">
          <text class="btn-text btn-text--secondary">{{aiCheckLoading ? '分析中…' : 'AI 检查合理性'}}</text>
        </view>

        <!-- 结果区域 -->
        <view wx:if="{{aiSuggestion}}" class="ai-result">
          <!-- 合理性标签 -->
          <view class="ai-verdict {{aiSuggestion.reasonable ? 'ai-verdict--ok' : 'ai-verdict--warn'}}">
            <view class="ai-verdict-icon">
              <view wx:if="{{aiSuggestion.reasonable}}" class="ai-verdict-check"></view>
              <view wx:else class="ai-verdict-cross"></view>
            </view>
            <text class="ai-verdict-text">{{aiSuggestion.summary}}</text>
          </view>

          <!-- 建议详情卡片 -->
          <view class="ai-detail-card">
            <view class="ai-detail-row" wx:if="{{aiSuggestion.suggestedDailyFrequency}}">
              <text class="ai-detail-label">建议频次</text>
              <text class="ai-detail-value">{{aiSuggestion.suggestedDailyFrequency}} 次/日</text>
            </view>
            <view class="ai-detail-row" wx:if="{{aiSuggestion.suggestedTimes && aiSuggestion.suggestedTimes.length}}">
              <text class="ai-detail-label">建议时间</text>
              <text class="ai-detail-value">{{aiSuggestion.suggestedTimes.join('、')}}</text>
            </view>
            <view class="ai-detail-row" wx:if="{{aiSuggestion.suggestedDoseText}}">
              <text class="ai-detail-label">建议用量</text>
              <text class="ai-detail-value">{{aiSuggestion.suggestedDoseText}}</text>
            </view>
            <view class="ai-detail-row" wx:if="{{aiSuggestion.suggestedMealTiming && aiSuggestion.suggestedMealTiming !== 'none'}}">
              <text class="ai-detail-label">进食关系</text>
              <text class="ai-detail-value">{{aiSuggestion.suggestedMealTiming === 'before' ? '饭前' : aiSuggestion.suggestedMealTiming === 'after' ? '饭后' : '空腹'}}</text>
            </view>
            <view class="ai-detail-row" wx:if="{{aiSuggestion.notes}}">
              <text class="ai-detail-label">补充说明</text>
              <text class="ai-detail-value">{{aiSuggestion.notes}}</text>
            </view>
          </view>

          <!-- AI 分析文本（可折叠） -->
          <view class="ai-analysis" wx:if="{{aiCheckResult}}">
            <view class="ai-analysis-toggle" bindtap="toggleAnalysis">
              <text class="ai-analysis-toggle-text">详细分析</text>
              <text class="ai-analysis-toggle-arrow {{analysisOpen ? 'ai-analysis-toggle-arrow--open' : ''}}">▶</text>
            </view>
            <view wx:if="{{analysisOpen}}" class="ai-analysis-body">
              <text class="ai-analysis-text" user-select>{{aiCheckResult}}</text>
            </view>
          </view>

          <!-- 思考过程（可折叠） -->
          <view class="ai-analysis" wx:if="{{aiCheckReasoning}}">
            <view class="ai-analysis-toggle" bindtap="toggleReasoning">
              <text class="ai-analysis-toggle-text">思考过程</text>
              <text class="ai-analysis-toggle-arrow {{reasoningOpen ? 'ai-analysis-toggle-arrow--open' : ''}}">▶</text>
            </view>
            <view wx:if="{{reasoningOpen}}" class="ai-analysis-body">
              <text class="ai-analysis-text" user-select>{{aiCheckReasoning}}</text>
            </view>
          </view>

          <!-- 采纳按钮 -->
          <view class="btn btn--primary tap-scale" bindtap="onAdoptAiSuggestion">
            <text class="btn-text">采纳建议并填入表单</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部保存按钮 -->
  <view class="bottom-bar reminder-bottom-bar">
    <view class="page-padding bottom-bar-inner reminder-bottom-inner">
      <view class="btn btn--primary tap-scale" bindtap="onSave">
        <text class="btn-text">保存提醒</text>
      </view>
    </view>
  </view>

  <!-- 每日次数选择弹层 -->
  <view wx:if="{{dailyFreqPopupVisible}}" class="popup-overlay" bindtap="closeDailyFreqPopup">
    <view class="popup-panel page-padding safe-bottom" catchtap="noop">
      <view class="popup-title">选择每日次数</view>
      <view class="popup-body">
        <view class="radio-group">
          <view class="radio-pill {{dailyFrequency === '1' ? 'radio-pill--active' : ''}}" bindtap="onDailyFreqSelect" data-value="1">
            <text class="radio-pill-text">1 次/日</text>
          </view>
          <view class="radio-pill {{dailyFrequency === '2' ? 'radio-pill--active' : ''}}" bindtap="onDailyFreqSelect" data-value="2">
            <text class="radio-pill-text">2 次/日</text>
          </view>
          <view class="radio-pill {{dailyFrequency === '3' ? 'radio-pill--active' : ''}}" bindtap="onDailyFreqSelect" data-value="3">
            <text class="radio-pill-text">3 次/日</text>
          </view>
          <view class="radio-pill {{dailyFrequency === '4' ? 'radio-pill--active' : ''}}" bindtap="onDailyFreqSelect" data-value="4">
            <text class="radio-pill-text">4 次/日</text>
          </view>
        </view>
      </view>
      <view class="popup-footer">
        <view class="btn btn--primary tap-scale" bindtap="closeDailyFreqPopup">
          <text class="btn-text">完成</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 饭前/饭后/空腹 选择弹层 -->
  <view wx:if="{{mealPopupVisible}}" class="popup-overlay" bindtap="closeMealPopup">
    <view class="popup-panel page-padding safe-bottom" catchtap="noop">
      <view class="popup-title">选择与进食关系</view>
      <view class="popup-body">
        <view class="radio-group">
          <view class="radio-pill {{mealTiming === 'none' ? 'radio-pill--active' : ''}}" bindtap="onMealTimingSelect" data-value="none">
            <text class="radio-pill-text">按医嘱/未指定</text>
          </view>
          <view class="radio-pill {{mealTiming === 'before' ? 'radio-pill--active' : ''}}" bindtap="onMealTimingSelect" data-value="before">
            <text class="radio-pill-text">饭前</text>
          </view>
          <view class="radio-pill {{mealTiming === 'after' ? 'radio-pill--active' : ''}}" bindtap="onMealTimingSelect" data-value="after">
            <text class="radio-pill-text">饭后</text>
          </view>
          <view class="radio-pill {{mealTiming === 'empty' ? 'radio-pill--active' : ''}}" bindtap="onMealTimingSelect" data-value="empty">
            <text class="radio-pill-text">空腹</text>
          </view>
        </view>
      </view>
      <view class="popup-footer">
        <view class="btn btn--primary tap-scale" bindtap="closeMealPopup">
          <text class="btn-text">完成</text>
        </view>
      </view>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
