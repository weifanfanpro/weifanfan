/* ═══ Reminder Setting — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F0F7FF;
}

.scrollarea {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.content {
  padding-bottom: calc(env(safe-area-inset-bottom) + 320rpx);
}

/* ═══ Hero ═══ */
.reminder-hero {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

/* 云朵 */
.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 120rpx;
  height: 40rpx;
  top: 20rpx;
  right: 20rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -28rpx;
  left: 20rpx;
}

.hero-cloud--2 {
  width: 80rpx;
  height: 28rpx;
  bottom: 30rpx;
  left: 40rpx;
  opacity: 0.6;
  animation: cloudFloat 10s ease-in-out infinite reverse;
}

/* 星星 */
.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { top: 16rpx; left: 80rpx; }
.hero-star--2 { bottom: 20rpx; right: 60rpx; animation-delay: 0.7s; width: 6rpx; height: 6rpx; }

/* 十字 */
.hero-cross {
  position: absolute;
  opacity: 0.15;
  pointer-events: none;
}

.hero-cross::before,
.hero-cross::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.hero-cross--1 {
  top: 24rpx;
  left: 24rpx;
  width: 16rpx;
  height: 16rpx;
}

.hero-cross--1::before {
  width: 100%;
  height: 30%;
  top: 35%;
  left: 0;
}

.hero-cross--1::after {
  width: 30%;
  height: 100%;
  top: 0;
  left: 35%;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.reminder-hero-top,
.reminder-hero .hero-title,
.reminder-hero .hero-sub,
.reminder-hero .hero-view-capsule {
  position: relative;
  z-index: 2;
}

.reminder-hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.hero-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.reminder-hero .hero-title {
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: 800;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.reminder-hero .hero-sub {
  color: rgba(255, 255, 255, 0.75);
  font-size: 24rpx;
}

.reminder-view-capsule {
  margin-top: 18rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.reminder-view-capsule .hero-view-capsule__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
}

.reminder-view-capsule .hero-view-capsule__text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
  font-weight: 500;
}

/* ═══ Editorial Heads ═══ */
.editorial-head {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.editorial-head-main {
  font-size: 34rpx;
  font-weight: 800;
  color: #1A3A5C;
  letter-spacing: 0.4rpx;
}

.editorial-head-tag {
  font-size: 20rpx;
  line-height: 1;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #4A9DFF;
  background: rgba(74, 157, 255, 0.08);
  border: 1rpx solid rgba(74, 157, 255, 0.15);
}

.editorial-head-sub {
  margin-top: 8rpx;
  margin-bottom: 12rpx;
  font-size: 23rpx;
  color: #8BA4C7;
  line-height: 1.45;
}

/* ═══ Cards ═══ */
.reminder-card {
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
  animation: reminderSectionIn 260ms ease both;
}

.editorial-module {
  position: relative;
  overflow: hidden;
}

.editorial-module::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(74, 157, 255, 0.03), rgba(74, 157, 255, 0));
  opacity: 0.5;
}

.editorial-module--feature::before {
  background: linear-gradient(160deg, rgba(74, 157, 255, 0.05), rgba(139, 164, 199, 0.03) 60%, rgba(255, 255, 255, 0));
  opacity: 0.6;
}

/* ═══ Cell Group ═══ */
.app-cell-group {
  position: relative;
  z-index: 1;
}

.app-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(74, 157, 255, 0.06);
  min-height: 88rpx;
  box-sizing: border-box;
}

.app-cell:last-child {
  border-bottom: none;
}

.app-cell--col {
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

.app-cell--arrow::after {
  content: '';
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid #B0C4DE;
  border-right: 2rpx solid #B0C4DE;
  transform: rotate(45deg);
  flex-shrink: 0;
  margin-left: 8rpx;
}

.app-cell-title {
  font-size: 28rpx;
  color: #1A3A5C;
  font-weight: 500;
}

.app-cell-note {
  font-size: 28rpx;
  color: #3D5A80;
  font-weight: 600;
}

.app-cell-input {
  text-align: right;
  font-size: 28rpx;
  color: #3D5A80;
  flex: 1;
  min-width: 0;
}

/* ═══ Radio Pills ═══ */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.radio-group--row {
  width: 100%;
}

.radio-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(74, 157, 255, 0.12);
  background: #FFFFFF;
  transition: all 200ms;
}

.radio-pill--active {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  border-color: #4A9DFF;
  box-shadow: 0 4rpx 16rpx rgba(74, 157, 255, 0.2);
}

.radio-pill-text {
  font-size: 26rpx;
  color: #3D5A80;
  font-weight: 500;
}

.radio-pill--active .radio-pill-text {
  color: #FFFFFF;
}

/* ═══ Toggle Switch ═══ */
.toggle {
  width: 88rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #D1E5FF;
  position: relative;
  transition: background 200ms;
  flex-shrink: 0;
}

.toggle--on {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
}

.toggle-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FFFFFF;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: transform 200ms;
}

.toggle--on .toggle-dot {
  transform: translateX(40rpx);
}

/* ═══ Weekday Pills ═══ */
.weekday-wrap {
  width: 100%;
}

.weekday-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx 12rpx;
  width: 100%;
}

.weekday-pill {
  min-width: 0;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #3D5A80;
  background: rgba(74, 157, 255, 0.04);
  border: 1rpx solid rgba(74, 157, 255, 0.1);
  transition: all 0.2s ease;
}

.weekday-pill--active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  border-color: #4A9DFF;
  box-shadow: 0 4rpx 16rpx rgba(74, 157, 255, 0.2);
}

/* ═══ Bottom Bar ═══ */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  border-top: none;
  padding-top: 16rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 12rpx);
}

.bottom-bar-inner {
  padding-bottom: 0;
}

.reminder-bottom-bar {
  background: rgba(240, 247, 255, 0.92);
  backdrop-filter: blur(10px);
}

.reminder-bottom-inner {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 -4rpx 24rpx rgba(43, 94, 167, 0.06);
}

/* ═══ Buttons ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease, opacity 150ms ease;
}

.btn:active {
  transform: scale(0.97);
}

.btn--primary {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
}

.btn--secondary {
  background: #E8F2FF;
  border: 1rpx solid rgba(74, 157, 255, 0.12);
}

.btn--disabled {
  opacity: 0.45;
  pointer-events: none;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.btn-text--secondary {
  color: #4A9DFF;
}

/* ═══ Popup ═══ */
.popup-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.popup-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding-top: 24rpx;
  box-shadow: 0 -8rpx 32rpx rgba(43, 94, 167, 0.1);
  border-top: 1rpx solid rgba(74, 157, 255, 0.08);
  animation: popupSlideUp 260ms ease-out;
}

@keyframes popupSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.popup-title {
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 24rpx;
  color: #1A3A5C;
}

.popup-body {
  margin-bottom: 32rpx;
}

.popup-footer {
  padding-bottom: 16rpx;
}

/* ═══ Calendar Card ═══ */
.calendar-card {
  padding: 24rpx;
  border-radius: 24rpx;
}

.calendar-hint {
  font-size: 24rpx;
  line-height: 1.55;
  color: #8BA4C7;
  margin-bottom: 20rpx;
}

/* ═══ AI Block ═══ */
.ai-check-card {
  padding: 24rpx;
  border-radius: 24rpx;
}

.ai-check-hint {
  font-size: 24rpx;
  line-height: 1.55;
  color: #8BA4C7;
  margin-bottom: 20rpx;
}

.ai-result {
  margin-top: 28rpx;
}

/* 合理性标签 */
.ai-verdict {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.ai-verdict--ok {
  background: rgba(76, 175, 80, 0.08);
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}

.ai-verdict--warn {
  background: rgba(255, 152, 0, 0.08);
  border: 1rpx solid rgba(255, 152, 0, 0.2);
}

.ai-verdict-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-verdict--ok .ai-verdict-icon {
  background: #4CAF50;
}

.ai-verdict--warn .ai-verdict-icon {
  background: #FF9800;
}

.ai-verdict-check {
  width: 16rpx;
  height: 10rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(-45deg) translate(2rpx, -2rpx);
}

.ai-verdict-cross {
  width: 18rpx;
  height: 18rpx;
  position: relative;
}

.ai-verdict-cross::before,
.ai-verdict-cross::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 3rpx;
  background: #fff;
  border-radius: 2rpx;
}

.ai-verdict-cross::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.ai-verdict-cross::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.ai-verdict-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A3A5C;
  line-height: 1.5;
}

/* 建议详情卡片 */
.ai-detail-card {
  background: rgba(74, 157, 255, 0.04);
  border: 1rpx solid rgba(74, 157, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.ai-detail-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(74, 157, 255, 0.06);
}

.ai-detail-row:last-child {
  border-bottom: none;
}

.ai-detail-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #3D5A80;
  width: 140rpx;
  flex-shrink: 0;
}

.ai-detail-value {
  font-size: 24rpx;
  color: #1A3A5C;
  flex: 1;
  line-height: 1.5;
}

/* 折叠区域 */
.ai-analysis {
  margin-bottom: 16rpx;
}

.ai-analysis-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: rgba(74, 157, 255, 0.04);
  border-radius: 12rpx;
}

.ai-analysis-toggle-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #3D5A80;
}

.ai-analysis-toggle-arrow {
  font-size: 20rpx;
  color: #4A9DFF;
  transition: transform 0.2s;
  transform: rotate(0deg);
}

.ai-analysis-toggle-arrow--open {
  transform: rotate(90deg);
}

.ai-analysis-body {
  padding: 20rpx;
  background: rgba(74, 157, 255, 0.02);
  border-radius: 0 0 12rpx 12rpx;
  margin-top: -8rpx;
}

.ai-analysis-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: #1A3A5C;
  white-space: pre-wrap;
  word-break: break-word;
}

@keyframes reminderSectionIn {
  from {
    opacity: 0;
    transform: translate3d(0, 12rpx, 0);
  }
  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .reminder-card { animation: none; }
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
  .popup-panel { animation: none; }
}
