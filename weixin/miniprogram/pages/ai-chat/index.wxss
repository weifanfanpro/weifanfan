/* ═══ AI Chat — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.scrollarea {
  height: 100vh;
  box-sizing: border-box;
}

.content {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.header {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  margin-top: 8rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

.header::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.header::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.drug-name {
  position: relative;
  z-index: 1;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #fffefb;
}

.view-hint {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 254, 251, 0.55);
}

.header-tags {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.collapse-card {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.collapse-card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.12);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.12);
  pointer-events: none;
  z-index: 1;
}

.panel-text {
  padding: 8rpx 10rpx 18rpx;
  font-size: 30rpx;
  color: #6b645c;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
}

.panel-list {
  padding: 8rpx 10rpx 18rpx;
}

.li {
  font-size: 30rpx;
  color: #6b645c;
  line-height: 1.7;
  margin: 8rpx 0;
}

.muted {
  color: #b0a99f;
}
