/* ═══ Points Order Detail — 蓝白卡通风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.mt2 {
  margin-top: 12rpx;
}

/* ═══ Card ═══ */
.order-card {
  position: relative;
  overflow: hidden;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.card-corner {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  pointer-events: none;
}

.card-corner--tl {
  top: 10rpx;
  left: 10rpx;
  border-top: 2rpx solid rgba(74, 157, 255, 0.15);
  border-left: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 4rpx 0 0 0;
}

.card-corner--br {
  bottom: 10rpx;
  right: 10rpx;
  border-bottom: 2rpx solid rgba(74, 157, 255, 0.15);
  border-right: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 0 0 4rpx 0;
}

.line {
  display: flex;
  justify-content: space-between;
  font-size: 25rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(74, 157, 255, 0.04);
}

.line:last-child {
  border-bottom: none;
}

.line-label {
  color: #8BA4C7;
}

.line-value {
  color: #1A3A5C;
  font-weight: 600;
}

.line-value--main {
  color: #4A9DFF;
  font-weight: 800;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A3A5C;
  margin-bottom: 8rpx;
}

.addr {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8BA4C7;
  line-height: 1.6;
}

/* ═══ Timeline ═══ */
.timeline-item {
  margin-top: 14rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #4A9DFF;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.timeline-text {
  font-size: 25rpx;
  color: #1A3A5C;
}

.timeline-sub {
  margin-top: 4rpx;
  color: #8BA4C7;
  font-size: 22rpx;
}

/* ═══ Bottom Bar ═══ */
.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(240, 247, 255, 0.92);
  backdrop-filter: blur(14px);
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
}

/* ═══ Buttons ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn--primary {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
}

.btn--ghost {
  background: transparent;
  border: 1rpx solid rgba(74, 157, 255, 0.15);
}

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.btn-text--ghost {
  color: #4A9DFF;
}
