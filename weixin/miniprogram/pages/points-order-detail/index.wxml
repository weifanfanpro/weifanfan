<view class="page page-padding detail-page">
  <custom-navbar title="订单详情" showBack="{true}" />
  <view wx:if="{{detail}}" class="card">
    <view class="line"><text>订单号</text><text>{{detail.orderId}}</text></view>
    <view class="line"><text>状态</text><text>{{detail.status}}</text></view>
    <view class="line"><text>消耗积分</text><text>{{detail.pointsCost}}</text></view>
    <view class="line"><text>扣后余额</text><text>{{detail.pointsBalanceAfter}}</text></view>
  </view>

  <view wx:if="{{detail && detail.addressMock}}" class="card mt">
    <view class="title">收货地址（模拟）</view>
    <view class="addr">{{detail.addressMock.receiver}} {{detail.addressMock.phone}}</view>
    <view class="addr">{{detail.addressMock.region}} {{detail.addressMock.detail}}</view>
  </view>

  <view wx:if="{{detail}}" class="card mt">
    <view class="title">物流状态</view>
    <view wx:for="{{detail.statusTimeline}}" wx:key="index" class="timeline-item">
      <view class="dot"></view>
      <view class="timeline-main">
        <view class="timeline-text">{{item.text}}</view>
        <view class="timeline-sub">{{item.status}}</view>
      </view>
    </view>
  </view>

  <view class="bottom" wx:if="{{detail}}">
    <t-button block theme="primary" bind:tap="onGoTransport">查看物流（运输页）</t-button>
    <view wx:if="{{detail.status === 'paid' || detail.status === 'packing' || detail.status === 'shipping'}}" class="mt2">
      <t-button block theme="default" loading="{{advancing}}" bind:tap="onAdvanceStatus">推进物流状态（模拟）</t-button>
    </view>
  </view>
</view>
