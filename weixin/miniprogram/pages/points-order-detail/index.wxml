<view class="page page-padding safe-bottom anim-in">
  <custom-navbar title="订单详情" showBack="{true}" />

  <view wx:if="{{detail}}" class="order-card">
    <view class="card-corner card-corner--tl"></view>
    <view class="card-corner card-corner--br"></view>
    <view class="line"><text class="line-label">订单号</text><text class="line-value">{{detail.orderId}}</text></view>
    <view class="line"><text class="line-label">状态</text><text class="line-value">{{detail.status}}</text></view>
    <view class="line"><text class="line-label">消耗积分</text><text class="line-value line-value--main">{{detail.pointsCost}}</text></view>
    <view class="line"><text class="line-label">扣后余额</text><text class="line-value">{{detail.pointsBalanceAfter}}</text></view>
  </view>

  <view wx:if="{{detail && detail.addressMock}}" class="order-card">
    <view class="card-corner card-corner--tl"></view>
    <view class="card-corner card-corner--br"></view>
    <view class="card-title">收货地址（模拟）</view>
    <view class="addr">{{detail.addressMock.receiver}} {{detail.addressMock.phone}}</view>
    <view class="addr">{{detail.addressMock.region}} {{detail.addressMock.detail}}</view>
  </view>

  <view wx:if="{{detail}}" class="order-card">
    <view class="card-corner card-corner--tl"></view>
    <view class="card-corner card-corner--br"></view>
    <view class="card-title">物流状态</view>
    <view wx:for="{{detail.statusTimeline}}" wx:key="index" class="timeline-item">
      <view class="dot"></view>
      <view class="timeline-main">
        <view class="timeline-text">{{item.text}}</view>
        <view class="timeline-sub">{{item.status}}</view>
      </view>
    </view>
  </view>

  <view class="bottom" wx:if="{{detail}}">
    <view class="btn btn--primary tap-scale" bindtap="onGoTransport">
      <text class="btn-text">查看物流（运输页）</text>
    </view>
    <view wx:if="{{detail.status === 'paid' || detail.status === 'packing' || detail.status === 'shipping'}}" class="mt2">
      <view class="btn btn--ghost tap-scale" bindtap="onAdvanceStatus">
        <text class="btn-text btn-text--ghost">{{advancing ? '推进中...' : '推进物流状态（模拟）'}}</text>
      </view>
    </view>
  </view>
</view>
