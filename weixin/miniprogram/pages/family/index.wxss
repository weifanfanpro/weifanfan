/* ═══ Family — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Hero ═══ */
.support-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 28rpx 28rpx 22rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { bottom: 20rpx; left: 50rpx; }

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.support-hero .hero-title,
.support-hero .hero-sub {
  position: relative;
  z-index: 2;
}

.support-hero .hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.support-hero .hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.75);
}

/* ═══ Mode Tabs ═══ */
.mode-tabs {
  display: flex;
  padding: 6rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #8BA4C7;
  transition: all 0.2s ease;
  font-weight: 500;
}

.mode-tab--active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(74, 157, 255, 0.25);
}

/* ═══ Status Tabs ═══ */
.status-tabs {
  display: flex;
  padding: 6rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.status-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #8BA4C7;
  transition: all 0.2s ease;
  font-weight: 500;
}

.status-tab--active {
  color: #4A9DFF;
  background: rgba(74, 157, 255, 0.08);
  font-weight: 600;
  border: 1rpx solid rgba(74, 157, 255, 0.15);
}

/* ═══ Empty State ═══ */
.empty-wrap {
  margin-top: 18rpx;
  padding: 48rpx 24rpx 40rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-buddy { margin-bottom: 16rpx; }

.empty-pill-body {
  position: relative;
  width: 64rpx;
  height: 84rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(74, 157, 255, 0.18);
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-pill-left {
  position: absolute; left: 0; top: 0; width: 50%; height: 100%;
  background: #FFFFFF;
}

.empty-pill-right {
  position: absolute; right: 0; top: 0; width: 50%; height: 100%;
  background: #4A9DFF;
}

.empty-pill-eye {
  position: absolute;
  width: 16rpx; height: 18rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 24rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0,0,0,0.06);
}

.empty-pill-left .empty-pill-eye { left: 8rpx; }
.empty-pill-right .empty-pill-eye { right: 8rpx; }

.empty-pill-pupil {
  position: absolute;
  width: 8rpx; height: 10rpx;
  background: #2B5EA7;
  border-radius: 50%;
  bottom: 3rpx;
  left: 50%;
  transform: translateX(-50%);
}

.empty-pill-mouth {
  position: absolute;
  bottom: 22rpx; left: 50%;
  transform: translateX(-50%);
  width: 14rpx; height: 6rpx;
  border-bottom: 2rpx solid #2B5EA7;
  border-radius: 0 0 50% 50%;
  z-index: 3;
}

.empty-title {
  font-size: 26rpx;
  color: #8BA4C7;
  font-weight: 500;
}

/* ═══ List ═══ */
.list-wrap {
  margin-top: 0;
}

.list-hint {
  padding: 16rpx 18rpx;
  font-size: 22rpx;
  color: #8BA4C7;
  border-bottom: 1rpx solid rgba(74, 157, 255, 0.06);
  background: #FFFFFF;
  border-radius: 22rpx 22rpx 0 0;
}

.family-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.family-card {
  border-radius: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
  padding: 24rpx;
  overflow: hidden;
}

.family-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.family-card-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.family-card-info {
  flex: 1;
  min-width: 0;
}

.family-card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A5C;
  line-height: 1.4;
}

.family-card-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #3D5A80;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(74, 157, 255, 0.06);
}

.family-card-meta {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(74, 157, 255, 0.06);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #8BA4C7;
}

/* ═══ Icons ═══ */
.icon-pill {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFFFFF 50%, #4A9DFF 50%);
  border: 2rpx solid rgba(74, 157, 255, 0.2);
  flex-shrink: 0;
}

.icon-send {
  width: 0;
  height: 0;
  border-left: 16rpx solid #4A9DFF;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* ═══ Tags ═══ */
.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.tag--warning { color: #FFB366; background: rgba(255, 179, 102, 0.08); }
.tag--success { color: #52D9A0; background: rgba(82, 217, 160, 0.08); }
.tag--default { color: #8BA4C7; background: rgba(139, 164, 199, 0.08); }

/* ═══ Button ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn--primary {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
}

.btn--ghost {
  background: transparent;
  border: 1rpx solid rgba(74, 157, 255, 0.15);
}

.btn--small {
  height: 60rpx;
  padding: 0 28rpx;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.btn-text--ghost {
  color: #4A9DFF;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
  .empty-pill-body { animation: none; }
}
