/* ═══ Family — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.support-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

.support-hero::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.support-hero::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.support-hero-glow {
  position: absolute;
  right: -80rpx;
  top: -78rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46, 158, 143, 0.12), rgba(46, 158, 143, 0));
}

.support-hero .hero-title,
.support-hero .hero-sub {
  position: relative;
  z-index: 1;
}

.support-hero .hero-title {
  color: #fffefb;
}

.support-hero .hero-sub {
  color: rgba(255, 254, 251, 0.55);
}

.panel {
  position: relative;
  padding-top: 8rpx;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.panel::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.12);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.12);
  pointer-events: none;
  z-index: 1;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.current-view-card,
.relation-card {
  border-radius: 24rpx;
}

.view-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.view-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(91, 122, 107, 0.08);
  border: 1rpx solid rgba(91, 122, 107, 0.15);
  color: #1c1917;
}

.pill-text {
  font-size: 26rpx;
  font-weight: 600;
}

.switch-wrap {
  display: flex;
  align-items: center;
}

.code-box {
  border-radius: 20rpx;
  border: 1rpx dashed rgba(28, 25, 23, 0.1);
  padding: 18rpx;
  background: rgba(91, 122, 107, 0.04);
}

.code-label {
  font-size: 24rpx;
  color: #b0a99f;
}

.code {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  color: #1c1917;
  word-break: break-all;
}

.li {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-wrap {
  padding: 24rpx 0;
}

.mode-tabs {
  display: flex;
  padding: 6rpx;
  margin-bottom: 16rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #6b645c;
  transition: all 0.2s ease;
}

.mode-tab--active {
  color: #fffefb;
  background: linear-gradient(135deg, #2E9E8F, #d4845a);
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(46, 158, 143, 0.2);
}

.status-tabs {
  display: flex;
  padding: 6rpx;
  margin-bottom: 16rpx;
}

.status-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #6b645c;
  transition: all 0.2s ease;
}

.status-tab--active {
  color: #2E9E8F;
  background: rgba(46, 158, 143, 0.08);
  font-weight: 600;
  border: 1rpx solid rgba(46, 158, 143, 0.15);
}

.list-hint {
  padding: 16rpx 18rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.05);
}

.note {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.note-col {
  align-items: flex-end;
}

.action-row {
  display: flex;
  gap: 12rpx;
}

.time-text {
  font-size: 22rpx;
  color: #b0a99f;
}
