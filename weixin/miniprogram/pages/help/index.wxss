/* ═══ Help — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Hero ═══ */
.help-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 28rpx 28rpx 22rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { bottom: 20rpx; left: 50rpx; }

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.help-hero .hero-title,
.help-hero .hero-sub {
  position: relative;
  z-index: 2;
}

.help-hero .hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.help-hero .hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.75);
}

/* ═══ Quick Start Card ═══ */
.quick-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(74, 157, 255, 0.08), rgba(109, 184, 255, 0.04));
  border: 1rpx solid rgba(74, 157, 255, 0.12);
}

.quick-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.quick-icon-pill {
  width: 28rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #FFFFFF 50%, rgba(255,255,255,0.5) 50%);
}

.quick-info { flex: 1; }

.quick-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A3A5C;
}

.quick-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #8BA4C7;
}

/* ═══ Steps Flow ═══ */
.steps-flow {
  padding: 0 12rpx;
  margin-bottom: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(74, 157, 255, 0.25);
}

.step-content {
  flex: 1;
  padding: 4rpx 0 20rpx;
}

.step-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A3A5C;
}

.step-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #8BA4C7;
  line-height: 1.5;
}

.step-line {
  width: 2rpx;
  height: 20rpx;
  background: rgba(74, 157, 255, 0.2);
  margin-left: 21rpx;
  margin-bottom: 0;
}

/* ═══ Section Label ═══ */
.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A3A5C;
  margin-bottom: 12rpx;
}

/* ═══ FAQ Card ═══ */
.faq-card {
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.05);
  margin-bottom: 12rpx;
  overflow: hidden;
  transition: box-shadow 0.2s ease;
}

.faq-card--open {
  box-shadow: 0 6rpx 24rpx rgba(74, 157, 255, 0.12);
  border-color: rgba(74, 157, 255, 0.15);
}

.faq-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 20rpx;
}

/* ═══ FAQ Icons ═══ */
.faq-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.faq-icon--scan { background: rgba(74, 157, 255, 0.1); }
.faq-icon--family { background: rgba(255, 107, 107, 0.1); }
.faq-icon--pharmacy { background: rgba(82, 217, 160, 0.1); }
.faq-icon--safe { background: rgba(255, 179, 102, 0.1); }

/* Scan icon */
.icon-scan-box {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #4A9DFF;
  border-radius: 4rpx;
  position: relative;
}

.icon-scan-line {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  height: 2rpx;
  background: #4A9DFF;
  top: 50%;
  transform: translateY(-50%);
  animation: scanMove 2s ease-in-out infinite;
}

@keyframes scanMove {
  0%, 100% { top: 20%; }
  50% { top: 80%; }
}

/* Family icon */
.icon-family-heart {
  width: 20rpx;
  height: 18rpx;
  position: relative;
}

.icon-family-heart::before,
.icon-family-heart::after {
  content: '';
  position: absolute;
  top: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FF6B6B;
}

.icon-family-heart::before { left: 0; }
.icon-family-heart::after { right: 0; }

.icon-family-heart::before {
  transform: rotate(-45deg);
  transform-origin: bottom right;
}

.icon-family-heart::after {
  transform: rotate(45deg);
  transform-origin: bottom left;
}

/* Pharmacy icon */
.icon-pharmacy-pin {
  width: 16rpx;
  height: 20rpx;
  background: #52D9A0;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
}

/* Safe icon */
.icon-safe-shield {
  width: 20rpx;
  height: 22rpx;
  border: 3rpx solid #FFB366;
  border-radius: 0 0 50% 50%;
  position: relative;
}

.icon-safe-shield::after {
  content: '';
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 3rpx;
  height: 8rpx;
  background: #FFB366;
  border-radius: 2rpx;
}

/* ═══ FAQ Title ═══ */
.faq-title-wrap { flex: 1; min-width: 0; }

.faq-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A3A5C;
}

.faq-brief {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8BA4C7;
}

/* ═══ Arrow ═══ */
.faq-arrow {
  flex-shrink: 0;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid #8BA4C7;
  transition: transform 0.2s ease;
}

.faq-arrow--up {
  transform: rotate(180deg);
}

/* ═══ FAQ Body ═══ */
.faq-body {
  padding: 0 20rpx 20rpx;
  animation: expandIn 0.2s ease;
}

@keyframes expandIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.faq-text {
  background: rgba(74, 157, 255, 0.03);
  border-radius: 16rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(74, 157, 255, 0.06);
}

.faq-step {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #3D5A80;
  line-height: 1.6;
}

.faq-step + .faq-step {
  border-top: 1rpx solid rgba(74, 157, 255, 0.06);
}

.faq-step-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.faq-note {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 179, 102, 0.06);
  border: 1rpx solid rgba(255, 179, 102, 0.1);
  font-size: 22rpx;
  color: #8BA4C7;
  line-height: 1.5;
}

.faq-action {
  margin-top: 16rpx;
}

/* ═══ Buttons ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
  margin-top: 16rpx;
}

.btn:active { transform: scale(0.97); }

.btn--primary {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
}

.btn--ghost {
  background: transparent;
  border: 1rpx solid rgba(74, 157, 255, 0.15);
}

.btn--small {
  height: 60rpx;
  padding: 0 28rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.btn-text--ghost { color: #4A9DFF; }

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
  .icon-scan-line { animation: none; }
  .faq-body { animation: none; }
}
