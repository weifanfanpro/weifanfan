/* ═══ Help / FAQ — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.support-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

.support-hero::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.support-hero::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.support-hero-glow {
  position: absolute;
  right: -80rpx;
  top: -78rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46, 158, 143, 0.12), rgba(46, 158, 143, 0));
}

.support-hero .hero-title,
.support-hero .hero-sub {
  position: relative;
  z-index: 1;
}

.support-hero .hero-title {
  color: #fffefb;
  font-size: 38rpx;
  font-weight: 800;
}

.support-hero .hero-sub {
  color: rgba(255, 254, 251, 0.55);
  font-size: 24rpx;
}

.sub {
  margin: 8rpx 0 16rpx;
  font-size: 32rpx;
}

.faq-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.faq-card::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 10rpx;
  height: 10rpx;
  border: 1.5rpx solid rgba(91, 122, 107, 0.2);
  transform: rotate(45deg);
  pointer-events: none;
  z-index: 1;
}

.faq-head {
  padding: 16rpx 20rpx 6rpx;
}

.faq-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1917;
}

.faq-sub {
  margin-top: 4rpx;
}

.txt {
  padding: 16rpx 8rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #6b645c;
  border-radius: 20rpx;
  background: #f5f2ed;
  border: 1rpx solid rgba(28, 25, 23, 0.04);
}

.mt {
  margin-top: 16rpx;
}

.actions-float {
  margin-top: 18rpx;
  padding: 12rpx;
  border-radius: 20rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(28, 25, 23, 0.03);
}
