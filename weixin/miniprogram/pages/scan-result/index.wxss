/* ═══ Scan Result — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F0F7FF;
}

.scrollarea {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.content {
  padding-bottom: calc(env(safe-area-inset-bottom) + 320rpx);
}

/* ═══ Hint ═══ */
.hint-row {
  margin: 16rpx 0 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(74, 157, 255, 0.06);
  border: 1rpx solid rgba(74, 157, 255, 0.12);
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.hint-icon {
  width: 30rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: #4A9DFF;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
  line-height: 30rpx;
  flex-shrink: 0;
}

.hint-text {
  font-size: 24rpx;
  color: #3D5A80;
  line-height: 1.5;
}

/* ═══ Hero ═══ */
.result-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 24rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
  animation: sectionIn 260ms ease both;
}

/* 云朵 */
.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

/* 星星 */
.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { bottom: 20rpx; left: 50rpx; }

/* 十字 */
.hero-cross {
  position: absolute;
  opacity: 0.15;
  pointer-events: none;
}

.hero-cross::before,
.hero-cross::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.hero-cross--1 {
  top: 20rpx;
  left: 30rpx;
  width: 14rpx;
  height: 14rpx;
}

.hero-cross--1::before {
  width: 100%;
  height: 30%;
  top: 35%;
  left: 0;
}

.hero-cross--1::after {
  width: 30%;
  height: 100%;
  top: 0;
  left: 35%;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.result-hero-head,
.result-hero-title,
.result-hero-sub,
.result-hero-badges {
  position: relative;
  z-index: 2;
}

.result-hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-hero-label {
  font-size: 22rpx;
  line-height: 1;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.8);
}

.result-hero-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.result-hero-title {
  margin-top: 20rpx;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.2;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.result-hero-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.result-hero-badges {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hero-badge {
  font-size: 22rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.85);
  font-weight: 600;
}

.hero-badge--light {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.12);
}

/* ═══ Section Cards ═══ */
.section-card {
  position: relative;
  margin-top: 18rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
  animation: sectionIn 300ms ease both;
  overflow: hidden;
}

.section-card--base {
  margin-top: 20rpx;
}

.section-card--risk {
  border-color: rgba(255, 107, 107, 0.15);
  background: linear-gradient(180deg, rgba(255, 107, 107, 0.03), #FFFFFF);
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title-main {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A3A5C;
}

.section-title-tag {
  font-size: 20rpx;
  line-height: 1;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #4A9DFF;
  background: rgba(74, 157, 255, 0.08);
  border: 1rpx solid rgba(74, 157, 255, 0.15);
  font-weight: 600;
}

.section-title-tag--risk {
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.08);
  border-color: rgba(255, 107, 107, 0.15);
}

.info-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.info-item {
  border-radius: 16rpx;
  background: rgba(74, 157, 255, 0.03);
  border: 1rpx solid rgba(74, 157, 255, 0.06);
  padding: 16rpx;
}

.info-label {
  font-size: 22rpx;
  color: #8BA4C7;
}

.info-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #1A3A5C;
  line-height: 1.45;
  word-break: break-word;
  font-weight: 600;
}

.detail-block {
  margin-top: 18rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #8BA4C7;
}

.detail-text {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #1A3A5C;
  line-height: 1.6;
  word-break: break-word;
}

.warning-list {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 107, 107, 0.04);
}

.warning-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  background: #FF6B6B;
  flex-shrink: 0;
}

.warning-text {
  font-size: 24rpx;
  color: #3D5A80;
  line-height: 1.55;
}

/* ═══ Bottom Bar ═══ */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 12rpx);
  border-top: none;
  backdrop-filter: blur(14px);
  background: rgba(240, 247, 255, 0.92);
}

.action-wrap {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 -8rpx 32rpx rgba(43, 94, 167, 0.06);
}

.action-gap {
  height: 16rpx;
}

.action-row-secondary {
  display: flex;
  gap: 16rpx;
}

/* ═══ Button ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
}

.btn:active {
  transform: scale(0.97);
}

.btn--primary {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
}

.btn--secondary {
  background: #E8F2FF;
  border: 1rpx solid rgba(74, 157, 255, 0.12);
}

.btn--accent {
  background: rgba(82, 217, 160, 0.08);
  border: 1rpx solid rgba(82, 217, 160, 0.2);
}

.btn--half {
  flex: 1;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.btn-text--secondary {
  color: #4A9DFF;
  font-size: 26rpx;
}

.btn-text--accent {
  color: #52D9A0;
  font-size: 26rpx;
}

/* ═══ Animation ═══ */
@keyframes sectionIn {
  from {
    opacity: 0;
    transform: translate3d(0, 14rpx, 0);
  }
  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .result-hero,
  .section-card {
    animation: none;
  }
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
}
