<view class="page page-padding safe-bottom anim-in">
  <custom-navbar title="关于" showBack="{true}" />

  <!-- 蓝色渐变 Hero -->
  <view class="about-hero">
    <view class="hero-cloud hero-cloud--1"></view>
    <view class="hero-star hero-star--1"></view>
    <view class="hero-title">关于 / 反馈</view>
    <view class="hero-sub">欢迎反馈问题与建议。</view>
  </view>

  <!-- 产品信息 -->
  <view class="card info-card">
    <view class="info-row">
      <view class="info-label">产品名称</view>
      <view class="info-value">智药助理（小程序）</view>
    </view>
    <view class="info-row">
      <view class="info-label">版本</view>
      <view class="info-value">0.1.0（UI 原型）</view>
    </view>
    <view class="info-row info-row--last">
      <view class="info-label">隐私与安全</view>
      <view class="info-value">不采集敏感信息（后端接入后会补充说明）</view>
    </view>
  </view>

  <!-- 意见反馈 -->
  <view class="section-title">意见反馈</view>
  <view class="card feedback-card">
    <textarea
      class="feedback-textarea"
      value="{{feedback}}"
      placeholder="例如：希望增加更大的按钮、增加漏服提醒…"
      bindinput="onChange"
      auto-height
      maxlength="500"
    />
    <view class="feedback-footer">
      <text class="feedback-count">{{feedback.length || 0}}/500</text>
    </view>
    <view class="btn btn--primary tap-scale" bindtap="onSubmit">
      <text class="btn-text">提交反馈</text>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
