/* ═══ About / Feedback — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Hero ═══ */
.about-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 28rpx 28rpx 22rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { bottom: 20rpx; left: 50rpx; }

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.about-hero .hero-title,
.about-hero .hero-sub {
  position: relative;
  z-index: 2;
}

.about-hero .hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.about-hero .hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.75);
}

/* ═══ Card ═══ */
.card {
  border-radius: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

/* ═══ Info Card ═══ */
.info-card {
  overflow: hidden;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid rgba(74, 157, 255, 0.06);
  gap: 20rpx;
}

.info-row--last { border-bottom: none; }

.info-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A3A5C;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #8BA4C7;
  text-align: right;
  flex: 1;
}

/* ═══ Section Title ═══ */
.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1A3A5C;
  margin-bottom: 12rpx;
}

/* ═══ Feedback Card ═══ */
.feedback-card {
  padding: 24rpx;
}

.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(74, 157, 255, 0.12);
  background: rgba(74, 157, 255, 0.03);
  font-size: 28rpx;
  color: #1A3A5C;
  line-height: 1.6;
  box-sizing: border-box;
}

.feedback-textarea-placeholder {
  color: #8BA4C7;
}

.feedback-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
  margin-bottom: 16rpx;
}

.feedback-count {
  font-size: 22rpx;
  color: #8BA4C7;
}

/* ═══ Button ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn--primary {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
}

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
}
