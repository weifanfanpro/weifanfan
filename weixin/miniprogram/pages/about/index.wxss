/* ═══ About / Feedback — 暖调古典 ═══ */
.sub {
  margin: 8rpx 0 16rpx;
  font-size: 32rpx;
}

.card {
  position: relative;
  border-radius: 22rpx;
  overflow: hidden;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(28, 25, 23, 0.06);
  border-right: 1.5rpx solid rgba(28, 25, 23, 0.06);
  pointer-events: none;
  z-index: 1;
}

.pad {
  padding: 24rpx;
  box-sizing: border-box;
  background: #fffefb;
}

.mt {
  margin-top: 16rpx;
}
