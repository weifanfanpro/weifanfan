<view class="page anim-in">
  <custom-navbar title="添加药品" showBack="{true}" />
  <scroll-view class="scrollarea" scroll-y type="list" enhanced="{{true}}" bounces="{{true}}">
    <view class="page-padding safe-bottom content">
      <view class="add-hero">
        <view class="add-hero-glow"></view>
        <view class="add-hero-top">
        </view>
        <view class="add-hero-title">添加药品</view>
        <view class="add-hero-sub">先录入基础信息，后续再设置提醒。</view>
      </view>

      <view class="step-card">
        <view class="step-head">
          <view class="step-index">Step 1</view>
          <view class="step-title">填写药品名称</view>
        </view>
        <view class="step-body">
          <t-input
            value="{{name}}"
            placeholder="请输入药品名称"
            borderless="{{true}}"
            class="name-input"
            bind:change="onNameChange"
          />
        </view>
      </view>

      <view class="step-card">
        <view class="step-head">
          <view class="step-index">Step 2</view>
          <view class="step-title">填写用药规则（可选）</view>
        </view>
        <view class="step-body">
          <view class="sub-hint muted small">描述用法用量，例如"每日3次，每次2片，饭后服用"。</view>
          <t-input
            value="{{rule}}"
            placeholder="例如：每日3次，每次2片，饭后服用"
            borderless="{{true}}"
            class="name-input"
            bind:change="onRuleChange"
          />
        </view>
      </view>

      <view class="step-card">
        <view class="step-head">
          <view class="step-index">Step 3</view>
          <view class="step-title">选择药品类型</view>
        </view>
        <view class="step-body">
          <t-radio-group value="{{isQuantifiable ? '1' : '0'}}" bind:change="onQuantifiableChange">
            <view class="type-option-row">
              <label class="type-option {{isQuantifiable ? 'type-option--active' : ''}}">
                <t-radio value="1">可量化</t-radio>
              </label>
              <label class="type-option {{!isQuantifiable ? 'type-option--active' : ''}}">
                <t-radio value="0">不可量化</t-radio>
              </label>
            </view>
          </t-radio-group>
          <view class="type-tip-grid">
            <view class="type-tip-card">
              <view class="type-tip-card-title">可量化</view>
              <view class="type-tip-card-text">能明确到每次几片、几袋、几毫升，并可记录总量。</view>
            </view>
            <view class="type-tip-card type-tip-card--muted">
              <view class="type-tip-card-title">不可量化</view>
              <view class="type-tip-card-text">只能写每次适量或按需使用，不记录总量。</view>
            </view>
          </view>
        </view>
      </view>

      <view class="step-card">
        <view class="step-head">
          <view class="step-index">Step 4</view>
          <view class="step-title">每次用量（可选）</view>
        </view>
        <view class="step-body">
          <view class="sub-hint muted small">填写单次用量，例如"每次2片"或"每次适量"。</view>
          <t-input
            value="{{doseText}}"
            placeholder="{{isQuantifiable ? '例如：每次 2 片' : '每次适量'}}"
            borderless="{{true}}"
            class="name-input"
            bind:change="onDoseTextChange"
          />
        </view>
      </view>

      <view wx:if="{{isQuantifiable}}" class="step-card">
        <view class="step-head">
          <view class="step-index">Step 5</view>
          <view class="step-title">药品总量（可选）</view>
        </view>
        <view class="step-body">
          <view class="sub-hint muted small">填写药品总量，便于管理库存。</view>
          <t-input
            value="{{totalAmountText}}"
            placeholder="例如：总量 30 片 / 2 瓶"
            borderless="{{true}}"
            class="name-input"
            bind:change="onTotalAmountTextChange"
          />
        </view>
      </view>

      <view class="step-card">
        <view class="step-head">
          <view class="step-index">确认</view>
          <view class="step-title">确认并进入提醒设置</view>
        </view>
        <view class="step-body">
          <view class="confirm-line">药品名称：{{name || '未填写'}}</view>
          <view class="confirm-line">用药规则：{{rule || '未填写'}}</view>
          <view class="confirm-line">药品类型：{{isQuantifiable ? '可量化' : '不可量化'}}</view>
          <view class="confirm-line" wx:if="{{doseText}}">每次用量：{{doseText}}</view>
          <view class="confirm-line" wx:if="{{isQuantifiable && totalAmountText}}">药品总量：{{totalAmountText}}</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar add-bottom-bar">
    <view class="page-padding safe-bottom add-bottom-inner">
      <t-button theme="primary" size="large" block disabled="{{!name}}" class="add-next-btn tap-scale" bind:tap="goNext">
        下一步：设置服药提醒
      </t-button>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
