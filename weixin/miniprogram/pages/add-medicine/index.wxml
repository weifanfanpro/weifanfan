<view class="page anim-in">
  <custom-navbar title="添加药品" showBack="{true}" />
  <scroll-view class="scrollarea" scroll-y type="list" enhanced="{{true}}" bounces="{{true}}">
    <view class="page-padding safe-bottom content">
      <!-- 蓝色渐变 Hero -->
      <view class="add-hero">
        <view class="hero-cloud hero-cloud--1"></view>
        <view class="hero-cloud hero-cloud--2"></view>
        <view class="hero-star hero-star--1"></view>
        <view class="hero-star hero-star--2"></view>
        <view class="hero-cross hero-cross--1"></view>
        <view class="add-hero-title">添加药品</view>
        <view class="add-hero-sub">先录入基础信息，后续再设置提醒。</view>
      </view>

      <!-- Step 1: 药品名称 -->
      <view class="step-card">
        <view class="step-head">
          <view class="step-index">Step 1</view>
          <view class="step-title">填写药品名称</view>
        </view>
        <view class="step-body">
          <input class="app-input" value="{{name}}" placeholder="请输入药品名称" bindinput="onNameChange" />
        </view>
      </view>

      <!-- Step 2: 用药规则 -->
      <view class="step-card">
        <view class="step-head">
          <view class="step-index">Step 2</view>
          <view class="step-title">填写用药方式</view>
        </view>
        <view class="step-body">
          <view class="sub-hint">填写用药方式，例如"口服"、"外用"、"静脉注射"等。</view>
          <input class="app-input" value="{{rule}}" placeholder="例如：口服、外用、舌下含服" bindinput="onRuleChange" />
        </view>
      </view>

      <!-- Step 3: 药品类型 -->
      <view class="step-card">
        <view class="step-head">
          <view class="step-index">Step 3</view>
          <view class="step-title">选择药品类型</view>
        </view>
        <view class="step-body">
          <view class="type-option-row">
            <view class="type-option {{isQuantifiable ? 'type-option--active' : ''}}" bindtap="onQuantifiableChange" data-value="1">
              <view class="type-option-dot {{isQuantifiable ? 'type-option-dot--active' : ''}}"></view>
              <text class="type-option-text">可量化</text>
            </view>
            <view class="type-option {{!isQuantifiable ? 'type-option--active' : ''}}" bindtap="onQuantifiableChange" data-value="0">
              <view class="type-option-dot {{!isQuantifiable ? 'type-option-dot--active' : ''}}"></view>
              <text class="type-option-text">不可量化</text>
            </view>
          </view>
          <view class="type-tip-grid">
            <view class="type-tip-card">
              <view class="type-tip-card-title">可量化</view>
              <view class="type-tip-card-text">能明确到每次几片、几袋、几毫升，并可记录总量。</view>
            </view>
            <view class="type-tip-card type-tip-card--muted">
              <view class="type-tip-card-title">不可量化</view>
              <view class="type-tip-card-text">只能写每次适量或按需使用，不记录总量。</view>
            </view>
          </view>
        </view>
      </view>

      <!-- Step 4: 每次用量 -->
      <view class="step-card">
        <view class="step-head">
          <view class="step-index">Step 4</view>
          <view class="step-title">每次用量</view>
        </view>
        <view class="step-body">
          <view class="sub-hint">填写单次用量，例如"每次2片"或"每次适量"。</view>
          <input class="app-input" value="{{doseText}}" placeholder="{{isQuantifiable ? '例如：每次 2 片' : '每次适量'}}" bindinput="onDoseTextChange" />
        </view>
      </view>

      <!-- Step 5: 药品总量（条件显示） -->
      <view wx:if="{{isQuantifiable}}" class="step-card">
        <view class="step-head">
          <view class="step-index">Step 5</view>
          <view class="step-title">药品总量</view>
        </view>
        <view class="step-body">
          <view class="sub-hint">填写药品总量，便于管理库存。</view>
          <input class="app-input" value="{{totalAmountText}}" placeholder="例如：总量 30 片 / 2 瓶" bindinput="onTotalAmountTextChange" />
        </view>
      </view>

      <!-- 确认卡片 -->
      <view class="step-card">
        <view class="step-head">
          <view class="step-index">确认</view>
          <view class="step-title">确认并进入提醒设置</view>
        </view>
        <view class="step-body">
          <view class="confirm-line">药品名称：{{name || '未填写'}}</view>
          <view class="confirm-line">用药规则：{{rule || '未填写'}}</view>
          <view class="confirm-line">药品类型：{{isQuantifiable ? '可量化' : '不可量化'}}</view>
          <view class="confirm-line" wx:if="{{doseText}}">每次用量：{{doseText}}</view>
          <view class="confirm-line" wx:if="{{isQuantifiable && totalAmountText}}">药品总量：{{totalAmountText}}</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部按钮栏 -->
  <view class="bottom-bar add-bottom-bar">
    <view class="page-padding safe-bottom add-bottom-inner">
      <view class="btn btn--primary {{!name ? 'btn--disabled' : ''}} tap-scale" bindtap="goNext">
        <text class="btn-text">下一步：设置服药提醒</text>
      </view>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
