/* ═══ Family Bind — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Hero ═══ */
.bind-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 28rpx 28rpx 22rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { bottom: 20rpx; left: 50rpx; }

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.bind-hero .hero-title,
.bind-hero .hero-sub {
  position: relative;
  z-index: 2;
}

.bind-hero .hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.bind-hero .hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.75);
}

/* ═══ Card ═══ */
.card {
  border-radius: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

/* ═══ View Card ═══ */
.view-card {
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.view-label {
  font-size: 24rpx;
  color: #8BA4C7;
  margin-bottom: 10rpx;
}

.view-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.view-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.view-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F2FF, #A8DAFF);
}

.view-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A3A5C;
}

/* ═══ Tabs ═══ */
.tabs {
  display: flex;
  padding: 6rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #8BA4C7;
  transition: all 0.2s ease;
  font-weight: 500;
}

.tab--active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(74, 157, 255, 0.25);
}

/* ═══ Tab Panel ═══ */
.tab-panel {
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.panel-hint {
  font-size: 24rpx;
  color: #8BA4C7;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

/* ═══ Section Title ═══ */
.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1A3A5C;
  margin: 20rpx 0 12rpx;
}

/* ═══ Code Card ═══ */
.code-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(74, 157, 255, 0.04);
  border: 1rpx solid rgba(74, 157, 255, 0.1);
  margin-bottom: 8rpx;
}

.code-label {
  font-size: 24rpx;
  color: #8BA4C7;
  margin-bottom: 8rpx;
}

.code-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A3A5C;
  word-break: break-all;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  margin-bottom: 16rpx;
}

/* ═══ Empty State ═══ */
.empty-wrap {
  margin-top: 20rpx;
  padding: 48rpx 24rpx 40rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-buddy { margin-bottom: 16rpx; }

.empty-pill-body {
  position: relative;
  width: 64rpx;
  height: 84rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(74, 157, 255, 0.18);
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-pill-left {
  position: absolute; left: 0; top: 0; width: 50%; height: 100%;
  background: #FFFFFF;
}

.empty-pill-right {
  position: absolute; right: 0; top: 0; width: 50%; height: 100%;
  background: #4A9DFF;
}

.empty-pill-eye {
  position: absolute;
  width: 16rpx; height: 18rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 24rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0,0,0,0.06);
}

.empty-pill-left .empty-pill-eye { left: 8rpx; }
.empty-pill-right .empty-pill-eye { right: 8rpx; }

.empty-pill-pupil {
  position: absolute;
  width: 8rpx; height: 10rpx;
  background: #2B5EA7;
  border-radius: 50%;
  bottom: 3rpx;
  left: 50%;
  transform: translateX(-50%);
}

.empty-pill-mouth {
  position: absolute;
  bottom: 22rpx; left: 50%;
  transform: translateX(-50%);
  width: 14rpx; height: 6rpx;
  border-bottom: 2rpx solid #2B5EA7;
  border-radius: 0 0 50% 50%;
  z-index: 3;
}

.empty-title {
  font-size: 26rpx;
  color: #8BA4C7;
  font-weight: 500;
}

/* ═══ Member List ═══ */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.05);
}

.member-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid rgba(74, 157, 255, 0.15);
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A3A5C;
}

.member-sub {
  font-size: 22rpx;
  color: #8BA4C7;
  margin-top: 2rpx;
}

/* ═══ Tags ═══ */
.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.tag--active { color: #4A9DFF; background: rgba(74, 157, 255, 0.08); }

/* ═══ Buttons ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
  margin-bottom: 12rpx;
}

.btn:active { transform: scale(0.97); }

.btn--primary {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
}

.btn--ghost {
  background: transparent;
  border: 1rpx solid rgba(74, 157, 255, 0.15);
}

.btn--danger {
  background: transparent;
  border: 1rpx solid rgba(255, 107, 107, 0.2);
}

.btn--small {
  height: 56rpx;
  padding: 0 24rpx;
  margin-bottom: 0;
}

.btn--tiny {
  height: 48rpx;
  padding: 0 18rpx;
  margin-bottom: 0;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.btn-text--ghost { color: #4A9DFF; }
.btn-text--danger { color: #FF6B6B; }

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
  .empty-pill-body { animation: none; }
  .tab-panel { animation: none; }
}
