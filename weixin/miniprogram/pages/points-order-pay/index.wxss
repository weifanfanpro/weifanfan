/* ═══ Points Order Pay — 蓝白卡通风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Pay Card ═══ */
.pay-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  padding: 36rpx;
  text-align: center;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 8rpx 32rpx rgba(43, 94, 167, 0.08);
}

.card-corner {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  pointer-events: none;
}

.card-corner--tl {
  top: 10rpx;
  left: 10rpx;
  border-top: 2rpx solid rgba(74, 157, 255, 0.15);
  border-left: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 4rpx 0 0 0;
}

.card-corner--br {
  bottom: 10rpx;
  right: 10rpx;
  border-bottom: 2rpx solid rgba(74, 157, 255, 0.15);
  border-right: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 0 0 4rpx 0;
}

/* 药丸图标 */
.pay-icon {
  margin-bottom: 16rpx;
}

.pay-pill-body {
  display: inline-block;
  position: relative;
  width: 48rpx;
  height: 64rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(74, 157, 255, 0.18);
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.pay-pill-left {
  position: absolute;
  left: 0; top: 0;
  width: 50%; height: 100%;
  background: #FFFFFF;
}

.pay-pill-right {
  position: absolute;
  right: 0; top: 0;
  width: 50%; height: 100%;
  background: #4A9DFF;
}

.pay-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1A3A5C;
}

.pay-order {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8BA4C7;
}

.pay-amount {
  margin-top: 16rpx;
  font-size: 56rpx;
  font-weight: 900;
  color: #4A9DFF;
  line-height: 1;
}

.pay-amount-unit {
  font-size: 28rpx;
  font-weight: 700;
}

.pay-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #8BA4C7;
}

/* ═══ Button ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .pay-pill-body { animation: none; }
}
