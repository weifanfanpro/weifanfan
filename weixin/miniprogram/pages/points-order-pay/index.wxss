/* ═══ Points Order Pay — 暖调古典 ═══ */
.pay-page {
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
  min-height: 100vh;
}

.pay-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  padding: 30rpx;
  text-align: center;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.pay-card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.12);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.12);
  pointer-events: none;
  z-index: 1;
}

.pay-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1c1917;
}

.pay-order {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #b0a99f;
}

.pay-amount {
  margin-top: 16rpx;
  font-size: 50rpx;
  font-weight: 900;
  color: #2E9E8F;
}

.pay-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #b0a99f;
}
