/* ═══ Medicine List — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.list-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

.list-hero::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.list-hero::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.list-hero-glow {
  position: absolute;
  right: -80rpx;
  top: -78rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46, 158, 143, 0.12), rgba(46, 158, 143, 0));
}

.list-hero .hero-title,
.list-hero .hero-sub,
.list-hero .hero-view-capsule {
  position: relative;
  z-index: 1;
}

.list-hero .hero-title {
  color: #fffefb;
  font-size: 38rpx;
  font-weight: 800;
}

.list-hero .hero-sub {
  color: rgba(255, 254, 251, 0.55);
  font-size: 24rpx;
}

.list-hero .hero-view-capsule {
  margin-top: 14rpx;
  background: rgba(91, 122, 107, 0.08);
  border: 1rpx solid rgba(91, 122, 107, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.list-hero .hero-view-capsule__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5b7a6b;
  opacity: 0.5;
  box-shadow: none;
}

.list-hero .hero-view-capsule__text {
  color: #b0a99f;
  font-size: 22rpx;
  font-weight: 500;
}

.empty-wrap {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx dashed rgba(28, 25, 23, 0.08);
}

.list-panel {
  border-radius: 24rpx;
  overflow: hidden;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.list-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 14rpx 16rpx 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(91, 122, 107, 0.06);
  border: 1rpx solid rgba(91, 122, 107, 0.1);
}

.list-hint-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #5b7a6b;
  flex-shrink: 0;
}

.med-list {
  background: #fffefb;
}

/* ═══ Swipe-to-delete ═══ */
.swipe-row {
  position: relative;
  overflow: hidden;
  margin: 0 16rpx;
}

.swipe-content {
  position: relative;
  z-index: 2;
  padding: 20rpx 6rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #fffefb;
  transition: transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.swipe-content--open {
  transition: none;
}

.swipe-content:active {
  filter: brightness(0.98);
}

.swipe-row:last-child .swipe-content {
  border-bottom: none;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  display: flex;
  align-items: stretch;
}

.swipe-action {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.swipe-action--delete {
  background: linear-gradient(135deg, #e34d59, #c4454f);
  color: #fff;
}

.swipe-action-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

/* ═══ Medicine row content ═══ */
.med-main {
  flex: 1;
  min-width: 0;
}

.med-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1917;
  line-height: 1.25;
}

.med-rule {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6b645c;
  line-height: 1.4;
}

.med-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.med-status {
  margin-right: 0 !important;
}

.mt {
  margin-top: 20rpx;
}
