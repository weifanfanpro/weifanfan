<view class="page page-padding safe-bottom anim-in">
  <custom-navbar title="药品清单" showBack="{true}" />

  <!-- 蓝色渐变 Hero -->
  <view class="list-hero">
    <view class="hero-cloud hero-cloud--1"></view>
    <view class="hero-cloud hero-cloud--2"></view>
    <view class="hero-star hero-star--1"></view>
    <view class="hero-cross hero-cross--1"></view>
    <view class="hero-title">{{heroTitle}}</view>
    <view class="hero-sub">{{heroSubtitle}}</view>
    <view class="hero-view-capsule">
      <view class="hero-view-capsule__dot"></view>
      <text class="hero-view-capsule__text">当前视角：{{viewLabel}}</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{list.length === 0}}" class="empty-wrap card">
    <view class="empty-state">
      <view class="empty-buddy">
        <view class="empty-pill-body">
          <view class="empty-pill-left">
            <view class="empty-pill-eye"><view class="empty-pill-pupil"></view></view>
          </view>
          <view class="empty-pill-right">
            <view class="empty-pill-eye"><view class="empty-pill-pupil"></view></view>
          </view>
          <view class="empty-pill-mouth"></view>
        </view>
      </view>
      <text class="empty-title">{{emptyText}}</text>
    </view>
    <view class="mt">
      <view class="btn btn--primary tap-scale" bindtap="onAdd">
        <text class="btn-text">添加药品</text>
      </view>
    </view>
  </view>

  <!-- 药品列表 -->
  <view wx:else class="list-panel card">
    <view class="list-hint">
      <text class="list-hint-dot"></text>
      <text class="list-hint-text">提示：左滑药品可删除</text>
    </view>
    <view class="med-list">
      <view
        wx:for="{{list}}"
        wx:key="id"
        class="swipe-row"
        data-uid="{{item.id}}"
        data-name="{{item.name}}"
        data-id="{{item.medicineId}}"
        bind:touchstart="onTouchStart"
        bind:touchmove="onTouchMove"
        bind:touchend="onTouchEnd"
      >
        <view
          class="swipe-content {{swipedId === item.id ? 'swipe-content--open' : ''}}"
          style="transform: translateX({{swipedId === item.id ? '-160rpx' : '0rpx'}});"
          bind:tap="onOpen"
          data-name="{{item.name}}"
          data-id="{{item.medicineId}}"
          data-uid="{{item.id}}"
        >
          <view class="med-main">
            <view class="med-name">{{item.name}}</view>
            <view class="med-rule">{{item.displayRule}}</view>
          </view>
          <view class="med-right">
            <view class="tag {{item.active ? 'tag--primary' : 'tag--default'}}">
              {{item.active ? activeText : inactiveText}}
            </view>
            <view class="css-chevron"></view>
          </view>
        </view>
        <view class="swipe-actions">
          <view
            class="swipe-action swipe-action--delete"
            data-uid="{{item.id}}"
            data-name="{{item.name}}"
            data-id="{{item.medicineId}}"
            bind:tap="onSwipeDelete"
          >
            <text class="swipe-action-icon">✕</text>
            <text class="swipe-action-text">删除</text>
          </view>
        </view>
      </view>
    </view>

    <view class="mt">
      <view class="btn btn--secondary tap-scale" bindtap="onAdd">
        <text class="btn-text btn-text--secondary">继续添加药品</text>
      </view>
    </view>
  </view>
</view>
