<view class="page anim-in">
  <custom-navbar title="药品信息" showBack="{true}" />
  <scroll-view class="scrollarea" scroll-y type="list" enhanced="{{true}}" bounces="{{true}}">
    <view class="page-padding safe-bottom content">
      <!-- 蓝色渐变 Header -->
      <view class="header card">
        <view class="hero-cloud hero-cloud--1"></view>
        <view class="hero-star hero-star--1"></view>
        <view class="drug-name">{{drug.name}}</view>
        <view class="hero-sub">{{heroSubtitle}}</view>
        <view class="hero-view-capsule">
          <view class="hero-view-capsule__dot"></view>
          <text class="hero-view-capsule__text">当前视角：{{viewLabel}}</text>
        </view>
        <view class="header-tags">
          <view class="tag tag--primary">{{drug.rule.timesPerDay}}</view>
          <view class="tag tag--default">{{drug.rule.doseEach}}</view>
          <view class="tag tag--default">{{drug.rule.when}}</view>
        </view>
      </view>

      <!-- 关键摘要 -->
      <view class="summary-card card">
        <view class="summary-title">关键摘要</view>
        <view class="summary-grid">
          <view class="summary-item">
            <view class="summary-label">每日频次</view>
            <view class="summary-value">{{drug.rule.timesPerDay}}</view>
          </view>
          <view class="summary-item">
            <view class="summary-label">单次剂量</view>
            <view class="summary-value">{{drug.rule.doseEach}}</view>
          </view>
          <view class="summary-item">
            <view class="summary-label">服用时机</view>
            <view class="summary-value">{{drug.rule.when}}</view>
          </view>
        </view>
      </view>

      <!-- 折叠面板 -->
      <view class="card collapse-card">
        <!-- 用法用量 -->
        <view class="accordion-item">
          <view class="accordion-header" bindtap="onTogglePanel" data-value="dose">
            <text class="accordion-title">用法用量（最重要）</text>
            <view class="accordion-arrow {{opened === 'dose' ? 'accordion-arrow--open' : ''}}"></view>
          </view>
          <view wx:if="{{opened === 'dose'}}" class="accordion-body">
            <view class="app-cell-group">
              <view class="app-cell">
                <text class="app-cell-title">每日几次</text>
                <text class="app-cell-note">{{drug.rule.timesPerDay}}</text>
              </view>
              <view class="app-cell">
                <text class="app-cell-title">每次几片/单位</text>
                <text class="app-cell-note">{{drug.rule.doseEach}}</text>
              </view>
              <view class="app-cell">
                <text class="app-cell-title">饭前/饭后/空腹</text>
                <text class="app-cell-note">{{drug.rule.when}}</text>
              </view>
              <view wx:if="{{drug.rule.isQuantifiable && drug.rule.totalAmountText}}" class="app-cell">
                <text class="app-cell-title">药品总量</text>
                <text class="app-cell-note">{{drug.rule.totalAmountText}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 主治功能 -->
        <view class="accordion-item">
          <view class="accordion-header" bindtap="onTogglePanel" data-value="func">
            <text class="accordion-title">主治功能</text>
            <view class="accordion-arrow {{opened === 'func' ? 'accordion-arrow--open' : ''}}"></view>
          </view>
          <view wx:if="{{opened === 'func'}}" class="accordion-body">
            <view class="panel-text">{{drug.function || fallbackFunctionText}}</view>
          </view>
        </view>

        <!-- 注意事项 -->
        <view class="accordion-item">
          <view class="accordion-header" bindtap="onTogglePanel" data-value="notice">
            <text class="accordion-title">注意事项（精简）</text>
            <view class="accordion-arrow {{opened === 'notice' ? 'accordion-arrow--open' : ''}}"></view>
          </view>
          <view wx:if="{{opened === 'notice'}}" class="accordion-body">
            <view class="panel-list">
              <view wx:if="{{drug.notices.length === 0}}" class="li">{{fallbackNoticeText}}</view>
              <view wx:if="{{drug.notices.length > 0}}" wx:for="{{drug.notices}}" wx:for-index="idx" wx:key="idx" class="li">- {{item}}</view>
            </view>
          </view>
        </view>

        <!-- 禁忌 -->
        <view class="accordion-item">
          <view class="accordion-header" bindtap="onTogglePanel" data-value="contra">
            <text class="accordion-title">禁忌/慎用人群</text>
            <view class="accordion-arrow {{opened === 'contra' ? 'accordion-arrow--open' : ''}}"></view>
          </view>
          <view wx:if="{{opened === 'contra'}}" class="accordion-body">
            <view class="panel-text">{{drug.contraindications || fallbackContraText}}</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="page-padding safe-bottom bottom-action-card">
      <view class="btn btn--primary tap-scale" bindtap="onSetReminder">
        <text class="btn-text">设置服药提醒</text>
      </view>
    </view>
  </view>
</view>
