/* ═══ Drug Detail — 暖调古典 ═══ */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.scrollarea {
  flex: 1;
  overflow: hidden;
}

.content {
  padding-bottom: calc(env(safe-area-inset-bottom) + 240rpx);
}

.header {
  position: relative;
  overflow: hidden;
  padding: 32rpx 28rpx 24rpx;
  box-sizing: border-box;
  margin-top: 8rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

.header::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.header::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.header-glow {
  position: absolute;
  right: -80rpx;
  top: -78rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46, 158, 143, 0.12), rgba(46, 158, 143, 0));
}

.drug-name {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
  color: #fffefb;
  position: relative;
  z-index: 1;
}

.hero-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 254, 251, 0.55);
  position: relative;
  z-index: 1;
}

.header-tags {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.header .hero-view-capsule {
  margin-top: 14rpx;
  position: relative;
  z-index: 1;
  background: rgba(91, 122, 107, 0.08);
  border: 1rpx solid rgba(91, 122, 107, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.header .hero-view-capsule__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5b7a6b;
  opacity: 0.5;
  box-shadow: none;
}

.header .hero-view-capsule__text {
  color: #b0a99f;
  font-size: 22rpx;
  font-weight: 500;
}

.summary-card {
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
  position: relative;
  overflow: hidden;
}

.summary-card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(28, 25, 23, 0.06);
  border-right: 1.5rpx solid rgba(28, 25, 23, 0.06);
  pointer-events: none;
}

.summary-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #b0a99f;
  letter-spacing: 1rpx;
  text-transform: uppercase;
  margin-bottom: 14rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-item {
  border-radius: 16rpx;
  padding: 16rpx 14rpx;
  background: rgba(46, 158, 143, 0.03);
  border: 1rpx solid rgba(46, 158, 143, 0.08);
}

.summary-label {
  font-size: 20rpx;
  color: #b0a99f;
  font-weight: 500;
}

.summary-value {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #1c1917;
  font-weight: 700;
  line-height: 1.35;
}

.collapse-card {
  overflow: hidden;
  border-radius: 22rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.panel {
  border-radius: 16rpx;
  overflow: hidden;
}

.panel-text {
  padding: 18rpx 12rpx;
  font-size: 28rpx;
  color: #6b645c;
  line-height: 1.6;
}

.panel-list {
  padding: 18rpx 12rpx;
}

.li {
  font-size: 28rpx;
  color: #6b645c;
  line-height: 1.7;
  margin: 10rpx 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  border-top: none;
  padding-bottom: env(safe-area-inset-bottom);
}

.bottom-action-card {
  padding-top: 12rpx;
  padding-bottom: 16rpx;
  background: rgba(255, 254, 251, 0.92);
  backdrop-filter: blur(12px);
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  box-shadow: 0 -10rpx 30rpx rgba(28, 25, 23, 0.06);
}
