<view class="page page-padding safe-bottom anim-in">
  <custom-navbar title="我的订单" showBack="{true}" />

  <view wx:if="{{!loading && list.length > 0}}" class="list-tip">长按订单卡片可删除记录</view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && list.length === 0}}" class="empty-wrap">
    <view class="empty-state">
      <view class="empty-buddy">
        <view class="empty-pill-body">
          <view class="empty-pill-left">
            <view class="empty-pill-eye"><view class="empty-pill-pupil"></view></view>
          </view>
          <view class="empty-pill-right">
            <view class="empty-pill-eye"><view class="empty-pill-pupil"></view></view>
          </view>
          <view class="empty-pill-mouth"></view>
        </view>
      </view>
      <text class="empty-title">暂无订单</text>
      <text class="empty-sub">去商城逛逛，用积分兑换心仪商品吧</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view
    wx:for="{{list}}"
    wx:key="orderId"
    class="order-card {{deletingOrderId === item.orderId ? 'order-card--deleting' : ''}}"
    data-id="{{item.orderId}}"
    data-status="{{item.status}}"
    bindtap="onOpenDetail"
    catchlongpress="onLongDelete"
  >
    <view class="card-corner card-corner--tl"></view>
    <view class="card-corner card-corner--br"></view>
    <image class="order-cover" src="{{item.firstItem.cover}}" mode="aspectFill" />
    <view class="order-main">
      <view class="order-name">{{item.firstItem.name}} x{{item.firstItem.quantity}}</view>
      <view class="order-meta">订单号：{{item.orderId}}</view>
      <view class="order-meta">创建时间：{{item.createdAtText}}</view>
    </view>
    <view class="order-right">
      <view class="order-cost">{{item.pointsCost}} 积分</view>
      <view class="order-status">{{item.status}}</view>
    </view>
  </view>
</view>
