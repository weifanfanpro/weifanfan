<view class="page detail-page safe-bottom">
  <custom-navbar title="商品详情" showBack="{true}" />

  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-pill">
      <view class="loading-pill-left"></view>
      <view class="loading-pill-right"></view>
    </view>
    <view class="loading-text">加载中...</view>
  </view>

  <view wx:elif="{{product}}" class="detail-scroll">
    <image class="cover" src="{{product.cover}}" mode="aspectFill" />
    <view class="content anim-in">
      <view class="card-corner card-corner--tl"></view>
      <view class="card-corner card-corner--br"></view>
      <view class="category-chip">{{product.category}}</view>
      <view class="name">{{product.name}}</view>
      <view class="desc">{{product.desc}}</view>
      <view class="meta">模拟库存：{{product.stockMock}}</view>
      <view class="price">{{product.pointsPrice}} <text class="price-unit">积分 / 件</text></view>
      <view class="qty-card">
        <view class="qty-row">
          <text class="qty-label">数量</text>
          <view class="qty-stepper">
            <view class="step-btn {{quantity <= 1 ? 'step-btn--disabled' : ''}}" bindtap="onStepDown">-</view>
            <input class="qty-input" type="number" value="{{quantity}}" bindinput="onQuantityChange" />
            <view class="step-btn {{quantity >= 99 ? 'step-btn--disabled' : ''}}" bindtap="onStepUp">+</view>
          </view>
        </view>
        <view class="calc-row">
          <text>预计消耗</text>
          <text class="calc-value">{{pointsCost}} 积分</text>
        </view>
      </view>
    </view>
    <view class="bottom">
      <view class="bottom-info">
        <view class="bottom-label">合计</view>
        <view class="bottom-price">{{pointsCost}} 积分</view>
      </view>
      <view class="btn btn--primary tap-scale" bindtap="onGoConfirm">
        <text class="btn-text">立即兑换</text>
      </view>
    </view>
  </view>
</view>
