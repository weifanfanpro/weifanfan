/* ═══ Points Product Detail — 暖调古典 ═══ */
.detail-page {
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
  min-height: 100vh;
}

.loading-wrap {
  padding-top: 120rpx;
  display: flex;
  justify-content: center;
}

.cover {
  width: 100%;
  height: 460rpx;
  background: #f5f2ed;
}

.content {
  position: relative;
  margin: -26rpx 22rpx 0;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.content::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.12);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.12);
  pointer-events: none;
  z-index: 1;
}

.category-chip {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 158, 143, 0.08);
  border: 1rpx solid rgba(46, 158, 143, 0.15);
  color: #2E9E8F;
  font-size: 21rpx;
}

.name {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: #1c1917;
}

.desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b645c;
  line-height: 1.6;
}

.meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #b0a99f;
}

.price {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #2E9E8F;
}

.qty-card {
  margin-top: 18rpx;
  border-radius: 16rpx;
  padding: 16rpx;
  background: rgba(46, 158, 143, 0.03);
  border: 1rpx solid rgba(46, 158, 143, 0.08);
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
}

.qty-label {
  font-weight: 700;
  color: #1c1917;
}

.qty-stepper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.step-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background: rgba(46, 158, 143, 0.08);
  color: #2E9E8F;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 56rpx;
  text-align: center;
}

.step-btn--disabled {
  opacity: 0.45;
}

.qty-input {
  width: 120rpx;
  height: 60rpx;
  padding: 0 8rpx;
  border-radius: 12rpx;
  background: #fffefb;
  border: 1rpx solid rgba(46, 158, 143, 0.1);
  text-align: center;
}

.calc-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #6b645c;
}

.calc-value {
  font-size: 30rpx;
  color: #2E9E8F;
  font-weight: 800;
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 18rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(245, 242, 237, 0.88);
  backdrop-filter: blur(14px);
  border-top: none;
}

.bottom-info {
  min-width: 0;
  width: 220rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  background: #fffefb;
}

.bottom-label {
  font-size: 22rpx;
  color: #b0a99f;
}

.bottom-price {
  margin-top: 4rpx;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  color: #2E9E8F;
}

.bottom-btn {
  flex: 1;
  min-width: 0;
}
