/* ═══ Points Product Detail — 蓝白卡通风格 ═══ */

.detail-page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Loading ═══ */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.loading-pill {
  position: relative;
  width: 48rpx;
  height: 64rpx;
  border-radius: 24rpx;
  overflow: hidden;
  animation: pillBounce 1.5s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.loading-pill-left {
  position: absolute;
  left: 0; top: 0;
  width: 50%; height: 100%;
  background: #FFFFFF;
}

.loading-pill-right {
  position: absolute;
  right: 0; top: 0;
  width: 50%; height: 100%;
  background: #4A9DFF;
}

.loading-text {
  font-size: 24rpx;
  color: #8BA4C7;
}

/* ═══ Cover ═══ */
.cover {
  width: 100%;
  height: 460rpx;
  background: #F0F7FF;
}

/* ═══ Content Card ═══ */
.content {
  position: relative;
  margin: -26rpx 22rpx 0;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 8rpx 32rpx rgba(43, 94, 167, 0.08);
}

.card-corner {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  pointer-events: none;
}

.card-corner--tl {
  top: 10rpx;
  left: 10rpx;
  border-top: 2rpx solid rgba(74, 157, 255, 0.15);
  border-left: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 4rpx 0 0 0;
}

.card-corner--br {
  bottom: 10rpx;
  right: 10rpx;
  border-bottom: 2rpx solid rgba(74, 157, 255, 0.15);
  border-right: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 0 0 4rpx 0;
}

.category-chip {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(74, 157, 255, 0.08);
  border: 1rpx solid rgba(74, 157, 255, 0.12);
  color: #4A9DFF;
  font-size: 21rpx;
  font-weight: 600;
}

.name {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: #1A3A5C;
}

.desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8BA4C7;
  line-height: 1.6;
}

.meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8BA4C7;
  opacity: 0.7;
}

.price {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #4A9DFF;
}

.price-unit {
  font-size: 24rpx;
  font-weight: 600;
}

/* ═══ Quantity Card ═══ */
.qty-card {
  margin-top: 18rpx;
  border-radius: 16rpx;
  padding: 16rpx;
  background: rgba(74, 157, 255, 0.03);
  border: 1rpx solid rgba(74, 157, 255, 0.08);
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
}

.qty-label {
  font-weight: 700;
  color: #1A3A5C;
}

.qty-stepper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.step-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background: rgba(74, 157, 255, 0.08);
  color: #4A9DFF;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 56rpx;
  text-align: center;
}

.step-btn--disabled {
  opacity: 0.45;
}

.qty-input {
  width: 120rpx;
  height: 60rpx;
  padding: 0 8rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.1);
  text-align: center;
}

.calc-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #8BA4C7;
}

.calc-value {
  font-size: 30rpx;
  color: #4A9DFF;
  font-weight: 800;
}

/* ═══ Bottom Bar ═══ */
.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 18rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(240, 247, 255, 0.92);
  backdrop-filter: blur(14px);
}

.bottom-info {
  min-width: 0;
  width: 220rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  background: #FFFFFF;
}

.bottom-label {
  font-size: 22rpx;
  color: #8BA4C7;
}

.bottom-price {
  margin-top: 4rpx;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  color: #4A9DFF;
}

/* ═══ Button ═══ */
.btn {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .loading-pill { animation: none; }
}
