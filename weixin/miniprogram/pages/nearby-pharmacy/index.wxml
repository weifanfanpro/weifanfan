<view class="page page-padding safe-bottom anim-in">
  <custom-navbar title="附近药店" showBack="{true}" />

  <!-- 蓝色渐变 Hero -->
  <view class="pharmacy-hero">
    <view class="hero-cloud hero-cloud--1"></view>
    <view class="hero-star hero-star--1"></view>
    <view class="hero-title">{{heroTitle}}</view>
    <view class="hero-sub">{{heroSubtitle}}</view>
    <view class="hero-view-capsule">
      <view class="view-dot"></view>
      <text>{{locationText}}</text>
    </view>
  </view>

  <!-- 提示条 -->
  <view class="notice-bar">
    <view class="notice-icon">i</view>
    <text class="notice-text">{{noticeText}}</text>
  </view>

  <!-- 定位与搜索工具栏 -->
  <view class="card toolbar-card">
    <view class="toolbar-head">
      <view class="toolbar-title">定位与搜索</view>
      <text class="toolbar-sub">{{locationText}}</text>
    </view>
    <view class="toolbar-btns">
      <view class="btn btn--primary btn--small tap-scale {{locating ? 'btn--disabled' : ''}}" bindtap="onRefreshLocation">
        <text class="btn-text">{{locating ? '定位中…' : '重新定位'}}</text>
      </view>
      <view class="btn btn--ghost btn--small tap-scale {{searching ? 'btn--disabled' : ''}}" bindtap="onSearchAgain">
        <text class="btn-text btn-text--ghost">{{searching ? '查询中…' : '刷新列表'}}</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{(searching || locating) && list.length === 0}}" class="loading-wrap">
    <view class="loading-dots">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
    <text class="loading-text">{{locating ? '正在定位…' : '查询附近药店…'}}</text>
  </view>

  <!-- 无位置权限 -->
  <view wx:elif="{{!userLat && !locating && !searching}}" class="empty-wrap">
    <view class="empty-state">
      <view class="empty-buddy">
        <view class="empty-pill-body">
          <view class="empty-pill-left">
            <view class="empty-pill-eye"><view class="empty-pill-pupil"></view></view>
          </view>
          <view class="empty-pill-right">
            <view class="empty-pill-eye"><view class="empty-pill-pupil"></view></view>
          </view>
          <view class="empty-pill-mouth"></view>
        </view>
      </view>
      <text class="empty-title">需要位置权限才能查找附近药店，可点击「重新定位」</text>
    </view>
  </view>

  <!-- 无搜索结果 -->
  <view wx:elif="{{!searching && list.length === 0 && hadSearch}}" class="empty-wrap">
    <view class="empty-state">
      <view class="empty-buddy">
        <view class="empty-pill-body">
          <view class="empty-pill-left">
            <view class="empty-pill-eye"><view class="empty-pill-pupil"></view></view>
          </view>
          <view class="empty-pill-right">
            <view class="empty-pill-eye"><view class="empty-pill-pupil"></view></view>
          </view>
          <view class="empty-pill-mouth"></view>
        </view>
      </view>
      <text class="empty-title">附近暂无检索结果，可稍后再试或去百度地图核对</text>
    </view>
  </view>

  <!-- 药店列表 -->
  <view wx:if="{{list.length > 0}}" class="card result-card">
    <view class="result-head">
      <view class="result-title">附近药店</view>
      <view class="result-sub">{{list.length}} 条结果</view>
    </view>
    <view
      wx:for="{{list}}"
      wx:key="key"
      class="pharmacy-row"
      bindtap="onOpenMap"
      data-lat="{{item.latitude}}"
      data-lng="{{item.longitude}}"
      data-name="{{item.name}}"
      data-address="{{item.address}}"
    >
      <view class="pharmacy-info">
        <view class="pharmacy-name">{{item.name}}</view>
        <view class="pharmacy-desc">{{item.desc}}</view>
      </view>
      <view class="pharmacy-dist">
        <text>{{item.distText}}</text>
        <view class="pharmacy-arrow"></view>
      </view>
    </view>
    <view wx:if="{{searching && list.length > 0}}" class="load-more">
      <view class="loading-dots loading-dots--small">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
      <text class="loading-text">加载更多…</text>
    </view>
    <view wx:if="{{!hasMore && list.length > 0}}" class="end-hint">没有更多了</view>
  </view>
</view>
