/* ═══════════════════════════════════════════
   登录页 · 蓝白卡通「药丸伙伴」风格
   ═══════════════════════════════════════════ */

.login-page {
  min-height: 100vh;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 35%, #A8DAFF 70%, #D6ECFF 100%);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* ═══════════════════════════════════════════
   背景装饰
   ═══════════════════════════════════════════ */

/* 云朵 */
.bg-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  pointer-events: none;
}

.bg-cloud--1 {
  width: 180rpx;
  height: 60rpx;
  top: 120rpx;
  right: -20rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.bg-cloud--1::before {
  content: '';
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  top: -40rpx;
  left: 30rpx;
}

.bg-cloud--2 {
  width: 120rpx;
  height: 40rpx;
  top: 280rpx;
  left: -10rpx;
  opacity: 0.6;
  animation: cloudFloat 10s ease-in-out infinite reverse;
}

.bg-cloud--3 {
  width: 100rpx;
  height: 32rpx;
  bottom: 200rpx;
  right: 60rpx;
  opacity: 0.4;
  animation: cloudFloat 12s ease-in-out infinite;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(16rpx); }
}

/* 星星 */
.bg-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.bg-star--1 { top: 80rpx; left: 60rpx; }
.bg-star--2 { top: 200rpx; right: 100rpx; animation-delay: 0.7s; width: 6rpx; height: 6rpx; }
.bg-star--3 { bottom: 300rpx; left: 120rpx; animation-delay: 1.4s; width: 10rpx; height: 10rpx; }
.bg-star--4 { top: 400rpx; right: 40rpx; animation-delay: 0.3s; width: 5rpx; height: 5rpx; }

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

/* 医疗十字 */
.bg-cross {
  position: absolute;
  opacity: 0.1;
  pointer-events: none;
}

.bg-cross::before,
.bg-cross::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.bg-cross--1 {
  top: 160rpx;
  left: 200rpx;
  width: 20rpx;
  height: 20rpx;
  transform: rotate(15deg);
}

.bg-cross--2 {
  bottom: 280rpx;
  right: 160rpx;
  width: 16rpx;
  height: 16rpx;
  transform: rotate(-10deg);
}

.bg-cross--3 {
  top: 500rpx;
  left: 40rpx;
  width: 12rpx;
  height: 12rpx;
  transform: rotate(25deg);
}

.bg-cross--1::before, .bg-cross--2::before, .bg-cross--3::before {
  width: 100%;
  height: 30%;
  top: 35%;
  left: 0;
}

.bg-cross--1::after, .bg-cross--2::after, .bg-cross--3::after {
  width: 30%;
  height: 100%;
  top: 0;
  left: 35%;
}

/* ═══════════════════════════════════════════
   页面主体
   ═══════════════════════════════════════════ */
.login-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  position: relative;
  z-index: 2;
}

/* ═══════════════════════════════════════════
   药丸角色
   ═══════════════════════════════════════════ */
.pill-buddy {
  position: relative;
  margin-bottom: 32rpx;
}

.pill-body {
  position: relative;
  width: 160rpx;
  height: 208rpx;
  border-radius: 80rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(43, 94, 167, 0.35);
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.pill-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 50%;
  height: 100%;
  background: #FFFFFF;
}

.pill-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 50%;
  height: 100%;
  background: #4A9DFF;
}

/* 眼睛 */
.pill-eye {
  position: absolute;
  width: 36rpx;
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 56rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.pill-eye--l { left: 20rpx; }
.pill-eye--r { right: 20rpx; }

.pill-pupil {
  position: absolute;
  width: 18rpx;
  height: 20rpx;
  background: #2B5EA7;
  border-radius: 50%;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  animation: pupilLook 4s ease-in-out infinite;
}

.pill-pupil::after {
  content: '';
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 3rpx;
  right: 2rpx;
}

@keyframes pupilLook {
  0%, 100% { transform: translateX(-50%); }
  25% { transform: translateX(-30%); }
  75% { transform: translateX(-70%); }
}

/* 腮红 */
.pill-cheek {
  position: absolute;
  width: 28rpx;
  height: 18rpx;
  border-radius: 50%;
  background: rgba(255, 179, 102, 0.4);
  top: 100rpx;
}

.pill-cheek--l { left: 8rpx; }
.pill-cheek--r { right: 8rpx; }

/* 嘴巴 */
.pill-mouth {
  position: absolute;
  bottom: 52rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 16rpx;
  border-bottom: 4rpx solid #2B5EA7;
  border-radius: 0 0 50% 50%;
  z-index: 3;
}

/* 小药丸装饰 */
.pill-mini {
  position: absolute;
  border-radius: 999rpx;
  animation: pillBounce 3s ease-in-out infinite;
}

.pill-mini--1 {
  width: 24rpx;
  height: 14rpx;
  background: rgba(255, 255, 255, 0.35);
  top: -10rpx;
  right: -28rpx;
  animation-delay: 0.5s;
}

.pill-mini--2 {
  width: 18rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.25);
  bottom: 20rpx;
  left: -24rpx;
  animation-delay: 1s;
}

/* ═══════════════════════════════════════════
   标题
   ═══════════════════════════════════════════ */
.login-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #FFFFFF;
  text-shadow: 0 3rpx 12rpx rgba(43, 94, 167, 0.3);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 500;
  margin-bottom: 40rpx;
}

/* ═══════════════════════════════════════════
   信息气泡
   ═══════════════════════════════════════════ */
.info-bubble {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 48rpx;
  width: 100%;
  box-sizing: border-box;
}

.ib-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ib-chat {
  width: 20rpx;
  height: 14rpx;
  border: 2.5rpx solid #FFFFFF;
  border-radius: 7rpx 7rpx 7rpx 2rpx;
  position: relative;
}

.ib-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.ib-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.ib-text--sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
}

/* ═══════════════════════════════════════════
   微信登录按钮
   ═══════════════════════════════════════════ */
.wx-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #E8F2FF 100%);
  box-shadow: 0 8rpx 32rpx rgba(43, 94, 167, 0.2);
  transition: transform 150ms ease, box-shadow 150ms ease;
  animation: btnPulse 2.5s ease-in-out infinite;
  margin-bottom: 32rpx;
}

.wx-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.15);
}

.wx-btn--loading {
  animation: none;
  opacity: 0.8;
}

@keyframes btnPulse {
  0%, 100% { box-shadow: 0 8rpx 32rpx rgba(43, 94, 167, 0.2); }
  50% { box-shadow: 0 8rpx 40rpx rgba(74, 157, 255, 0.35); }
}

/* 微信图标 */
.wx-icon {
  position: relative;
  width: 40rpx;
  height: 36rpx;
}

.wx-bubble {
  width: 36rpx;
  height: 28rpx;
  border: 3rpx solid #07C160;
  border-radius: 14rpx 14rpx 14rpx 4rpx;
  position: relative;
}

.wx-dot {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #07C160;
  top: 50%;
  transform: translateY(-50%);
}

.wx-dot--1 { left: 10rpx; }
.wx-dot--2 { right: 8rpx; }

/* Loading 旋转 */
.wx-spinner {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-spinner-pill {
  width: 28rpx;
  height: 14rpx;
  border-radius: 7rpx;
  background: linear-gradient(90deg, #4A9DFF 50%, #A8DAFF 50%);
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.wx-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2B5EA7;
  letter-spacing: 2rpx;
}

/* ═══════════════════════════════════════════
   安全提示
   ═══════════════════════════════════════════ */
.safe-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sh-lock {
  position: relative;
  width: 16rpx;
  height: 18rpx;
}

.sh-lock-body {
  position: absolute;
  bottom: 0;
  left: 1rpx;
  width: 14rpx;
  height: 10rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 2rpx;
}

.sh-lock-shackle {
  position: absolute;
  top: 0;
  left: 4rpx;
  width: 8rpx;
  height: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
}

.sh-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .pill-body { animation: none; }
  .pill-pupil { animation: none; }
  .bg-cloud { animation: none; }
  .bg-star { animation: none; }
  .pill-mini { animation: none; }
  .wx-btn { animation: none; }
  .wx-spinner-pill { animation: none; }
}
