/* ═══ Login Page — 暖调古典 ═══ */
.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.logo-wrap {
  width: 176rpx;
  height: 176rpx;
  border-radius: 9999rpx;
  background: #fffefb;
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.12),
    0 4rpx 12rpx rgba(28, 25, 23, 0.06);
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.logo-wrap::before {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  width: 24rpx;
  height: 24rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.2);
  border-left: 2rpx solid rgba(46, 158, 143, 0.2);
  z-index: 3;
  pointer-events: none;
}

.logo-wrap::after {
  content: '';
  position: absolute;
  bottom: 14rpx;
  right: 14rpx;
  width: 24rpx;
  height: 24rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.2);
  border-right: 2rpx solid rgba(46, 158, 143, 0.2);
  z-index: 3;
  pointer-events: none;
}

.logo-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 9999rpx;
}

.app-name {
  margin-top: 32rpx;
  font-size: 44rpx;
  font-weight: 800;
  color: #1c1917;
  letter-spacing: 2rpx;
}

.app-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #b0a99f;
  letter-spacing: 0.5rpx;
}

.login-card {
  position: relative;
  background: #fffefb;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 64rpx;
  box-shadow:
    0 24rpx 64rpx rgba(28, 25, 23, 0.06),
    0 4rpx 12rpx rgba(28, 25, 23, 0.03);
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  overflow: hidden;
}

.login-card::before {
  content: '';
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2.5rpx solid rgba(46, 158, 143, 0.18);
  border-left: 2.5rpx solid rgba(46, 158, 143, 0.18);
  z-index: 3;
  pointer-events: none;
}

.login-card::after {
  content: '';
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2.5rpx solid rgba(46, 158, 143, 0.18);
  border-right: 2.5rpx solid rgba(46, 158, 143, 0.18);
  z-index: 3;
  pointer-events: none;
}

.login-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1c1917;
  letter-spacing: 1rpx;
}

.login-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #6b645c;
}

.btn-wrap {
  margin-top: 48rpx;
}
