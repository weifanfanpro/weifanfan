/* ═══ Address Edit — 暖调古典 ═══ */
.edit-page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
  padding-left: 20rpx;
  padding-right: 20rpx;
  box-sizing: border-box;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 24rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  border: 0;
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

.hero::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.hero-title {
  position: relative;
  z-index: 1;
  font-size: 34rpx;
  font-weight: 800;
  color: #fffefb;
}

.hero-desc {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 254, 251, 0.55);
}

.hero-tip {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  font-size: 21rpx;
  color: rgba(255, 254, 251, 0.7);
  background: rgba(255, 254, 251, 0.06);
  border: 1rpx solid rgba(255, 254, 251, 0.1);
}

.form-card {
  position: relative;
  overflow: hidden;
  margin-top: 16rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.form-card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.12);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.12);
  pointer-events: none;
  z-index: 1;
}

.form-group-title {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #1c1917;
}

.form-group-title--secondary {
  margin-top: 16rpx;
}

.field + .field {
  margin-top: 14rpx;
}

.label {
  font-size: 24rpx;
  color: #6b645c;
  margin-bottom: 8rpx;
}

.input {
  height: 72rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(46, 158, 143, 0.1);
  background: rgba(46, 158, 143, 0.03);
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1c1917;
}

.picker-input {
  height: 72rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(46, 158, 143, 0.1);
  background: rgba(46, 158, 143, 0.03);
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #b0a99f;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-input--selected {
  color: #1c1917;
}

.textarea {
  width: 100%;
  min-height: 168rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(46, 158, 143, 0.1);
  background: rgba(46, 158, 143, 0.03);
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #1c1917;
}

.switch-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(46, 158, 143, 0.08);
  border-radius: 14rpx;
  background: rgba(46, 158, 143, 0.03);
  padding: 16rpx 18rpx;
}

.switch-row .label {
  margin-bottom: 0;
}

.switch-desc {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #b0a99f;
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(245, 242, 237, 0.88);
  backdrop-filter: blur(14px);
  border-top: none;
}
