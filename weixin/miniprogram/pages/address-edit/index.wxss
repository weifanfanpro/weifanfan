/* ═══ Address Edit — 蓝白卡通风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ═══ Hero ═══ */
.edit-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
}

.hero-star--1 {
  bottom: 20rpx;
  left: 50rpx;
  animation: starTwinkle 2s ease-in-out infinite;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.hero-title {
  position: relative;
  z-index: 1;
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.hero-desc {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

.hero-tip {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

/* ═══ Form Card ═══ */
.form-card {
  position: relative;
  overflow: hidden;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 6rpx 24rpx rgba(43, 94, 167, 0.06);
}

.card-corner {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  pointer-events: none;
}

.card-corner--tl {
  top: 10rpx;
  left: 10rpx;
  border-top: 2rpx solid rgba(74, 157, 255, 0.15);
  border-left: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 4rpx 0 0 0;
}

.card-corner--br {
  bottom: 10rpx;
  right: 10rpx;
  border-bottom: 2rpx solid rgba(74, 157, 255, 0.15);
  border-right: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 0 0 4rpx 0;
}

.form-group-title {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #1A3A5C;
}

.form-group-title--secondary {
  margin-top: 16rpx;
}

.field + .field {
  margin-top: 14rpx;
}

.label {
  font-size: 24rpx;
  color: #8BA4C7;
  margin-bottom: 8rpx;
}

.input {
  height: 72rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(74, 157, 255, 0.1);
  background: rgba(74, 157, 255, 0.03);
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1A3A5C;
}

.picker-input {
  height: 72rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(74, 157, 255, 0.1);
  background: rgba(74, 157, 255, 0.03);
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #8BA4C7;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-input--selected {
  color: #1A3A5C;
}

.textarea {
  width: 100%;
  min-height: 168rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(74, 157, 255, 0.1);
  background: rgba(74, 157, 255, 0.03);
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #1A3A5C;
}

.switch-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(74, 157, 255, 0.06);
  border-radius: 14rpx;
  background: rgba(74, 157, 255, 0.03);
  padding: 16rpx 18rpx;
}

.switch-row .label {
  margin-bottom: 0;
}

.switch-desc {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #8BA4C7;
}

/* ═══ Bottom Bar ═══ */
.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(240, 247, 255, 0.92);
  backdrop-filter: blur(14px);
}

/* ═══ Button ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
}
