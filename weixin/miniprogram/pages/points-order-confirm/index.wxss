/* ═══ Points Order Confirm — 暖调古典 ═══ */
.confirm-page {
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
  min-height: 100vh;
  padding-bottom: calc(134rpx + env(safe-area-inset-bottom));
}

.confirm-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.mt {
  margin-top: 0;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1917;
}

.order-hero {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1rpx solid rgba(46, 158, 143, 0.12);
  padding: 20rpx;
  background: #fffefb;
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.order-hero::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.12);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.12);
  pointer-events: none;
  z-index: 1;
}

.order-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-head-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #2E9E8F;
  background: rgba(46, 158, 143, 0.08);
  border: 1rpx solid rgba(46, 158, 143, 0.15);
}

.summary-grid {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.summary-item {
  border-radius: 14rpx;
  background: rgba(46, 158, 143, 0.03);
  border: 1rpx solid rgba(46, 158, 143, 0.08);
  padding: 10rpx 12rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #b0a99f;
}

.summary-value {
  margin-top: 4rpx;
  font-size: 28rpx;
  color: #1c1917;
  font-weight: 700;
}

.summary-value--main {
  color: #2E9E8F;
  font-size: 32rpx;
}

.meta {
  margin-top: 8rpx;
  color: #6b645c;
  font-size: 25rpx;
}

.cost {
  margin-top: 12rpx;
  color: #2E9E8F;
  font-size: 32rpx;
  font-weight: 800;
}

.balance {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5b7a6b;
  background: rgba(91, 122, 107, 0.06);
  border: 1rpx solid rgba(91, 122, 107, 0.12);
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
}

.balance--warn {
  color: #b45309;
  background: rgba(180, 140, 60, 0.06);
  border-color: rgba(180, 140, 60, 0.12);
}

.addr-item {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: rgba(28, 25, 23, 0.02);
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  transition: all 160ms ease;
}

.addr-item--active {
  border-color: rgba(46, 158, 143, 0.25);
  background: rgba(46, 158, 143, 0.04);
  box-shadow: 0 10rpx 20rpx rgba(46, 158, 143, 0.08);
}

.address-card {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}

.address-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.address-head-sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #b0a99f;
  line-height: 1.45;
}

.address-head-action {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #2E9E8F;
  border: 1rpx solid rgba(46, 158, 143, 0.2);
  background: rgba(46, 158, 143, 0.06);
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}

.address-head-arrow {
  font-size: 24rpx;
  line-height: 1;
}

.addr-line-1 {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.addr-main {
  min-width: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx 12rpx;
}

.addr-name {
  font-size: 38rpx;
  line-height: 1;
  color: #1c1917;
  font-weight: 800;
}

.addr-phone {
  font-size: 34rpx;
  line-height: 1;
  color: #1c1917;
  font-weight: 700;
}

.addr-default {
  margin-top: 4rpx;
  flex-shrink: 0;
  font-size: 20rpx;
  color: #2E9E8F;
  background: rgba(46, 158, 143, 0.08);
  border: 1rpx solid rgba(46, 158, 143, 0.15);
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.addr-line-2 {
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.65;
  color: #6b645c;
}

.address-empty {
  margin-top: 12rpx;
  border-radius: 16rpx;
  border: 1rpx dashed rgba(46, 158, 143, 0.2);
  background: rgba(46, 158, 143, 0.03);
  padding: 16rpx 18rpx;
  color: #b0a99f;
  font-size: 24rpx;
}

.address-add-btn {
  margin-top: 10rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  border-radius: 999rpx;
  padding: 0 20rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2E9E8F, #d4845a);
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(245, 242, 237, 0.88);
  backdrop-filter: blur(14px);
  border-top: none;
  box-shadow: 0 -8rpx 18rpx rgba(28, 25, 23, 0.04);
  padding: 12rpx 22rpx calc(12rpx + env(safe-area-inset-bottom));
}

.bottom-hint {
  margin-bottom: 8rpx;
  text-align: center;
  font-size: 22rpx;
  color: #b0a99f;
}

.bottom-hint--warn {
  color: #b45309;
}
