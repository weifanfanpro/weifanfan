/* ═══ Tab Shell · 药丸伙伴风格 ═══ */
.tab-shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #F0F7FF;
}

.tab-shell-swiper {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.tab-shell-item {
  height: 100%;
  overflow: hidden;
}

.tab-shell-panel {
  display: block;
  height: 100%;
}

.tab-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  transition: transform 180ms cubic-bezier(0.34, 1.56, 0.64, 1), background 180ms ease;
}

.tab-icon image {
  width: 52rpx;
  height: 52rpx;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 26rpx;
  height: 26rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #FF6B6B;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 26rpx;
  text-align: center;
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
  animation: badgePop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes badgePop {
  0% { transform: scale(0); }
  100% { transform: scale(1); }
}

.app-tabbar {
  flex-shrink: 0;
  width: 100%;
  background: rgba(255, 255, 255, 0.95) !important;
  backdrop-filter: blur(16px);
  border-top: none !important;
  box-shadow: 0 -4rpx 24rpx rgba(43, 94, 167, 0.06);
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
}

.app-tabbar .t-tab-bar-item--active .tab-icon {
  background: rgba(74, 157, 255, 0.1);
  transform: translateY(-4rpx) scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(74, 157, 255, 0.15);
}
