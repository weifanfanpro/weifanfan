/* ═══ Profile Edit — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.profile-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 24rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

/* 角饰 */
.profile-hero::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.profile-hero::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.profile-hero-glow {
  position: absolute;
  right: -80rpx;
  top: -78rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46, 158, 143, 0.12), rgba(46, 158, 143, 0));
}

.profile-hero-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.profile-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 254, 251, 0.2);
  flex-shrink: 0;
}

.meta {
  flex: 1;
}

.name {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #fffefb;
}

.sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 254, 251, 0.55);
}

.hero-chip {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: rgba(255, 254, 251, 0.7);
  border: 1rpx solid rgba(255, 254, 251, 0.15);
  background: rgba(255, 254, 251, 0.06);
}

.account-card {
  position: relative;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
  overflow: hidden;
}

/* 角饰 */
.account-card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.12);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.12);
  pointer-events: none;
  z-index: 1;
}

.card-title {
  font-size: 24rpx;
  color: #b0a99f;
  font-weight: 600;
  margin: 0 4rpx 10rpx;
}

.full {
  width: 100%;
}

.nickname-input-wrap {
  width: 100%;
  border-radius: 12rpx;
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(46, 158, 143, 0.1);
  background: rgba(46, 158, 143, 0.03);
  box-sizing: border-box;
}

.nickname-input {
  width: 100%;
  min-height: 56rpx;
  font-size: 28rpx;
  color: #1c1917;
  text-align: right;
}

.avatar-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.avatar-pick-btn {
  border-radius: 999rpx !important;
}

.actions-float {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow: 0 12rpx 36rpx rgba(28, 25, 23, 0.04);
}
