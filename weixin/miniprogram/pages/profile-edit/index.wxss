/* ═══ Profile Edit — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Hero ═══ */
.profile-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 28rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

/* 装饰 */
.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { bottom: 20rpx; left: 50rpx; }
.hero-star--2 { top: 24rpx; left: 140rpx; animation-delay: 0.7s; }

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.profile-hero-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  z-index: 2;
}

.profile-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(43, 94, 167, 0.15);
}

.meta {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.3;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.75);
}

.hero-chip {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* ═══ 卡片 ═══ */
.card {
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
  overflow: hidden;
}

.account-card {
  padding: 0 28rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 24rpx;
  color: #8BA4C7;
  font-weight: 600;
  padding: 22rpx 0 10rpx;
}

/* ═══ Cell 行 ═══ */
.cell-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(74, 157, 255, 0.06);
}

.cell-row--last {
  border-bottom: none;
}

.cell-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A3A5C;
  flex-shrink: 0;
}

.cell-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  min-width: 0;
}

/* 昵称输入 */
.nickname-input-wrap {
  width: 100%;
  max-width: 400rpx;
  border-radius: 14rpx;
  padding: 10rpx 16rpx;
  border: 1rpx solid rgba(74, 157, 255, 0.12);
  background: rgba(74, 157, 255, 0.03);
  box-sizing: border-box;
}

.nickname-input {
  width: 100%;
  min-height: 56rpx;
  font-size: 28rpx;
  color: #1A3A5C;
  text-align: right;
}

/* ═══ 操作按钮卡片 ═══ */
.actions-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

/* ═══ 按钮 ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn--primary {
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
}

.btn--ghost {
  background: transparent;
  border: 1rpx solid rgba(74, 157, 255, 0.15);
}

.btn--small {
  height: 60rpx;
  padding: 0 28rpx;
}

.btn--disabled {
  opacity: 0.6;
  pointer-events: none;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.btn-text--ghost {
  color: #4A9DFF;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
}
