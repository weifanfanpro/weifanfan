/* ═══ Points Mall — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Hero ═══ */
.mall-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-cloud--2 {
  width: 80rpx;
  height: 28rpx;
  bottom: 12rpx;
  left: 32rpx;
  animation: cloudFloat 10s ease-in-out infinite 2s;
}

.hero-cloud--2::before {
  content: '';
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -20rpx;
  left: 12rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
}

.hero-star--1 {
  bottom: 20rpx;
  left: 50rpx;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--2 {
  top: 24rpx;
  left: 120rpx;
  width: 6rpx;
  height: 6rpx;
  animation: starTwinkle 3s ease-in-out infinite 1s;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.hero-main {
  position: relative;
  z-index: 2;
}

.hero-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.hero-points {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.points-num {
  font-size: 64rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
  text-shadow: 0 4rpx 12rpx rgba(43, 94, 167, 0.25);
  animation: pointsPulse 3s ease-in-out infinite;
}

.points-unit {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 6rpx;
}

@keyframes pointsPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}

.hero-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* Hero 按钮 */
.btn--hero {
  position: relative;
  z-index: 2;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(8px);
}

.btn-text--hero {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

/* ═══ Earn Card ═══ */
.earn-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.05);
}

.earn-icon {
  flex-shrink: 0;
}

.earn-pill-body {
  position: relative;
  width: 36rpx;
  height: 48rpx;
  border-radius: 18rpx;
  overflow: hidden;
  animation: pillBounce 3s ease-in-out infinite;
}

.earn-pill-left {
  position: absolute;
  left: 0; top: 0;
  width: 50%; height: 100%;
  background: #FFFFFF;
}

.earn-pill-right {
  position: absolute;
  right: 0; top: 0;
  width: 50%; height: 100%;
  background: #4A9DFF;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

.earn-text {
  font-size: 24rpx;
  color: #8BA4C7;
  line-height: 1.5;
  flex: 1;
}

/* ═══ Category Tabs ═══ */
.cat-scroll {
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.cat-tabs {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.cat-tab {
  display: inline-flex;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #8BA4C7;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.04);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.cat-tab--active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  border-color: transparent;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(74, 157, 255, 0.25);
}

/* ═══ Loading ═══ */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.loading-pill {
  position: relative;
  width: 48rpx;
  height: 64rpx;
  border-radius: 24rpx;
  overflow: hidden;
  animation: pillBounce 1.5s ease-in-out infinite;
}

.loading-pill-left {
  position: absolute;
  left: 0; top: 0;
  width: 50%; height: 100%;
  background: #FFFFFF;
}

.loading-pill-right {
  position: absolute;
  right: 0; top: 0;
  width: 50%; height: 100%;
  background: #4A9DFF;
}

.loading-text {
  font-size: 24rpx;
  color: #8BA4C7;
}

/* ═══ Empty State ═══ */
.empty-wrap {
  margin-top: 20rpx;
  padding: 48rpx 24rpx 40rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-buddy { margin-bottom: 16rpx; }

.empty-pill-body {
  position: relative;
  width: 64rpx;
  height: 84rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(74, 157, 255, 0.18);
  animation: pillBounce 3s ease-in-out infinite;
}

.empty-pill-left {
  position: absolute; left: 0; top: 0; width: 50%; height: 100%;
  background: #FFFFFF;
}

.empty-pill-right {
  position: absolute; right: 0; top: 0; width: 50%; height: 100%;
  background: #4A9DFF;
}

.empty-pill-eye {
  position: absolute;
  width: 16rpx; height: 18rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 24rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0,0,0,0.06);
}

.empty-pill-left .empty-pill-eye { left: 8rpx; }
.empty-pill-right .empty-pill-eye { right: 8rpx; }

.empty-pill-pupil {
  position: absolute;
  width: 8rpx; height: 10rpx;
  background: #2B5EA7;
  border-radius: 50%;
  bottom: 3rpx;
  left: 50%;
  transform: translateX(-50%);
}

.empty-pill-mouth {
  position: absolute;
  bottom: 22rpx; left: 50%;
  transform: translateX(-50%);
  width: 14rpx; height: 6rpx;
  border-bottom: 2rpx solid #2B5EA7;
  border-radius: 0 0 50% 50%;
  z-index: 3;
}

.empty-title {
  font-size: 26rpx;
  color: #8BA4C7;
  font-weight: 500;
}

.empty-mini {
  padding: 40rpx 0;
  text-align: center;
}

.empty-mini-text {
  font-size: 24rpx;
  color: #8BA4C7;
}

/* ═══ Goods List ═══ */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ═══ Goods Card ═══ */
.goods-card {
  position: relative;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 6rpx 24rpx rgba(43, 94, 167, 0.06);
  transition: transform 150ms ease;
}

.goods-card:active {
  transform: scale(0.98);
}

/* 装饰角 */
.card-corner {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  pointer-events: none;
}

.card-corner--tl {
  top: 8rpx;
  left: 8rpx;
  border-top: 2rpx solid rgba(74, 157, 255, 0.15);
  border-left: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 4rpx 0 0 0;
}

.card-corner--br {
  bottom: 8rpx;
  right: 8rpx;
  border-bottom: 2rpx solid rgba(74, 157, 255, 0.15);
  border-right: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 0 0 4rpx 0;
}

.goods-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 18rpx;
  background: #F0F7FF;
  flex-shrink: 0;
}

.goods-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.goods-category {
  display: inline-flex;
  align-self: flex-start;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #4A9DFF;
  background: rgba(74, 157, 255, 0.08);
}

.goods-name {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1A3A5C;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8BA4C7;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.goods-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.goods-price {
  display: flex;
  align-items: baseline;
}

.price-num {
  font-size: 38rpx;
  font-weight: 900;
  color: #4A9DFF;
  line-height: 1;
}

.price-unit {
  font-size: 22rpx;
  font-weight: 600;
  color: #4A9DFF;
}

.goods-stock {
  font-size: 22rpx;
  color: #8BA4C7;
}

/* ═══ Shared Button ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn--small {
  height: 56rpx;
  padding: 0 24rpx;
  margin-bottom: 0;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
  .points-num { animation: none; }
  .earn-pill-body { animation: none; }
  .empty-pill-body { animation: none; }
  .loading-pill { animation: none; }
}
