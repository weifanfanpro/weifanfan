/* ═══ AI Chat Pick Medicine — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.hero-sub--strong {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1c1917;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 80rpx 32rpx;
}

.med-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.05);
  background: #fffefb;
}

.med-row:last-child {
  border-bottom: none;
}

.med-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.med-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
}

.med-rule {
  font-size: 24rpx;
  color: #6b645c;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.med-chev {
  flex-shrink: 0;
  font-size: 36rpx;
  color: #b0a99f;
  padding: 0 8rpx;
}
