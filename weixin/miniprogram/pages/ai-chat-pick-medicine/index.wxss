/* ═══ AI Chat Pick Medicine — 蓝白卡通「药丸伙伴」风格 ═══ */

.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #F0F7FF;
}

.mb {
  margin-bottom: 16rpx;
}

/* ═══ Hero ═══ */
.brand-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 24rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { bottom: 20rpx; left: 50rpx; }

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.brand-hero .hero-title,
.brand-hero .hero-sub,
.brand-hero .hero-view-capsule {
  position: relative;
  z-index: 2;
}

.brand-hero .hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.2);
}

.brand-hero .hero-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.75);
}

.hero-view-capsule {
  margin-top: 14rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.hero-view-capsule__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
}

.hero-view-capsule__text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
  font-weight: 500;
}

/* ═══ Loading ═══ */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 80rpx 32rpx;
}

.loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4A9DFF;
  animation: dotBounce 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-hint {
  font-size: 24rpx;
  color: #8BA4C7;
}

/* ═══ Empty State ═══ */
.empty-wrap {
  margin-top: 32rpx;
  padding: 0 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.empty-buddy { margin-bottom: 24rpx; }

.empty-pill-body {
  position: relative;
  width: 80rpx;
  height: 104rpx;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.2);
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-pill-left {
  position: absolute; left: 0; top: 0; width: 50%; height: 100%;
  background: #FFFFFF;
}

.empty-pill-right {
  position: absolute; right: 0; top: 0; width: 50%; height: 100%;
  background: #4A9DFF;
}

.empty-pill-eye {
  position: absolute;
  width: 20rpx; height: 22rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 30rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0,0,0,0.06);
}

.empty-pill-left .empty-pill-eye { left: 10rpx; }
.empty-pill-right .empty-pill-eye { right: 10rpx; }

.empty-pill-pupil {
  position: absolute;
  width: 10rpx; height: 12rpx;
  background: #2B5EA7;
  border-radius: 50%;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
}

.empty-pill-mouth {
  position: absolute;
  bottom: 28rpx; left: 50%;
  transform: translateX(-50%);
  width: 18rpx; height: 8rpx;
  border-bottom: 3rpx solid #2B5EA7;
  border-radius: 0 0 50% 50%;
  z-index: 3;
}

.empty-title {
  font-size: 28rpx;
  color: #8BA4C7;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

/* ═══ List ═══ */
.med-card {
  border-radius: 24rpx;
  overflow: hidden;
}

.med-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(74, 157, 255, 0.06);
  background: #FFFFFF;
}

.med-row:last-child {
  border-bottom: none;
}

.med-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.med-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A5C;
}

.med-rule {
  font-size: 24rpx;
  color: #3D5A80;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.css-chevron {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid #B0C4DE;
  border-right: 2rpx solid #B0C4DE;
  transform: rotate(45deg);
}

.muted {
  color: #8BA4C7;
}

.small {
  font-size: 22rpx;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
  .empty-pill-body { animation: none; }
  .loading-dot { animation: none; }
}
