<view class="page page-padding safe-bottom anim-in">
  <custom-navbar title="选择咨询药品" showBack="{true}" />
  <view class="brand-hero mb">
    <view class="hero-title">选择药品</view>
    <view class="hero-sub muted">以下为当前视角下的药单，点选后将带入咨询上下文（与首页/清单一致）。</view>
    <view class="hero-view-capsule">
      <view class="hero-view-capsule__dot"></view>
      <text class="hero-view-capsule__text">当前视角：{{viewLabel}}</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading theme="dots" size="40rpx" />
    <text class="muted small">加载药单中…</text>
  </view>

  <view wx:elif="{{list.length === 0}}" class="card pad">
    <t-empty description="当前视角下暂无药单药品，可先添加药品后再来咨询" />
  </view>

  <view wx:else class="card">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="med-row tap-scale"
      data-id="{{item.id}}"
      data-medicine-id="{{item.medicineId}}"
      data-name="{{item.name}}"
      data-rule="{{item.rule}}"
      bindtap="onPick"
    >
      <view class="med-main">
        <text class="med-name">{{item.name}}</text>
        <text class="med-rule muted small">{{item.rule}}</text>
      </view>
      <text class="med-chev">›</text>
    </view>
  </view>
</view>
