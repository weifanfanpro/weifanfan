<view class="page page-padding address-page">
  <custom-navbar title="收货地址" showBack="{true}" />
  <view class="hero card-elevated anim-in">
    <view class="hero-glow hero-glow--a"></view>
    <view class="hero-glow hero-glow--b"></view>
    <view class="hero-top">
      <view>
        <view class="hero-title">地址簿</view>
        <view class="hero-desc">支持多个收货地址，默认地址优先用于下单</view>
      </view>
      <view class="hero-badge">{{list.length}} 个地址</view>
    </view>
    <view class="hero-footer">
      <view class="hero-foot-note">可管理家庭、公司等多个场景地址</view>
    </view>
  </view>

  <view wx:if="{{!loading && list.length === 0}}" class="empty-wrap">
    <view class="empty-illustration"></view>
    <view class="empty-title">暂无收货地址</view>
    <view class="empty-desc">建议先新增常用地址，结算时将自动优先带出默认地址</view>
    <t-button theme="primary" block bind:tap="onAddAddress">去新增地址</t-button>
  </view>

  <view wx:else class="addr-list">
    <view
      wx:for="{{list}}"
      wx:key="addressId"
      class="addr-item card tap-scale anim-in {{mode === 'choose' && selectedAddressId === item.addressId ? 'addr-item--active' : ''}}"
      data-id="{{item.addressId}}"
      bind:tap="onChooseAddress"
    >
      <view class="addr-head-marker"></view>
      <view class="addr-line-1">
        <text class="addr-name">{{item.receiver}}</text>
        <text class="addr-phone">{{item.phone}}</text>
        <text wx:if="{{item.isDefault}}" class="addr-default">默认</text>
        <text wx:if="{{item.tag}}" class="addr-tag">{{item.tag}}</text>
      </view>
      <view class="addr-line-2">{{item.region}} {{item.detail}}</view>
      <view class="addr-actions">
        <view class="action-btn action-btn--primary {{item.isDefault ? 'action-btn--disabled' : ''}}" data-id="{{item.addressId}}" catch:tap="onSetDefault">设为默认</view>
        <view class="action-btn action-btn--edit" data-id="{{item.addressId}}" catch:tap="onEditAddress">编辑</view>
        <view class="action-btn action-btn--danger" data-id="{{item.addressId}}" catch:tap="onDeleteAddress">删除</view>
      </view>
    </view>
  </view>

  <view class="address-bottom-action">
    <t-button theme="primary" block bind:tap="onAddAddress">新增地址</t-button>
  </view>
</view>
