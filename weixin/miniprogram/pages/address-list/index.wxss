/* ═══ Address List — 蓝白卡通风格 ═══ */

.page {
  min-height: 100vh;
  background: #F0F7FF;
}

/* ═══ Hero ═══ */
.addr-hero {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 157, 255, 0.2);
}

.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.hero-cloud--1 {
  width: 100rpx;
  height: 34rpx;
  top: 16rpx;
  right: 24rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -24rpx;
  left: 16rpx;
}

.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  pointer-events: none;
}

.hero-star--1 {
  bottom: 20rpx;
  left: 50rpx;
  animation: starTwinkle 2s ease-in-out infinite;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.5); }
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.hero-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

.hero-badge {
  padding: 6rpx 14rpx;
  height: fit-content;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}

.hero-footer {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
}

.hero-foot-note {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ═══ Empty State ═══ */
.empty-wrap {
  margin-top: 20rpx;
  padding: 48rpx 24rpx 40rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-buddy { margin-bottom: 16rpx; }

.empty-pill-body {
  position: relative;
  width: 64rpx;
  height: 84rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(74, 157, 255, 0.18);
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-pill-left {
  position: absolute; left: 0; top: 0; width: 50%; height: 100%;
  background: #FFFFFF;
}

.empty-pill-right {
  position: absolute; right: 0; top: 0; width: 50%; height: 100%;
  background: #4A9DFF;
}

.empty-pill-eye {
  position: absolute;
  width: 16rpx; height: 18rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 24rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0,0,0,0.06);
}

.empty-pill-left .empty-pill-eye { left: 8rpx; }
.empty-pill-right .empty-pill-eye { right: 8rpx; }

.empty-pill-pupil {
  position: absolute;
  width: 8rpx; height: 10rpx;
  background: #2B5EA7;
  border-radius: 50%;
  bottom: 3rpx;
  left: 50%;
  transform: translateX(-50%);
}

.empty-pill-mouth {
  position: absolute;
  bottom: 22rpx; left: 50%;
  transform: translateX(-50%);
  width: 14rpx; height: 6rpx;
  border-bottom: 2rpx solid #2B5EA7;
  border-radius: 0 0 50% 50%;
  z-index: 3;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A3A5C;
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8BA4C7;
  text-align: center;
}

.empty-wrap .btn {
  margin-top: 24rpx;
}

/* ═══ Address Card ═══ */
.addr-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.addr-card {
  position: relative;
  overflow: hidden;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(74, 157, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(43, 94, 167, 0.06);
  transition: all 150ms ease;
}

.addr-card:active {
  transform: scale(0.98);
}

.addr-card--active {
  border-color: rgba(74, 157, 255, 0.25);
  background: rgba(74, 157, 255, 0.03);
  box-shadow: 0 6rpx 24rpx rgba(74, 157, 255, 0.1);
}

.card-corner {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  pointer-events: none;
}

.card-corner--tl {
  top: 10rpx;
  left: 10rpx;
  border-top: 2rpx solid rgba(74, 157, 255, 0.15);
  border-left: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 4rpx 0 0 0;
}

.card-corner--br {
  bottom: 10rpx;
  right: 10rpx;
  border-bottom: 2rpx solid rgba(74, 157, 255, 0.15);
  border-right: 2rpx solid rgba(74, 157, 255, 0.15);
  border-radius: 0 0 4rpx 0;
}

.addr-line-1 {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx 10rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A3A5C;
}

.addr-phone {
  font-size: 24rpx;
  color: #8BA4C7;
}

.addr-badge {
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 999rpx;
  padding: 2rpx 12rpx;
}

.addr-badge--default {
  color: #4A9DFF;
  background: rgba(74, 157, 255, 0.08);
  border: 1rpx solid rgba(74, 157, 255, 0.12);
}

.addr-badge--tag {
  color: #6DB8FF;
  background: rgba(109, 184, 255, 0.08);
  border: 1rpx solid rgba(109, 184, 255, 0.12);
}

.addr-line-2 {
  margin-top: 12rpx;
  line-height: 1.6;
  font-size: 24rpx;
  color: #8BA4C7;
}

/* ═══ Actions ═══ */
.addr-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
}

.action-btn {
  min-width: 120rpx;
  height: 52rpx;
  border-radius: 12rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #4A9DFF;
  background: rgba(74, 157, 255, 0.06);
  border: 1rpx solid rgba(74, 157, 255, 0.12);
  transition: transform 150ms ease;
}

.action-btn:active { transform: scale(0.95); }

.action-btn--disabled {
  opacity: 0.45;
  pointer-events: none;
}

.action-btn--edit {
  color: #4A9DFF;
  background: rgba(74, 157, 255, 0.06);
  border-color: rgba(74, 157, 255, 0.12);
}

.action-btn--danger {
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.06);
  border-color: rgba(255, 107, 107, 0.12);
}

/* ═══ Bottom Bar ═══ */
.bottom-bar {
  margin-top: 20rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
}

/* ═══ Button ═══ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 8rpx 24rpx rgba(74, 157, 255, 0.25);
  transition: transform 150ms ease;
}

.btn:active { transform: scale(0.97); }

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
  .empty-pill-body { animation: none; }
}
