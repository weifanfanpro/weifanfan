/* ═══ AI Chat Scan Medicine — 暖调古典 ═══ */
.page {
  min-height: 100vh;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  margin-top: 8rpx;
  border-radius: 28rpx;
  background: linear-gradient(148deg, #1c1917 0%, #2d2824 52%, #3a342e 100%);
  box-shadow:
    0 24rpx 60rpx rgba(28, 25, 23, 0.25),
    0 4rpx 12rpx rgba(28, 25, 23, 0.08);
}

.hero::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.3);
  border-left: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.3);
  border-right: 2rpx solid rgba(46, 158, 143, 0.3);
  z-index: 3;
  pointer-events: none;
}

.tip {
  position: relative;
  z-index: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #fffefb;
}

.tip-sub {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: rgba(255, 254, 251, 0.55);
}

.frame-wrap {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.frame {
  width: 72vw;
  height: 72vw;
  max-width: 560rpx;
  max-height: 560rpx;
  background: #fffefb;
  border-radius: 24rpx;
  position: relative;
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  overflow: hidden;
}

.frame::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(circle at 50% 20%, rgba(46, 158, 143, 0.06), rgba(46, 158, 143, 0));
}

.cam {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.corner {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border: 8rpx solid #2E9E8F;
}
.tl { left: 12rpx; top: 12rpx; border-right: 0; border-bottom: 0; border-radius: 16rpx 0 0 0; }
.tr { right: 12rpx; top: 12rpx; border-left: 0; border-bottom: 0; border-radius: 0 16rpx 0 0; }
.bl { left: 12rpx; bottom: 12rpx; border-right: 0; border-top: 0; border-radius: 0 0 0 16rpx; }
.br { right: 12rpx; bottom: 12rpx; border-left: 0; border-top: 0; border-radius: 0 0 16rpx 0; }

.frame-hint {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #6b645c;
}

.recognizing {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 254, 251, 0.86);
  backdrop-filter: blur(10px);
}

.actions {
  margin-top: 20rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  border-radius: 20rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
}
