<view class="page page-padding safe-bottom anim-in">
  <custom-navbar title="咨询 · 识别药品" showBack="{true}" />
  <view class="hero">
    <view class="hero-cloud hero-cloud--1"></view>
    <view class="hero-star hero-star--1"></view>
    <view class="hero-cross hero-cross--1"></view>
    <view class="tip">为本次咨询识别药品</view>
    <view class="muted tip-sub">与底部「扫药」Tab 无关；识别为阿里云 OCR + 通义千问整理（云函数 recognizeMedicine），返回咨询后随问题发给 AI</view>
    <view class="hero-view-capsule">
      <view class="hero-view-capsule__dot"></view>
      <text class="hero-view-capsule__text">当前视角：{{viewLabel}}</text>
    </view>

    <view class="frame-wrap">
      <view class="frame">
        <camera
          class="cam"
          mode="normal"
          device-position="back"
          flash="{{flashMode}}"
          binderror="onCameraError"
        ></camera>
        <view class="corner tl"></view>
        <view class="corner tr"></view>
        <view class="corner bl"></view>
        <view class="corner br"></view>

        <view wx:if="{{recognizing}}" class="recognizing">
          <view class="loading-dots">
            <view class="loading-dot"></view>
            <view class="loading-dot"></view>
            <view class="loading-dot"></view>
          </view>
          <text class="recognizing-text">识别中…</text>
        </view>
        <view wx:else class="frame-hint muted">拍摄药盒或说明书</view>
      </view>
    </view>
  </view>

  <view class="actions">
    <view class="app-cell-group">
      <view class="app-cell">
        <view class="app-cell-title">闪光灯</view>
        <view class="toggle {{flashOn ? 'toggle--on' : ''}}" catchtap="noop" bindtap="onToggleFlash">
          <view class="toggle-dot"></view>
        </view>
      </view>
    </view>
    <view class="btn btn--primary tap-scale" bindtap="onStartRecognize">
      <text class="btn-text">拍照识别</text>
    </view>
    <view class="btn btn--secondary tap-scale" bindtap="onChooseFromAlbum">
      <text class="btn-text btn-text--secondary">从相册选择</text>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
