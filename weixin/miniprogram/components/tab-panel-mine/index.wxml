<view class="mine-root">
  <scroll-view scroll-y class="mine-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-content anim-in">

      <!-- ═══ Profile Hero ═══ -->
      <view class="hero" bind:tap="onEditProfile">
        <view class="hero-cloud hero-cloud--1"></view>
        <view class="hero-cloud hero-cloud--2"></view>
        <view class="hero-star hero-star--1"></view>
        <view class="hero-star hero-star--2"></view>
        <view class="hero-star hero-star--3"></view>
        <view class="hero-cross hero-cross--1"></view>
        <view class="hero-cross hero-cross--2"></view>

        <!-- 用户头像 -->
        <view class="hero-avatar">
          <view class="ha-ring">
            <image class="ha-img" src="{{user.avatarUrl}}" mode="aspectFill" />
          </view>
        </view>

        <text class="hero-name">{{user.nickName}}</text>
        <text class="hero-org">健康管理中心</text>

        <view class="hero-actions">
          <view class="hero-btn hero-btn--edit tap-scale" catch:tap="onEditProfile">
            <view class="hb-icon">
              <view class="hb-pencil"></view>
            </view>
            <text class="hb-text">编辑</text>
          </view>
          <view class="hero-btn hero-btn--points tap-scale" catch:tap="onGoPointsMall">
            <view class="hb-icon">
              <view class="hb-star-icon"></view>
            </view>
            <text class="hb-text">积分 {{pointsBalance}}</text>
          </view>
        </view>
      </view>

      <!-- ═══ Perspective & Family ═══ -->
      <view class="dual-card">
        <view class="dual-left tap-scale" bind:tap="onSwitchPerspective">
          <view class="dl-icon">
            <view class="dl-person-head"></view>
            <view class="dl-person-body"></view>
          </view>
          <view class="dl-text">
            <text class="dl-label">当前视角</text>
            <text class="dl-value">{{perspectiveLabel}}</text>
          </view>
          <view class="dl-arrow"></view>
        </view>
        <view class="dual-sep"></view>
        <view class="dual-right tap-scale" bind:tap="onGoFamily">
          <view class="dl-icon dl-icon--family">
            <view class="dl-pair-l">
              <view class="dl-pair-head"></view>
              <view class="dl-pair-body"></view>
            </view>
            <view class="dl-pair-r">
              <view class="dl-pair-head"></view>
              <view class="dl-pair-body"></view>
            </view>
          </view>
          <view class="dl-text">
            <text class="dl-label">家属协作</text>
            <text class="dl-value">成员与待办</text>
          </view>
        </view>
      </view>

      <!-- ═══ 用药管理 ═══ -->
      <view class="section-head">
        <view class="sh-pill"></view>
        <text class="sh-title">用药管理</text>
        <view class="sh-line"></view>
      </view>
      <view class="menu-card">
        <view
          wx:for="{{menuItems}}"
          wx:key="url"
          class="menu-row tap-scale"
          bind:tap="onNavItemTap"
          data-url="{{item.url}}"
        >
          <view class="mr-left">
            <view class="mr-icon mr-icon--{{item.cssIcon}}"></view>
            <text class="mr-title">{{item.title}}</text>
          </view>
          <view class="mr-arrow">
            <view class="mr-arrow-line"></view>
            <view class="mr-arrow-head"></view>
          </view>
        </view>
      </view>

      <!-- ═══ 服务支持 ═══ -->
      <view class="section-head">
        <view class="sh-pill"></view>
        <text class="sh-title">服务支持</text>
        <view class="sh-line"></view>
      </view>
      <view class="menu-card">
        <view
          wx:for="{{supportItems}}"
          wx:key="url"
          class="menu-row tap-scale"
          bind:tap="onNavItemTap"
          data-url="{{item.url}}"
        >
          <view class="mr-left">
            <view class="mr-icon mr-icon--{{item.cssIcon}}"></view>
            <text class="mr-title">{{item.title}}</text>
          </view>
          <view class="mr-arrow">
            <view class="mr-arrow-line"></view>
            <view class="mr-arrow-head"></view>
          </view>
        </view>
      </view>

      <!-- ═══ Safe Notice ═══ -->
      <view class="safe-notice">
        <view class="sn-icon">
          <view class="sn-i-body">
            <view class="sn-i-dot"></view>
            <view class="sn-i-stem"></view>
          </view>
        </view>
        <text class="sn-text">本工具仅辅助提醒，不替代医嘱。用药请遵医嘱，如有不适及时就医。</text>
      </view>

    </view>
  </scroll-view>
  <t-toast id="t-toast" />
</view>
