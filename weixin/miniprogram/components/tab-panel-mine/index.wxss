/* ═══════════════════════════════════════════
   我的 · Mine Panel
   蓝白卡通「药丸伙伴」风格
   ═══════════════════════════════════════════ */

/* ─── 色彩系统 ─── */
/* 主蓝 #4A9DFF  深蓝 #2B5EA7  天蓝 #A8DAFF
   珊瑚 #FF6B6B  蜜桃 #FFB366  薄荷 #52D9A0
   背景 #F0F7FF  文字 #1A3A5C / #3D5A80 / #8BA4C7 */

.mine-root {
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  min-height: 0;
  background: #F0F7FF;
}

.mine-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
}

.mine-content {
  padding: 0 28rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* ═══════════════════════════════════════════
   HERO — 蓝色渐变区
   ═══════════════════════════════════════════ */
.hero {
  position: relative;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  border-radius: 0 0 48rpx 48rpx;
  padding: 40rpx 28rpx 32rpx;
  margin: 0 -28rpx 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── 云朵 ── */
.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.hero-cloud--1 {
  width: 140rpx;
  height: 48rpx;
  top: 30rpx;
  right: 40rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -30rpx;
  left: 20rpx;
}

.hero-cloud--2 {
  width: 100rpx;
  height: 36rpx;
  top: 100rpx;
  left: 24rpx;
  opacity: 0.5;
  animation: cloudFloat 10s ease-in-out infinite reverse;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(12rpx); }
}

/* ── 星星 ── */
.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { top: 24rpx; left: 60rpx; }
.hero-star--2 { top: 60rpx; right: 120rpx; animation-delay: 0.7s; width: 6rpx; height: 6rpx; }
.hero-star--3 { top: 140rpx; left: 180rpx; animation-delay: 1.4s; width: 10rpx; height: 10rpx; }

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.4); }
}

/* ── 医疗十字 ── */
.hero-cross {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  opacity: 0.12;
}

.hero-cross::before,
.hero-cross::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.hero-cross::before {
  width: 18rpx;
  height: 5rpx;
  top: 6.5rpx;
  left: 0;
}

.hero-cross::after {
  width: 5rpx;
  height: 18rpx;
  top: 0;
  left: 6.5rpx;
}

.hero-cross--1 { top: 40rpx; right: 180rpx; transform: rotate(15deg); }
.hero-cross--2 { bottom: 60rpx; left: 60rpx; transform: rotate(-10deg); width: 14rpx; height: 14rpx; }

/* ═══════════════════════════════════════════
   用户头像
   ═══════════════════════════════════════════ */
.hero-avatar {
  position: relative;
  z-index: 2;
  margin-bottom: 16rpx;
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.ha-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, rgba(255,255,255,0.6) 100%);
  box-shadow: 0 8rpx 32rpx rgba(43, 94, 167, 0.25);
}

.ha-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

/* 用户信息 */
.hero-name {
  position: relative;
  z-index: 2;
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.3);
  margin-bottom: 4rpx;
}

.hero-org {
  position: relative;
  z-index: 2;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
}

/* ── 操作按钮 ── */
.hero-actions {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 16rpx;
}

.hero-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.hero-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.3);
}

.hb-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 铅笔图标 */
.hb-pencil {
  width: 16rpx;
  height: 3rpx;
  background: #FFFFFF;
  border-radius: 2rpx;
  transform: rotate(-45deg);
  position: relative;
}

.hb-pencil::after {
  content: '';
  position: absolute;
  right: -4rpx;
  top: -3rpx;
  width: 0;
  height: 0;
  border-left: 5rpx solid #FFFFFF;
  border-top: 3rpx solid transparent;
  border-bottom: 3rpx solid transparent;
}

/* 星星图标 */
.hb-star-icon {
  width: 18rpx;
  height: 18rpx;
  background: #FFB366;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

.hb-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ═══════════════════════════════════════════
   双栏卡片 — 视角 & 家属
   ═══════════════════════════════════════════ */
.dual-card {
  display: flex;
  align-items: stretch;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.06);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.dual-left,
.dual-right {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 20rpx;
}

.dual-left:active,
.dual-right:active {
  background: #F0F7FF;
}

.dual-sep {
  width: 1rpx;
  background: #E8F2FF;
  margin: 16rpx 0;
  flex-shrink: 0;
}

/* ── 图标 ── */
.dl-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: #E8F2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

/* 小人图标 */
.dl-person-head {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4A9DFF;
  position: absolute;
  top: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}

.dl-person-body {
  width: 20rpx;
  height: 10rpx;
  border-radius: 10rpx 10rpx 0 0;
  background: #4A9DFF;
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 双人图标 */
.dl-icon--family {
  gap: 0;
}

.dl-pair-l,
.dl-pair-r {
  position: relative;
  width: 20rpx;
  height: 28rpx;
}

.dl-pair-l {
  margin-right: -4rpx;
}

.dl-pair-r {
  margin-left: -4rpx;
}

.dl-pair-head {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4A9DFF;
  position: absolute;
  top: 2rpx;
  left: 50%;
  transform: translateX(-50%);
}

.dl-pair-body {
  width: 16rpx;
  height: 8rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #4A9DFF;
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  transform: translateX(-50%);
}

.dl-pair-r .dl-pair-head,
.dl-pair-r .dl-pair-body {
  background: #A8DAFF;
}

.dl-text {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
  flex: 1;
}

.dl-label {
  font-size: 20rpx;
  color: #8BA4C7;
}

.dl-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A3A5C;
}

/* 下拉箭头 */
.dl-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid #8BA4C7;
  flex-shrink: 0;
  margin-left: auto;
}

/* ═══════════════════════════════════════════
   分组标题
   ═══════════════════════════════════════════ */
.section-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.sh-pill {
  width: 24rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #4A9DFF 50%, #A8DAFF 50%);
  flex-shrink: 0;
}

.sh-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #1A3A5C;
  flex-shrink: 0;
}

.sh-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, #D1E5FF, transparent);
}

/* ═══════════════════════════════════════════
   菜单卡片
   ═══════════════════════════════════════════ */
.menu-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.06);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #F0F7FF;
  transition: background 120ms ease;
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-row:active {
  background: #F0F7FF;
}

.mr-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.mr-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A3A5C;
}

/* ── 箭头 ── */
.mr-arrow {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.mr-arrow-line {
  width: 12rpx;
  height: 2rpx;
  background: #D1E5FF;
}

.mr-arrow-head {
  width: 0;
  height: 0;
  border-top: 6rpx solid transparent;
  border-bottom: 6rpx solid transparent;
  border-left: 8rpx solid #D1E5FF;
}

/* ═══════════════════════════════════════════
   CSS-only 菜单图标
   ═══════════════════════════════════════════ */
.mr-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

.mr-icon-img {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

/* ── 药丸图标 ── */
.mr-icon--mi-pill {
  background: #E8F2FF;
}

.mr-icon--mi-pill::before {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #4A9DFF 50%, #A8DAFF 50%);
}

/* ── 时钟图标 ── */
.mr-icon--mi-clock {
  background: #FFF8ED;
}

.mr-icon--mi-clock::before {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border: 2.5rpx solid #FFB366;
  border-radius: 50%;
}

.mr-icon--mi-clock::after {
  content: '';
  position: absolute;
  width: 2rpx;
  height: 7rpx;
  background: #FFB366;
  top: 11rpx;
  left: 50%;
  transform: translateX(-50%);
  transform-origin: bottom;
  border-radius: 1rpx;
  box-shadow: 5rpx -2rpx 0 0 #FFB366;
}

/* ── 柱状图图标 ── */
.mr-icon--mi-chart {
  background: #FFF0F0;
}

.mr-icon--mi-chart::before {
  content: '';
  position: absolute;
  width: 4rpx;
  height: 14rpx;
  background: #FF6B6B;
  border-radius: 2rpx;
  left: 12rpx;
  bottom: 12rpx;
  box-shadow:
    8rpx 4rpx 0 0 #FF6B6B,
    16rpx -2rpx 0 0 #FFB366;
}

/* ── 盒子图标 ── */
.mr-icon--mi-box {
  background: #E8F2FF;
}

.mr-icon--mi-box::before {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 14rpx;
  border: 2.5rpx solid #4A9DFF;
  border-radius: 2rpx;
  top: 16rpx;
}

.mr-icon--mi-box::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 6rpx;
  border: 2.5rpx solid #4A9DFF;
  border-radius: 2rpx;
  top: 10rpx;
}

/* ── 星星图标 ── */
.mr-icon--mi-star {
  background: #FFF8ED;
}

.mr-icon--mi-star::before {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: #FFB366;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

/* ── 地图钉图标 ── */
.mr-icon--mi-pin {
  background: #FFF8ED;
}

.mr-icon--mi-pin::before {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 20rpx;
  border: 2.5rpx solid #FFB366;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  top: 8rpx;
  left: 50%;
  margin-left: -8rpx;
}

.mr-icon--mi-pin::after {
  content: '';
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #FFB366;
  top: 16rpx;
  left: 50%;
  margin-left: -3rpx;
}

/* ── 问号图标 ── */
.mr-icon--mi-help {
  background: #E8F2FF;
}

.mr-icon--mi-help::before {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border: 2.5rpx solid #4A9DFF;
  border-radius: 50%;
}

.mr-icon--mi-help::after {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 3rpx;
  background: #4A9DFF;
  border-radius: 2rpx;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  box-shadow:
    0rpx 5rpx 0 0 #4A9DFF,
    -2rpx 10rpx 0 0 #4A9DFF,
    0rpx 15rpx 0 0 #4A9DFF;
}

/* ── 气泡图标 ── */
.mr-icon--mi-chat {
  background: #E8F2FF;
}

.mr-icon--mi-chat::before {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 16rpx;
  border: 2.5rpx solid #4A9DFF;
  border-radius: 8rpx 8rpx 8rpx 2rpx;
  top: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* ── 链接图标 ── */
.mr-icon--mi-link {
  background: #E8F2FF;
}

.mr-icon--mi-link::before {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 2.5rpx solid #4A9DFF;
  border-radius: 50%;
  top: 8rpx;
  left: 10rpx;
}

.mr-icon--mi-link::after {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 2.5rpx solid #4A9DFF;
  border-radius: 50%;
  bottom: 8rpx;
  right: 10rpx;
}

/* ── ID图标 ── */
.mr-icon--mi-id {
  background: #F0F7FF;
}

.mr-icon--mi-id::before {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 16rpx;
  border: 2.5rpx solid #8BA4C7;
  border-radius: 3rpx;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
}

.mr-icon--mi-id::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 2rpx;
  background: #8BA4C7;
  border-radius: 1rpx;
  top: 18rpx;
  left: 50%;
  transform: translateX(-50%);
  box-shadow: 0 4rpx 0 0 #8BA4C7;
}

/* ═══════════════════════════════════════════
   安全提示
   ═══════════════════════════════════════════ */
.safe-notice {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid #E8F2FF;
  margin-top: 8rpx;
}

.sn-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #E8F2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

.sn-i-body {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sn-i-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #8BA4C7;
  margin-bottom: 2rpx;
}

.sn-i-stem {
  width: 2rpx;
  height: 8rpx;
  background: #8BA4C7;
  border-radius: 1rpx;
}

.sn-text {
  font-size: 22rpx;
  line-height: 1.6;
  color: #8BA4C7;
  flex: 1;
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .hero-avatar { animation: none; }
  .hero-cloud { animation: none; }
  .hero-star { animation: none; }
}
