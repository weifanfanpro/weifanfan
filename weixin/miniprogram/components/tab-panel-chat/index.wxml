<view class="chat-panel">
  <!-- ═══ Top toolbar ═══ -->
  <view class="toolbar" id="toolbar">
    <view class="toolbar-side toolbar-side--left">
      <view class="toolbar-btn tap-scale" bindtap="onOpenDrawer" hover-class="toolbar-btn--hover">
        <!-- CSS 药箱图标 -->
        <view class="css-icon css-icon--cabinet">
          <view class="ccb-body"></view>
          <view class="ccb-lid"></view>
          <view class="ccb-cross"></view>
        </view>
      </view>
    </view>
    <view class="toolbar-center">
      <view class="toolbar-pill"></view>
      <text class="toolbar-title">{{sessionTitle}}</text>
    </view>
    <view class="toolbar-side toolbar-side--right">
      <view class="toolbar-btn tap-scale" bindtap="onNewChat" hover-class="toolbar-btn--hover">
        <view class="css-icon css-icon--plus">
          <view class="cp-h"></view>
          <view class="cp-v"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- ═══ 记忆药丸墙 (全屏遮罩) ═══ -->
  <view class="pill-wall-mask {{drawerOpen ? 'pill-wall-mask--show' : ''}}" catchtap="onCloseDrawer" />
  <view class="pill-wall {{drawerOpen ? 'pill-wall--open' : ''}}">
    <!-- 顶部标题栏 -->
    <view class="pw-header">
      <view class="pw-title-row">
        <view class="pw-pill-deco"></view>
        <text class="pw-title">记忆药丸</text>
        <text class="pw-count">{{sessions.length}} 颗</text>
      </view>
      <view class="pw-close" bindtap="onCloseDrawer">
        <view class="css-icon css-icon--close">
          <view class="ccl-line ccl-line--1"></view>
          <view class="ccl-line ccl-line--2"></view>
        </view>
      </view>
    </view>

    <!-- 药丸网格 -->
    <scroll-view scroll-y class="pw-scroll" enhanced show-scrollbar="{{false}}">
      <!-- 加载态 -->
      <view wx:if="{{sessionListLoading}}" class="pw-loading">
        <view class="loading-dots">
          <view class="ld-dot ld-dot--1"></view>
          <view class="ld-dot ld-dot--2"></view>
          <view class="ld-dot ld-dot--3"></view>
        </view>
        <text class="pw-loading-text">正在回忆...</text>
      </view>

      <!-- 空态 -->
      <view wx:elif="{{sessions.length === 0}}" class="pw-empty">
        <view class="pwe-buddy">
          <view class="pwe-body">
            <view class="pwe-eye pwe-eye--l"></view>
            <view class="pwe-eye pwe-eye--r"></view>
            <view class="pwe-mouth"></view>
          </view>
        </view>
        <text class="pwe-text">还没有对话记录</text>
        <text class="pwe-sub">开始你的第一次咨询吧～</text>
      </view>

      <!-- 对话列表 -->
      <view wx:else class="pw-list">
        <view
          wx:for="{{sessions}}"
          wx:key="sessionId"
          wx:for-index="idx"
          class="list-item {{sessionId == item.sessionId ? 'list-item--active' : ''}}"
          data-idx="{{idx}}"
          bindtap="onPillTap"
        >
          <view class="list-item-dot"></view>
          <view class="list-item-body">
            <text class="list-item-title">{{item.title}}</text>
            <text class="list-item-time">{{item.timeText}}</text>
          </view>
          <view class="list-item-del" data-idx="{{idx}}" catchtap="onTapDel">
            <view class="lid-icon">
              <view class="lid-line lid-line--1"></view>
              <view class="lid-line lid-line--2"></view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 删除确认弹窗 -->
    <view wx:if="{{showDelConfirm}}" class="del-confirm-mask" catchtap="onCancelDel">
      <view class="del-confirm-box" catchtap="">
        <text class="del-confirm-title">删除对话</text>
        <text class="del-confirm-desc">确定删除这条历史记录吗？</text>
        <view class="del-confirm-actions">
          <view class="del-confirm-btn del-confirm-btn--cancel" bindtap="onCancelDel">取消</view>
          <view class="del-confirm-btn del-confirm-btn--ok" bindtap="onConfirmDel">删除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- ═══ Thinking status pill ═══ -->
  <view wx:if="{{thinkingLabel}}" class="thinking-pill" style="top: {{toolbarH}}px;">
    <view class="thinking-dot"></view>
    <text class="thinking-text">{{thinkingLabel}}</text>
  </view>

  <!-- ═══ Main chat area ═══ -->
  <view class="chat-main">
    <!-- Welcome state -->
    <block wx:if="{{messages.length === 0 && !sending}}">
      <view class="welcome">
        <!-- 药丸伙伴头像 -->
        <view class="welcome-buddy">
          <view class="wb-body">
            <view class="wb-eye wb-eye--l"></view>
            <view class="wb-eye wb-eye--r"></view>
            <view class="wb-cheek wb-cheek--l"></view>
            <view class="wb-cheek wb-cheek--r"></view>
            <view class="wb-mouth"></view>
          </view>
        </view>
        <text class="welcome-heading">嗨！我是药丸伙伴</text>
        <text class="welcome-desc">我可以帮你了解用药常识、提醒与健康管理，请把你的问题交给我~</text>
        <view class="welcome-hints">
          <view class="welcome-hint tap-scale" bindtap="onQuickQuestion" data-q="感冒了可以吃什么药？">
            <view class="wh-icon">
              <view class="wh-pill"></view>
            </view>
            <text>感冒了可以吃什么药？</text>
          </view>
          <view class="welcome-hint tap-scale" bindtap="onQuickQuestion" data-q="降压药漏服了怎么办？">
            <view class="wh-icon">
              <view class="wh-clock"></view>
            </view>
            <text>降压药漏服了怎么办？</text>
          </view>
        </view>
      </view>
    </block>

    <!-- Messages -->
    <scroll-view
      wx:else
      scroll-y
      class="chat-scroll"
      scroll-into-view="{{scrollTarget}}"
      scroll-with-animation
      enhanced
      show-scrollbar="{{false}}"
      key="{{_scrollKey}}"
    >
      <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="msg-wrap">
        <!-- User message -->
        <view wx:if="{{item.role === 'user'}}" class="msg-row msg-row--user">
          <view
            wx:if="{{item.consultAttach}}"
            class="msg-consult-link tap-scale"
            data-index="{{index}}"
            bindtap="onOpenMsgConsultDetail"
          >查看关联药品</view>
          <view class="bubble bubble--user">
            <text class="bubble-text bubble-text--user">{{item.displayContent || item.content}}</text>
          </view>
        </view>

        <!-- AI message -->
        <view wx:else class="msg-row msg-row--ai">
          <view class="ai-avatar">
            <view class="aa-pill">
              <view class="aa-pill-left"></view>
              <view class="aa-pill-right"></view>
            </view>
          </view>
          <view class="msg-ai-body">
            <!-- Reasoning toggle -->
            <view wx:if="{{item.reasoning}}" class="reasoning-block">
              <view class="reasoning-toggle" data-index="{{index}}" bindtap="onToggleReasoning">
                <view class="rt-arrow {{reasoningOpen[index] ? 'rt-arrow--up' : ''}}"></view>
                <text>思考过程</text>
              </view>
              <view wx:if="{{reasoningOpen[index]}}" class="reasoning-content">
                <text class="reasoning-text" user-select>{{item.reasoning}}</text>
              </view>
            </view>
            <!-- Main response -->
            <view class="bubble bubble--ai">
              <text class="bubble-text bubble-text--ai" user-select>{{item.content}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Typing indicator -->
      <view wx:if="{{sending}}" class="msg-row msg-row--ai">
        <view class="ai-avatar">
          <view class="aa-pill">
            <view class="aa-pill-left"></view>
            <view class="aa-pill-right"></view>
          </view>
        </view>
        <view class="typing-indicator">
          <view class="loading-dots">
            <view class="ld-dot ld-dot--1"></view>
            <view class="ld-dot ld-dot--2"></view>
            <view class="ld-dot ld-dot--3"></view>
          </view>
          <text class="typing-label">正在回复...</text>
        </view>
      </view>
      <view id="chat-anchor" class="chat-anchor"></view>
    </scroll-view>
  </view>

  <!-- ═══ Tool option pills ═══ -->
  <view class="option-bar">
    <scroll-view scroll-x class="option-scroll" enhanced show-scrollbar="{{false}}" enable-flex>
      <view class="option-inner">
        <view class="option-pill {{deepThinking ? 'option-pill--on' : ''}} tap-scale" bindtap="toggleDeepThinking">
          <view class="op-icon">
            <view class="opi-layer opi-layer--1"></view>
            <view class="opi-layer opi-layer--2"></view>
          </view>
          <text>深度思考</text>
        </view>
        <view class="option-pill {{webSearch ? 'option-pill--on' : ''}} tap-scale" bindtap="toggleWebSearch">
          <view class="op-icon">
            <view class="opi-globe"></view>
            <view class="opi-globe-line"></view>
          </view>
          <text>联网搜索</text>
        </view>
        <view class="option-pill option-pill--accent tap-scale" bindtap="onOpenMedicineSheet">
          <view class="op-icon">
            <view class="opi-bottle"></view>
          </view>
          <text>选择咨询药品</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ═══ Medicine pick sheet ═══ -->
  <view class="sheet-mask {{sheetVisible ? 'sheet-mask--show' : ''}}" catchtap="onCloseSheet" />
  <view class="sheet {{sheetVisible ? 'sheet--open' : ''}}">
    <view class="sheet-handle"></view>
    <view class="sheet-title">选择咨询方式</view>
    <view class="sheet-item tap-scale" bindtap="onSheetScan">
      <view class="si-icon">
        <view class="sii-lens"></view>
        <view class="sii-handle"></view>
      </view>
      <text class="sheet-item-label">扫描药品</text>
    </view>
    <view class="sheet-item tap-scale" bindtap="onSheetPickList">
      <view class="si-icon">
        <view class="sii-list"></view>
        <view class="sii-dot sii-dot--1"></view>
        <view class="sii-dot sii-dot--2"></view>
        <view class="sii-dot sii-dot--3"></view>
      </view>
      <text class="sheet-item-label">从药单选择</text>
    </view>
    <view class="sheet-cancel tap-scale" bindtap="onCloseSheet">取消</view>
  </view>

  <!-- ═══ Input dock ═══ -->
  <view class="input-dock" id="input-dock">
    <view wx:if="{{toolStatusText}}" class="tool-badge">{{toolStatusText}}</view>
    <view class="input-card">
      <!-- Consult chip -->
      <view wx:if="{{consultTitle}}" class="consult-chip">
        <view class="consult-chip-body tap-scale" bindtap="onOpenConsultDetail">
          <view class="consult-chip-info">
            <text class="consult-chip-name">{{consultTitle}}</text>
            <text class="consult-chip-hint">点击查看详情</text>
          </view>
        </view>
        <view class="consult-chip-x" catchtap="onClearConsult">
          <view class="ccx-icon">
            <view class="ccx-line ccx-line--1"></view>
            <view class="ccx-line ccx-line--2"></view>
          </view>
        </view>
      </view>
      <!-- Textarea -->
      <view class="input-row">
        <textarea
          class="input-field"
          value="{{inputValue}}"
          placeholder="请输入你的健康问题"
          placeholder-class="input-placeholder"
          maxlength="-1"
          auto-height
          show-confirm-bar="{{false}}"
          cursor-spacing="24"
          bindinput="onInput"
          confirm-type="send"
          bindconfirm="onSend"
        />
        <view class="send-area {{canSend ? '' : 'send-area--off'}}" bindtap="onSend">
          <view class="send-circle">
            <view class="send-arrow"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
