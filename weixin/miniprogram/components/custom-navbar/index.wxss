/* ═══ 导航栏 · 药丸伙伴风格 ═══ */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 100%);
}

.navbar__content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 16rpx;
}

.navbar__left {
  flex-shrink: 0;
  width: 72rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.navbar__back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  transition: background 150ms ease;
}

.navbar__back:active {
  background: rgba(255, 255, 255, 0.3);
}

.navbar__chevron {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #FFFFFF;
  border-bottom: 4rpx solid #FFFFFF;
  transform: rotate(45deg);
  margin-left: 4rpx;
}

.navbar__title-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 0;
  padding: 0 16rpx;
}

/* 小药丸图标 */
.navbar__pill-icon {
  width: 24rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #FFFFFF 50%, rgba(255,255,255,0.5) 50%);
  flex-shrink: 0;
}

.navbar__title {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.3);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.navbar__right {
  flex-shrink: 0;
  width: 72rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.navbar-placeholder {
  width: 100%;
  background: transparent;
}
