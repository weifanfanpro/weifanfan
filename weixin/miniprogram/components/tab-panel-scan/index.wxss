/* ═══ Scan Panel — 暖调古典 ═══ */
.page {
  min-height: 100%;
}

.scan-page {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  padding-bottom: 16rpx;
  background: #f5f2ed;
  background-image:
    repeating-linear-gradient(
      0deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx, rgba(28, 25, 23, 0.012) 80rpx
    );
}

.library-zone {
  flex-shrink: 0;
  padding: 8rpx 0 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  margin-bottom: 8rpx;
}

.hero {
  position: relative;
  padding: 28rpx;
  box-sizing: border-box;
  margin-top: 8rpx;
  flex: 1;
  flex-shrink: 1;
  min-height: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border-radius: 28rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 24rpx 64rpx rgba(28, 25, 23, 0.06),
    0 4rpx 12rpx rgba(28, 25, 23, 0.03);
}

/* 角饰 */
.hero::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 28rpx;
  height: 28rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.15);
  border-left: 2rpx solid rgba(46, 158, 143, 0.15);
  z-index: 3;
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 28rpx;
  height: 28rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.15);
  border-right: 2rpx solid rgba(46, 158, 143, 0.15);
  z-index: 3;
  pointer-events: none;
}

.tip {
  font-size: 34rpx;
  font-weight: 700;
  color: #1c1917;
  position: relative;
  z-index: 1;
}

.tip-sub {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #b0a99f;
  position: relative;
  z-index: 1;
}

.hero-view-capsule {
  margin-top: 14rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(91, 122, 107, 0.06);
  border: 1rpx solid rgba(91, 122, 107, 0.1);
  position: relative;
  z-index: 1;
  align-self: flex-start;
}

.hero-view-capsule__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5b7a6b;
  opacity: 0.5;
}

.hero-view-capsule__text {
  font-size: 22rpx;
  color: #6b645c;
  font-weight: 500;
}

.frame-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  overflow: hidden;
  width: 100%;
}

.frame {
  position: relative;
  width: 72vw;
  max-width: 100%;
  max-height: 100%;
  aspect-ratio: 1;
  height: auto;
  background: #f0ede6;
  border-radius: 24rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  overflow: hidden;
}

.frame::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(circle at 50% 20%, rgba(46, 158, 143, 0.06), transparent);
}

.cam {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* 扫描角 — 赤陶色 */
.corner {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border: 6rpx solid #2E9E8F;
}

.tl { left: 12rpx; top: 12rpx; border-right: 0; border-bottom: 0; border-radius: 12rpx 0 0 0; }
.tr { right: 12rpx; top: 12rpx; border-left: 0; border-bottom: 0; border-radius: 0 12rpx 0 0; }
.bl { left: 12rpx; bottom: 12rpx; border-right: 0; border-top: 0; border-radius: 0 0 0 12rpx; }
.br { right: 12rpx; bottom: 12rpx; border-left: 0; border-top: 0; border-radius: 0 0 12rpx 0; }

.frame-hint {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #b0a99f;
}

.recognizing {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 254, 251, 0.88);
  backdrop-filter: blur(10px);
}

.actions {
  margin-top: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(28, 25, 23, 0.03);
}
