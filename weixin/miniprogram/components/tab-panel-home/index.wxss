/* ═══════════════════════════════════════════
   药丸伙伴 · Medicine Buddy
   卡通医疗风格首页
   ═══════════════════════════════════════════ */

/* ─── 色彩系统 ─── */
/* 主蓝 #4A9DFF  深蓝 #2B5EA7  天蓝 #E8F2FF
   珊瑚 #FF6B6B  蜜桃 #FFB366  薄荷 #52D9A0
   薰衣草 #B8A9FF  背景 #F0F7FF  文字 #3D5A80 */

.page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #F0F7FF;
}

.safe-shell {
  padding: 0 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

.scrollarea {
  flex: 1;
  min-height: 0;
  overflow-y: hidden;
}

.bottom-spacer { height: 48rpx; }

/* ═══════════════════════════════════════════
   HERO — 药丸伙伴世界
   ═══════════════════════════════════════════ */
.hero {
  position: relative;
  background: linear-gradient(170deg, #4A9DFF 0%, #6DB8FF 40%, #A8DAFF 100%);
  border-radius: 0 0 48rpx 48rpx;
  padding: 24rpx 28rpx 36rpx;
  margin: 0 -28rpx;
  overflow: hidden;
}

/* ── 云朵 ── */
.hero-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.hero-cloud--1 {
  width: 160rpx;
  height: 56rpx;
  top: 60rpx;
  right: 40rpx;
  animation: cloudFloat 8s ease-in-out infinite;
}

.hero-cloud--1::before {
  content: '';
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  top: -36rpx;
  left: 24rpx;
}

.hero-cloud--2 {
  width: 120rpx;
  height: 40rpx;
  top: 140rpx;
  left: 30rpx;
  opacity: 0.6;
  animation: cloudFloat 10s ease-in-out infinite reverse;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(16rpx); }
}

/* ── 星星 ── */
.hero-star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  animation: starTwinkle 2s ease-in-out infinite;
}

.hero-star--1 { top: 40rpx; left: 60rpx; animation-delay: 0s; }
.hero-star--2 { top: 80rpx; right: 120rpx; animation-delay: 0.7s; width: 6rpx; height: 6rpx; }
.hero-star--3 { top: 120rpx; left: 160rpx; animation-delay: 1.4s; width: 10rpx; height: 10rpx; }

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.4); }
}

/* ── 医疗十字 ── */
.hero-cross {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  opacity: 0.12;
}

.hero-cross::before,
.hero-cross::after {
  content: '';
  position: absolute;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.hero-cross::before {
  width: 20rpx;
  height: 6rpx;
  top: 7rpx;
  left: 0;
}

.hero-cross::after {
  width: 6rpx;
  height: 20rpx;
  top: 0;
  left: 7rpx;
}

.hero-cross--1 { top: 50rpx; right: 200rpx; transform: rotate(15deg); }
.hero-cross--2 { bottom: 80rpx; left: 50rpx; transform: rotate(-10deg); width: 16rpx; height: 16rpx; }

/* ── 顶部信息 ── */
.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 2;
  margin-bottom: 20rpx;
}

.hero-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(43, 94, 167, 0.3);
}

.hero-time-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8px);
}

.hero-time-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #52D9A0;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(82, 217, 160, 0.4); }
  50% { opacity: 0.7; box-shadow: 0 0 0 6rpx rgba(82, 217, 160, 0); }
}

.hero-time-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-variant-numeric: tabular-nums;
  letter-spacing: 1rpx;
}

/* ═══════════════════════════════════════════
   药丸伙伴角色
   ═══════════════════════════════════════════ */
.pill-buddy {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 8rpx 0 24rpx;
}

.pill-body {
  position: relative;
  width: 140rpx;
  height: 180rpx;
  border-radius: 70rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(43, 94, 167, 0.3);
  animation: pillBounce 3s ease-in-out infinite;
}

@keyframes pillBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.pill-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 50%;
  height: 100%;
  background: #FFFFFF;
}

.pill-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 50%;
  height: 100%;
  background: #4A9DFF;
}

/* 眼睛 */
.pill-eye {
  position: absolute;
  width: 32rpx;
  height: 36rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 52rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.pill-eye--l { left: 18rpx; }
.pill-eye--r { right: 18rpx; }

.pill-pupil {
  position: absolute;
  width: 16rpx;
  height: 18rpx;
  background: #2B5EA7;
  border-radius: 50%;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  animation: pupilLook 4s ease-in-out infinite;
}

.pill-pupil::after {
  content: '';
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #FFFFFF;
  border-radius: 50%;
  top: 2rpx;
  right: 2rpx;
}

@keyframes pupilLook {
  0%, 100% { transform: translateX(-50%); }
  25% { transform: translateX(-30%); }
  75% { transform: translateX(-70%); }
}

/* 腮红 */
.pill-cheek {
  position: absolute;
  width: 24rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 179, 102, 0.4);
  top: 92rpx;
}

.pill-cheek--l { left: 8rpx; }
.pill-cheek--r { right: 8rpx; }

/* 嘴巴 */
.pill-mouth {
  position: absolute;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
}

.pill-mouth--happy {
  width: 28rpx;
  height: 14rpx;
  border-bottom: 4rpx solid #2B5EA7;
  border-radius: 0 0 50% 50%;
}

.pill-mouth--worried {
  width: 20rpx;
  height: 12rpx;
  border-top: 4rpx solid #2B5EA7;
  border-radius: 50% 50% 0 0;
}

/* 数字气泡 */
.pill-num-bubble {
  position: absolute;
  right: -20rpx;
  top: -10rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 4;
  animation: bubblePop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes bubblePop {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.pill-num {
  font-size: 48rpx;
  font-weight: 900;
  color: #4A9DFF;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.pill-num-label {
  font-size: 18rpx;
  color: #8BA4C7;
  font-weight: 600;
  margin-top: 2rpx;
}

.pill-view-tag {
  position: absolute;
  left: -16rpx;
  bottom: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(4px);
  z-index: 4;
}

.pill-view-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* ═══════════════════════════════════════════
   进度胶囊
   ═══════════════════════════════════════════ */
.capsule-progress {
  position: relative;
  z-index: 2;
}

.capsule-track {
  height: 28rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.25);
  overflow: hidden;
  position: relative;
}

.capsule-fill {
  height: 100%;
  border-radius: 14rpx;
  background: linear-gradient(90deg, #52D9A0, #7EECC0);
  transition: width 600ms cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
  overflow: hidden;
}

.capsule-fill-shine {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.4), transparent);
  border-radius: 14rpx 14rpx 0 0;
}

.capsule-labels {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.capsule-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.capsule-num {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

/* ═══════════════════════════════════════════
   焦点卡片
   ═══════════════════════════════════════════ */
.focus {
  position: relative;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-top: -16rpx;
  box-shadow: 0 8rpx 32rpx rgba(43, 94, 167, 0.08);
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 药片装饰 */
.focus-pill-deco {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  opacity: 0.08;
}

.fpd-cap {
  width: 40rpx;
  height: 80rpx;
  border-radius: 20rpx;
}

.fpd-cap--left { background: #4A9DFF; }
.fpd-cap--right { background: #A8DAFF; margin-left: -8rpx; }

.focus-status-bar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.focus-status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4A9DFF;
}

.focus-status-dot--overdue { background: #FF6B6B; }
.focus-status-dot--notYet { background: #A8DAFF; }
.focus-status-dot--taken { background: #52D9A0; }

.focus-status-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #4A9DFF;
}

.focus-status-text--overdue { color: #FF6B6B; }
.focus-status-text--notYet { color: #8BA4C7; }
.focus-status-text--taken { color: #52D9A0; }

.focus-view-pill {
  margin-left: auto;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #E8F2FF;
}

.focus-view-text {
  font-size: 20rpx;
  color: #4A9DFF;
  font-weight: 600;
}

.focus-name {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #1A3A5C;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.focus-dose {
  display: block;
  font-size: 26rpx;
  color: #8BA4C7;
  margin-bottom: 24rpx;
}

/* ── 操作按钮 ── */
.focus-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #4A9DFF, #6DB8FF);
  box-shadow: 0 6rpx 20rpx rgba(74, 157, 255, 0.3);
  transition: transform 150ms ease, box-shadow 150ms ease;
}

.focus-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(74, 157, 255, 0.2);
}

.focus-btn--overdue {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.3);
}

.focus-btn--taken,
.focus-btn--notYet {
  background: #E8F2FF;
  box-shadow: none;
}

.focus-btn--disabled {
  opacity: 0.5;
  pointer-events: none;
}

.focus-btn-pill {
  width: 24rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.4);
}

.focus-btn--taken .focus-btn-pill,
.focus-btn--notYet .focus-btn-pill {
  background: #A8DAFF;
}

.focus-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.focus-btn--taken .focus-btn-text,
.focus-btn--notYet .focus-btn-text {
  color: #8BA4C7;
}

/* ── 空态 ── */
.focus--empty,
.focus--done {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 28rpx;
  text-align: center;
}

/* 空态小药丸 */
.empty-buddy {
  margin-bottom: 20rpx;
}

.eb-body {
  width: 80rpx;
  height: 100rpx;
  border-radius: 40rpx;
  background: linear-gradient(180deg, #E8F2FF 50%, #D1E5FF 50%);
  position: relative;
  animation: pillBounce 3s ease-in-out infinite;
}

.eb-eye {
  position: absolute;
  width: 14rpx;
  height: 16rpx;
  background: #8BA4C7;
  border-radius: 50%;
  top: 28rpx;
}

.eb-eye--l { left: 18rpx; }
.eb-eye--r { right: 18rpx; }

.eb-mouth {
  position: absolute;
  width: 20rpx;
  height: 10rpx;
  border-bottom: 3rpx solid #8BA4C7;
  border-radius: 0 0 50% 50%;
  bottom: 28rpx;
  left: 50%;
  transform: translateX(-50%);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D5A80;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #8BA4C7;
}

/* ── 完成态 ── */
.done-buddy {
  margin-bottom: 20rpx;
}

.db-body {
  width: 80rpx;
  height: 100rpx;
  border-radius: 40rpx;
  background: linear-gradient(180deg, #D4F5E6 50%, #B0EACC 50%);
  position: relative;
  animation: pillBounce 3s ease-in-out infinite;
}

.db-eye {
  position: absolute;
  width: 14rpx;
  height: 4rpx;
  background: #2B7A50;
  border-radius: 0 0 50% 50%;
  top: 32rpx;
  border-bottom: 3rpx solid #2B7A50;
}

.db-eye--l { left: 18rpx; transform: rotate(-10deg); }
.db-eye--r { right: 18rpx; transform: rotate(10deg); }

.db-mouth {
  position: absolute;
  width: 24rpx;
  height: 12rpx;
  border-bottom: 3rpx solid #2B7A50;
  border-radius: 0 0 50% 50%;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
}

.db-star {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background: #FFB366;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  animation: starTwinkle 1.5s ease-in-out infinite;
}

.db-star--1 { top: 4rpx; right: -16rpx; }
.db-star--2 { top: 20rpx; left: -16rpx; animation-delay: 0.5s; }

.done-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2B7A50;
  margin-bottom: 8rpx;
}

.done-sub {
  font-size: 24rpx;
  color: #52D9A0;
}

/* ═══════════════════════════════════════════
   快捷入口 — 胶囊按钮
   ═══════════════════════════════════════════ */
.quick-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 12rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.06);
  transition: transform 150ms ease;
}

.quick-btn:active { transform: scale(0.95); }

.qb-icon {
  width: 52rpx;
  height: 52rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qb-icon--anim {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qb-img {
  width: 64rpx;
  height: 64rpx;
}

.qb-icon--float {
  animation: iconFloat 2.5s ease-in-out infinite;
}

.qb-icon--pulse {
  animation: iconPulse 2s ease-in-out infinite;
}

.qb-icon--bounce {
  animation: iconBounce 2s ease-in-out infinite;
}

@keyframes iconFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

@keyframes iconPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

@keyframes iconBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  30% { transform: translateY(-8rpx) scale(1.05); }
  60% { transform: translateY(0) scale(0.97); }
}

.qb-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #3D5A80;
}

/* 加号图标 */
.qb-plus-h, .qb-plus-v {
  position: absolute;
  background: #4A9DFF;
  border-radius: 2rpx;
}

.qb-plus-h { width: 24rpx; height: 4rpx; }
.qb-plus-v { width: 4rpx; height: 24rpx; }

/* 扫描图标 */
.qb-scan-line {
  position: absolute;
  width: 28rpx;
  height: 3rpx;
  background: #4A9DFF;
  top: 16rpx;
}

.qb-scan-line--b { top: auto; bottom: 16rpx; }

.qb-scan-corner {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-color: #4A9DFF;
  border-style: solid;
  border-width: 0;
}

.qb-scan-corner--tl { top: 8rpx; left: 8rpx; border-top-width: 3rpx; border-left-width: 3rpx; border-radius: 3rpx 0 0 0; }
.qb-scan-corner--tr { top: 8rpx; right: 8rpx; border-top-width: 3rpx; border-right-width: 3rpx; border-radius: 0 3rpx 0 0; }
.qb-scan-corner--bl { bottom: 8rpx; left: 8rpx; border-bottom-width: 3rpx; border-left-width: 3rpx; border-radius: 0 0 0 3rpx; }
.qb-scan-corner--br { bottom: 8rpx; right: 8rpx; border-bottom-width: 3rpx; border-right-width: 3rpx; border-radius: 0 0 3rpx 0; }

/* 地图图标 */
.qb-pin {
  width: 20rpx;
  height: 24rpx;
  border: 3rpx solid #FFB366;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  position: relative;
}

.qb-pin-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FFB366;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* ═══════════════════════════════════════════
   风险提示
   ═══════════════════════════════════════════ */
.risk-card {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.risk-card--mid {
  background: #FFF8ED;
  border: 2rpx solid #FFE0B2;
}

.risk-card--high {
  background: #FFF0F0;
  border: 2rpx solid #FFCDD2;
}

.risk-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.risk-card--mid .risk-icon { background: #FFB366; }
.risk-card--high .risk-icon { background: #FF6B6B; }

.risk-icon-char {
  font-size: 22rpx;
  font-weight: 900;
  color: #FFFFFF;
}

.risk-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #3D5A80;
  flex: 1;
}

/* ═══════════════════════════════════════════
   统计行
   ═══════════════════════════════════════════ */
.stats-row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(43, 94, 167, 0.06);
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.stat-sep {
  width: 1rpx;
  height: 40rpx;
  background: #E8F2FF;
  flex-shrink: 0;
  margin: 0 8rpx;
}

.stat-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

.stat-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.stat-icon--risk { background: #FFF0E0; }
.stat-icon--stock { background: #E0F0FF; }

/* 盾牌图标 */
.si-shield {
  width: 18rpx;
  height: 20rpx;
  border: 2.5rpx solid #FFB366;
  border-radius: 2rpx 2rpx 50% 50%;
  position: relative;
}

.si-shield::after {
  content: '';
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-bottom: 2rpx solid #FFB366;
  border-right: 2rpx solid #FFB366;
  transform: rotate(45deg);
  top: 4rpx;
  left: 50%;
  margin-left: -3rpx;
}

/* 盒子图标 */
.si-box {
  width: 20rpx;
  height: 14rpx;
  border: 2.5rpx solid #4A9DFF;
  border-radius: 2rpx;
  position: absolute;
  bottom: 10rpx;
}

.si-box-lid {
  width: 24rpx;
  height: 6rpx;
  border: 2.5rpx solid #4A9DFF;
  border-radius: 2rpx;
  position: absolute;
  top: 12rpx;
}

.stat-val {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #1A3A5C;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #8BA4C7;
  margin-top: 4rpx;
}

/* ═══════════════════════════════════════════
   今日用药时间线
   ═══════════════════════════════════════════ */
.timeline-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.th-pill {
  width: 28rpx;
  height: 14rpx;
  border-radius: 7rpx;
  background: linear-gradient(90deg, #4A9DFF 50%, #A8DAFF 50%);
}

.th-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A3A5C;
  flex: 1;
}

.th-count {
  font-size: 22rpx;
  color: #8BA4C7;
  font-weight: 600;
}

/* ── 时段标签 ── */
.slot-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 0 10rpx;
}

.slot-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4A9DFF;
  opacity: 0.4;
}

.slot-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #8BA4C7;
  letter-spacing: 0.5rpx;
}

/* ── 药品行 ── */
.med-row {
  display: flex;
  align-items: stretch;
  margin-bottom: 10rpx;
}

.mr-time {
  width: 80rpx;
  flex-shrink: 0;
  padding-top: 24rpx;
  display: flex;
  justify-content: flex-end;
  padding-right: 16rpx;
}

.mr-time-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #4A9DFF;
  font-variant-numeric: tabular-nums;
  letter-spacing: 1rpx;
}

/* 节点 */
.mr-node {
  width: 28rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.mr-stem {
  width: 3rpx;
  flex: 1;
  background: #E8F2FF;
}

.mr-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 3rpx solid #D1E5FF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 2;
  position: relative;
}

.mr-dot-inner {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #D1E5FF;
}

.mr-dot--notYet { border-color: #A8DAFF; }
.mr-dot--notYet .mr-dot-inner { background: #A8DAFF; }

.mr-dot--due {
  border-color: #4A9DFF;
  box-shadow: 0 0 0 4rpx rgba(74, 157, 255, 0.15);
}
.mr-dot--due .mr-dot-inner { background: #4A9DFF; }

.mr-dot--overdue {
  border-color: #FF6B6B;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.15);
}
.mr-dot--overdue .mr-dot-inner { background: #FF6B6B; }

.mr-dot--taken { border-color: #52D9A0; }
.mr-dot--taken .mr-dot-inner { background: #52D9A0; }

/* ── 内容卡 ── */
.mr-card {
  flex: 1;
  min-width: 0;
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  margin-left: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(43, 94, 167, 0.05);
  transition: transform 120ms ease;
}

.mr-card:active { transform: scale(0.98); }

.mr-card--due {
  box-shadow: 0 4rpx 16rpx rgba(74, 157, 255, 0.12);
  border: 2rpx solid rgba(74, 157, 255, 0.1);
}

.mr-card--overdue {
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.1);
  border: 2rpx solid rgba(255, 107, 107, 0.1);
}

.mr-card--taken { opacity: 0.6; }

.mr-card-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.mr-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #1A3A5C;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mr-tag {
  padding: 3rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.mr-tag--notYet { background: #E8F2FF; }
.mr-tag--due { background: #E0F0FF; }
.mr-tag--overdue { background: #FFF0F0; }
.mr-tag--taken { background: #E8FAF0; }

.mr-tag-text {
  font-size: 20rpx;
  font-weight: 700;
}

.mr-tag--notYet .mr-tag-text { color: #8BA4C7; }
.mr-tag--due .mr-tag-text { color: #4A9DFF; }
.mr-tag--overdue .mr-tag-text { color: #FF6B6B; }
.mr-tag--taken .mr-tag-text { color: #52D9A0; }

.mr-card-bot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mr-dose {
  font-size: 22rpx;
  color: #8BA4C7;
}

/* ── 操作按钮 ── */
.mr-btn {
  padding: 6rpx 20rpx;
  border-radius: 10rpx;
  transition: transform 150ms ease;
}

.mr-btn:active { transform: scale(0.9); }

.mr-btn--notYet { background: #E8F2FF; }
.mr-btn--due { background: #E0F0FF; }
.mr-btn--overdue { background: #FFF0F0; }
.mr-btn--taken { background: #E8FAF0; }

.mr-btn-text {
  font-size: 22rpx;
  font-weight: 700;
}

.mr-btn--notYet .mr-btn-text { color: #A8DAFF; }
.mr-btn--due .mr-btn-text { color: #4A9DFF; }
.mr-btn--overdue .mr-btn-text { color: #FF6B6B; }
.mr-btn--taken .mr-btn-text { color: #52D9A0; }

.mr-btn--disabled {
  opacity: 0.45;
  pointer-events: none;
}

.mr-btn--pulse {
  animation: btnPulse 2s ease-in-out infinite;
}

@keyframes btnPulse {
  0%, 100% { box-shadow: none; }
  50% { box-shadow: 0 0 0 6rpx rgba(74, 157, 255, 0.12); }
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .pill-body, .empty-buddy .eb-body, .done-buddy .db-body { animation: none; }
  .pill-pupil { animation: none; }
  .hero-cloud { animation: none; }
  .hero-star, .db-star { animation: none; }
  .hero-time-dot { animation: none; }
  .mr-btn--pulse { animation: none; }
  .capsule-fill { transition: none; }
  .pill-num-bubble { animation: none; }
  .confetti-piece { animation: none !important; }
}

/* ═══ 全屏庆祝效果 ═══ */
.confetti-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  pointer-events: none;
  overflow: hidden;
}

/* ── 服药成功文字 ── */
.confetti-success-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  z-index: 10;
  animation: textPopIn 0.5s ease-out 0.2s both;
}

.success-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52D9A0, #4A9DFF);
  color: #fff;
  font-size: 56rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(82, 217, 160, 0.4);
}

.success-label {
  font-size: 36rpx;
  font-weight: 800;
  color: #1A3A5C;
  text-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
}

@keyframes textPopIn {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
  60% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
  100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}

/* ── 闪烁星星 ── */
.star {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FFD93D;
  box-shadow: 0 0 12rpx 4rpx rgba(255, 217, 61, 0.6);
  animation: starTwinkle 0.8s ease-in-out infinite;
}

.star--1 { top: 15%; left: 20%; animation-delay: 0s; }
.star--2 { top: 25%; right: 25%; animation-delay: 0.15s; width: 12rpx; height: 12rpx; }
.star--3 { top: 40%; left: 15%; animation-delay: 0.3s; width: 20rpx; height: 20rpx; }
.star--4 { top: 35%; right: 18%; animation-delay: 0.45s; }
.star--5 { top: 60%; left: 25%; animation-delay: 0.6s; width: 10rpx; height: 10rpx; }
.star--6 { top: 55%; right: 22%; animation-delay: 0.2s; width: 14rpx; height: 14rpx; }
.star--7 { top: 70%; left: 30%; animation-delay: 0.5s; }
.star--8 { top: 65%; right: 28%; animation-delay: 0.35s; width: 18rpx; height: 18rpx; }

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* ── 顶部飘落彩纸 ── */
.cf {
  position: absolute;
  top: -20rpx;
  width: 14rpx;
  height: 20rpx;
  border-radius: 3rpx;
  opacity: 0;
  animation: confettiFall 2.5s ease-in forwards;
}

.cf--1  { left: 5%; background: #FF6B6B; animation-delay: 0.00s; }
.cf--2  { left: 12%; background: #4A9DFF; width: 10rpx; height: 16rpx; border-radius: 50%; animation-delay: 0.08s; }
.cf--3  { left: 20%; background: #FFB366; width: 16rpx; height: 12rpx; animation-delay: 0.16s; }
.cf--4  { left: 28%; background: #52D9A0; width: 12rpx; height: 18rpx; border-radius: 50%; animation-delay: 0.24s; }
.cf--5  { left: 35%; background: #B8A9FF; animation-delay: 0.04s; }
.cf--6  { left: 42%; background: #FFD93D; width: 18rpx; height: 14rpx; animation-delay: 0.12s; }
.cf--7  { left: 50%; background: #FF6B6B; width: 10rpx; height: 10rpx; border-radius: 50%; animation-delay: 0.20s; }
.cf--8  { left: 58%; background: #4A9DFF; width: 14rpx; height: 22rpx; animation-delay: 0.28s; }
.cf--9  { left: 65%; background: #52D9A0; width: 16rpx; height: 12rpx; animation-delay: 0.06s; }
.cf--10 { left: 72%; background: #FFB366; width: 12rpx; height: 16rpx; border-radius: 50%; animation-delay: 0.14s; }
.cf--11 { left: 80%; background: #B8A9FF; animation-delay: 0.22s; }
.cf--12 { left: 88%; background: #FFD93D; width: 10rpx; height: 14rpx; animation-delay: 0.30s; }
.cf--13 { left: 95%; background: #FF6B6B; width: 14rpx; height: 18rpx; animation-delay: 0.10s; }
.cf--14 { left: 8%; background: #4A9DFF; width: 12rpx; height: 12rpx; border-radius: 50%; animation-delay: 0.18s; }
.cf--15 { left: 32%; background: #52D9A0; animation-delay: 0.26s; }
.cf--16 { left: 48%; background: #FFB366; width: 16rpx; height: 10rpx; animation-delay: 0.02s; }
.cf--17 { left: 62%; background: #B8A9FF; width: 10rpx; height: 18rpx; border-radius: 50%; animation-delay: 0.32s; }
.cf--18 { left: 78%; background: #FFD93D; width: 14rpx; height: 14rpx; animation-delay: 0.08s; }
.cf--19 { left: 85%; background: #FF6B6B; width: 12rpx; height: 20rpx; animation-delay: 0.20s; }
.cf--20 { left: 92%; background: #4A9DFF; width: 10rpx; height: 10rpx; border-radius: 50%; animation-delay: 0.28s; }

@keyframes confettiFall {
  0% { opacity: 1; transform: translateY(0) rotate(0deg); }
  100% { opacity: 0; transform: translateY(110vh) rotate(720deg); }
}

/* ── 中间爆开彩纸 ── */
.cb {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 16rpx;
  border-radius: 3rpx;
  opacity: 0;
  animation: confettiBurst 1.8s ease-out forwards;
}

.cb--1  { background: #FF6B6B; animation: cb1 1.8s ease-out 0.1s forwards; }
.cb--2  { background: #4A9DFF; width: 10rpx; height: 10rpx; border-radius: 50%; animation: cb2 1.8s ease-out 0.15s forwards; }
.cb--3  { background: #FFB366; width: 14rpx; height: 12rpx; animation: cb3 1.8s ease-out 0.05s forwards; }
.cb--4  { background: #52D9A0; width: 8rpx; height: 14rpx; border-radius: 50%; animation: cb4 1.8s ease-out 0.2s forwards; }
.cb--5  { background: #B8A9FF; animation: cb5 1.8s ease-out 0.12s forwards; }
.cb--6  { background: #FFD93D; width: 12rpx; height: 12rpx; animation: cb6 1.8s ease-out 0.08s forwards; }
.cb--7  { background: #FF6B6B; width: 10rpx; height: 18rpx; animation: cb7 1.8s ease-out 0.18s forwards; }
.cb--8  { background: #4A9DFF; width: 14rpx; height: 10rpx; border-radius: 50%; animation: cb8 1.8s ease-out 0.03s forwards; }
.cb--9  { background: #52D9A0; animation: cb9 1.8s ease-out 0.22s forwards; }
.cb--10 { background: #FFB366; width: 10rpx; height: 16rpx; animation: cb10 1.8s ease-out 0.16s forwards; }

@keyframes cb1 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(-180rpx, -280rpx) rotate(400deg); } }
@keyframes cb2 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(160rpx, -320rpx) rotate(-360deg); } }
@keyframes cb3 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(-220rpx, -180rpx) rotate(500deg); } }
@keyframes cb4 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(200rpx, -240rpx) rotate(-420deg); } }
@keyframes cb5 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(-140rpx, -360rpx) rotate(380deg); } }
@keyframes cb6 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(240rpx, -160rpx) rotate(-520deg); } }
@keyframes cb7 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(-260rpx, -200rpx) rotate(440deg); } }
@keyframes cb8 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(180rpx, -340rpx) rotate(-380deg); } }
@keyframes cb9 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(-200rpx, -260rpx) rotate(460deg); } }
@keyframes cb10 { 0% { opacity: 1; transform: translate(0,0) rotate(0); } 100% { opacity: 0; transform: translate(220rpx, -220rpx) rotate(-400deg); } }

/* ── 两侧喷射彩纸 ── */
.cp {
  position: absolute;
  width: 16rpx;
  height: 24rpx;
  border-radius: 4rpx;
  top: 55%;
  opacity: 0;
}

/* ── 左侧喷射 ── */
.cp--L1  { left: 0; background: #FF6B6B; width: 14rpx; height: 20rpx; animation: bL1 2s ease-out 0.00s forwards; }
.cp--L2  { left: 0; background: #FFB366; width: 18rpx; height: 12rpx; border-radius: 2rpx; animation: bL2 2s ease-out 0.04s forwards; }
.cp--L3  { left: 0; background: #4A9DFF; width: 12rpx; height: 28rpx; border-radius: 6rpx; animation: bL3 2s ease-out 0.08s forwards; }
.cp--L4  { left: 0; background: #52D9A0; width: 20rpx; height: 10rpx; animation: bL1 2s ease-out 0.02s forwards; }
.cp--L5  { left: 0; background: #B8A9FF; width: 10rpx; height: 10rpx; border-radius: 50%; animation: bL2 2s ease-out 0.12s forwards; }
.cp--L6  { left: 0; background: #FFD93D; width: 14rpx; height: 14rpx; border-radius: 50%; animation: bL3 2s ease-out 0.06s forwards; }
.cp--L7  { left: 0; background: #FF6B6B; width: 16rpx; height: 22rpx; border-radius: 3rpx; animation: bL1 2s ease-out 0.10s forwards; }
.cp--L8  { left: 0; background: #4A9DFF; width: 10rpx; height: 24rpx; border-radius: 5rpx; animation: bL2 2s ease-out 0.14s forwards; }
.cp--L9  { left: 0; background: #52D9A0; width: 18rpx; height: 8rpx; animation: bL3 2s ease-out 0.03s forwards; }
.cp--L10 { left: 0; background: #FFB366; width: 12rpx; height: 16rpx; border-radius: 3rpx; animation: bL1 2s ease-out 0.09s forwards; }

@keyframes bL1 {
  0%   { opacity: 1; transform: translate(0, 0) rotate(0deg); }
  40%  { opacity: 1; transform: translate(200rpx, -300rpx) rotate(180deg); }
  100% { opacity: 0; transform: translate(350rpx, 250rpx) rotate(600deg); }
}
@keyframes bL2 {
  0%   { opacity: 1; transform: translate(0, 0) rotate(0deg); }
  40%  { opacity: 1; transform: translate(160rpx, -400rpx) rotate(-150deg); }
  100% { opacity: 0; transform: translate(300rpx, 200rpx) rotate(-520deg); }
}
@keyframes bL3 {
  0%   { opacity: 1; transform: translate(0, 0) rotate(0deg); }
  40%  { opacity: 1; transform: translate(240rpx, -240rpx) rotate(220deg); }
  100% { opacity: 0; transform: translate(400rpx, 300rpx) rotate(680deg); }
}

/* ── 右侧喷射 ── */
.cp--R1  { right: 0; background: #FF6B6B; width: 14rpx; height: 20rpx; animation: bR1 2s ease-out 0.02s forwards; }
.cp--R2  { right: 0; background: #4A9DFF; width: 18rpx; height: 12rpx; border-radius: 2rpx; animation: bR2 2s ease-out 0.06s forwards; }
.cp--R3  { right: 0; background: #FFB366; width: 12rpx; height: 28rpx; border-radius: 6rpx; animation: bR3 2s ease-out 0.10s forwards; }
.cp--R4  { right: 0; background: #B8A9FF; width: 20rpx; height: 10rpx; animation: bR1 2s ease-out 0.01s forwards; }
.cp--R5  { right: 0; background: #52D9A0; width: 10rpx; height: 10rpx; border-radius: 50%; animation: bR2 2s ease-out 0.08s forwards; }
.cp--R6  { right: 0; background: #FFD93D; width: 14rpx; height: 14rpx; border-radius: 50%; animation: bR3 2s ease-out 0.04s forwards; }
.cp--R7  { right: 0; background: #FF6B6B; width: 16rpx; height: 22rpx; border-radius: 3rpx; animation: bR1 2s ease-out 0.12s forwards; }
.cp--R8  { right: 0; background: #4A9DFF; width: 10rpx; height: 24rpx; border-radius: 5rpx; animation: bR2 2s ease-out 0.07s forwards; }
.cp--R9  { right: 0; background: #FFB366; width: 18rpx; height: 8rpx; animation: bR3 2s ease-out 0.03s forwards; }
.cp--R10 { right: 0; background: #52D9A0; width: 12rpx; height: 16rpx; border-radius: 3rpx; animation: bR1 2s ease-out 0.11s forwards; }

@keyframes bR1 {
  0%   { opacity: 1; transform: translate(0, 0) rotate(0deg); }
  40%  { opacity: 1; transform: translate(-200rpx, -300rpx) rotate(-180deg); }
  100% { opacity: 0; transform: translate(-350rpx, 250rpx) rotate(-600deg); }
}
@keyframes bR2 {
  0%   { opacity: 1; transform: translate(0, 0) rotate(0deg); }
  40%  { opacity: 1; transform: translate(-160rpx, -400rpx) rotate(150deg); }
  100% { opacity: 0; transform: translate(-300rpx, 200rpx) rotate(520deg); }
}
@keyframes bR3 {
  0%   { opacity: 1; transform: translate(0, 0) rotate(0deg); }
  40%  { opacity: 1; transform: translate(-240rpx, -240rpx) rotate(-220deg); }
  100% { opacity: 0; transform: translate(-400rpx, 300rpx) rotate(-680deg); }
}
