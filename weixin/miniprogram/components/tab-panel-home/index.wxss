/* ═══════════════════════════════════════════
   Editorial Warmth · Classical Edition
   杂志暖调 · 古典纹饰版
   ═══════════════════════════════════════════ */

/* ─── Page ─── */
.page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #f5f2ed;
  /* 极淡回纹底纹 */
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx,
      rgba(28, 25, 23, 0.012) 80rpx
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 79rpx,
      rgba(28, 25, 23, 0.012) 79rpx,
      rgba(28, 25, 23, 0.012) 80rpx
    );
}

.safe-shell {
  padding-bottom: calc(env(safe-area-inset-bottom) + 28rpx);
}

.scrollarea {
  flex: 1;
  min-height: 0;
  overflow-y: hidden;
}

/* ─── 3D Tilt System ─── */
.card-3d-wrap {
  perspective: 1400rpx;
}

.card-3d {
  position: relative;
  transform-style: preserve-3d;
  transform: perspective(1400rpx)
    rotateX(var(--tilt-rx, 0deg))
    rotateY(var(--tilt-ry, 0deg))
    scale(var(--tilt-scale, 1));
  transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
              box-shadow 240ms ease;
}

.card-3d-shine {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background: radial-gradient(
    circle at var(--shine-x, 50%) var(--shine-y, 50%),
    rgba(255, 255, 255, 0.45),
    transparent 55%
  );
  z-index: 2;
  opacity: 0.5;
}

.card-3d-wrap--hero,
.card-3d-wrap--empty {
  animation: none;
}

/* ═══════════════════════════════════════════
   Hero Card
   ═══════════════════════════════════════════ */
.hero {
  position: relative;
  padding: 44rpx 40rpx 52rpx;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 28rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 24rpx 64rpx rgba(28, 25, 23, 0.06),
    0 4rpx 12rpx rgba(28, 25, 23, 0.03);
}

/* ── 回纹角饰 ── */
.corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  pointer-events: none;
  z-index: 3;
}

/* 左上角 */
.corner--tl {
  top: 20rpx;
  left: 20rpx;
  border-top: 3rpx solid rgba(46, 158, 143, 0.2);
  border-left: 3rpx solid rgba(46, 158, 143, 0.2);
}

.corner--tl::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.1);
  border-left: 2rpx solid rgba(46, 158, 143, 0.1);
}

/* 右上角 */
.corner--tr {
  top: 20rpx;
  right: 20rpx;
  border-top: 3rpx solid rgba(46, 158, 143, 0.2);
  border-right: 3rpx solid rgba(46, 158, 143, 0.2);
}

.corner--tr::after {
  content: '';
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.1);
  border-right: 2rpx solid rgba(46, 158, 143, 0.1);
}

/* 左下角 */
.corner--bl {
  bottom: 20rpx;
  left: 20rpx;
  border-bottom: 3rpx solid rgba(46, 158, 143, 0.2);
  border-left: 3rpx solid rgba(46, 158, 143, 0.2);
}

.corner--bl::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.1);
  border-left: 2rpx solid rgba(46, 158, 143, 0.1);
}

/* 右下角 */
.corner--br {
  bottom: 20rpx;
  right: 20rpx;
  border-bottom: 3rpx solid rgba(46, 158, 143, 0.2);
  border-right: 3rpx solid rgba(46, 158, 143, 0.2);
}

.corner--br::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.1);
  border-right: 2rpx solid rgba(46, 158, 143, 0.1);
}

/* ── 水印暗纹（回字纹） ── */
.hero-watermark {
  position: absolute;
  right: -10rpx;
  top: 50%;
  transform: translateY(-50%) rotate(12deg);
  width: 280rpx;
  height: 280rpx;
  opacity: 0.03;
  pointer-events: none;
  z-index: 0;
  border: 4rpx solid #1c1917;
  border-radius: 4rpx;
}

.hero-watermark::before {
  content: '';
  position: absolute;
  inset: 14rpx;
  border: 3rpx solid #1c1917;
  border-radius: 2rpx;
}

.hero-watermark::after {
  content: '';
  position: absolute;
  inset: 30rpx;
  border: 2rpx solid #1c1917;
  border-radius: 2rpx;
}

.hero-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.hero-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #2E9E8F;
  letter-spacing: 1rpx;
}

.hero-time-chip {
  font-size: 24rpx;
  font-weight: 500;
  color: #a09890;
  padding: 6rpx 18rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.08);
  border-radius: 999rpx;
  font-variant-numeric: tabular-nums;
  letter-spacing: 2rpx;
}

.hero-num-row {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.hero-num {
  font-size: 180rpx;
  font-weight: 900;
  color: #1c1917;
  line-height: 0.82;
  letter-spacing: -8rpx;
  font-variant-numeric: tabular-nums;
}

.hero-num-meta {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 22rpx;
}

.hero-num-unit {
  font-size: 28rpx;
  font-weight: 500;
  color: #a09890;
  letter-spacing: 1rpx;
}

.hero-num-bar {
  width: 40rpx;
  height: 3rpx;
  background: #2E9E8F;
  border-radius: 999rpx;
  opacity: 0.5;
}

.hero-view-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.hero-view-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5b7a6b;
  opacity: 0.5;
}

.hero-view-text {
  font-size: 22rpx;
  color: #b0a99f;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* ═══════════════════════════════════════════
   Metrics — 轮播
   ═══════════════════════════════════════════ */
.metrics-wrap {
  margin-top: 20rpx;
}

.metrics-swiper {
  height: 220rpx;
  /* 禁止 swiper 自带指示器 */
  --swipe-dot: none;
}

.metrics-swiper .wx-swiper-dots,
.metrics-swiper .wx-swiper-dot {
  display: none !important;
}

.swiper-item-wrap {
  height: 100%;
  padding: 0 6rpx;
  box-sizing: border-box;
  display: flex;
}

.swiper-item-wrap .metric {
  flex: 1;
  height: 100%;
  box-sizing: border-box;
}

/* 指示器 */
.metric-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.metric-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(28, 25, 23, 0.1);
  transition: all 350ms cubic-bezier(0.22, 1, 0.36, 1);
}

.metric-dot--active {
  width: 28rpx;
  border-radius: 999rpx;
  background: #2E9E8F;
  opacity: 0.5;
}

.metric {
  position: relative;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 12rpx 36rpx rgba(28, 25, 23, 0.04),
    0 2rpx 8rpx rgba(28, 25, 23, 0.02);
  overflow: hidden;
}

.metric--risk { border-left: 4rpx solid #5b7a6b; }
.metric--stock { border-left: 4rpx solid #2E9E8F; }

/* 指标卡角饰 — L 形 + 端点圆 */
.metric-corner {
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  pointer-events: none;
  z-index: 1;
}

.metric-corner--tl {
  top: 12rpx;
  right: 12rpx;
  border-top: 2rpx solid rgba(28, 25, 23, 0.07);
  border-right: 2rpx solid rgba(28, 25, 23, 0.07);
}

.metric-corner--tl::after {
  content: '';
  position: absolute;
  top: -2.5rpx;
  right: -2.5rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: rgba(46, 158, 143, 0.2);
}

.metric-corner--br {
  bottom: 12rpx;
  left: 12rpx;
  border-bottom: 2rpx solid rgba(28, 25, 23, 0.07);
  border-left: 2rpx solid rgba(28, 25, 23, 0.07);
}

.metric-corner--br::after {
  content: '';
  position: absolute;
  bottom: -2.5rpx;
  left: -2.5rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: rgba(46, 158, 143, 0.2);
}

.metric-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #a09890;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.metric-val {
  margin-top: 12rpx;
  font-size: 56rpx;
  font-weight: 800;
  color: #1c1917;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.metric-u {
  font-size: 24rpx;
  font-weight: 500;
  color: #b0a99f;
  margin-left: 4rpx;
}

.metric-sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #c4bfb8;
}

/* ═══════════════════════════════════════════
   Hint
   ═══════════════════════════════════════════ */
.hint {
  margin-top: 16rpx;
  padding: 14rpx 20rpx;
  border-radius: 14rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #8c857d;
}

.hint--mid {
  background: rgba(180, 140, 60, 0.06);
  border-left: 3rpx solid rgba(180, 140, 60, 0.3);
}

.hint--high {
  background: rgba(46, 158, 143, 0.05);
  border-left: 3rpx solid rgba(46, 158, 143, 0.25);
}

/* ═══════════════════════════════════════════
   古典分割线 — 中轴对称纹样
   ═══════════════════════════════════════════ */
.ornament-divider {
  margin: 36rpx 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.od-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(28, 25, 23, 0.02),
    rgba(28, 25, 23, 0.08) 50%,
    rgba(28, 25, 23, 0.02)
  );
}

.od-center {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 菱形纹 — 两层嵌套 */
.od-diamond {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid rgba(46, 158, 143, 0.25);
  transform: rotate(45deg);
  position: relative;
}

.od-diamond::before {
  content: '';
  position: absolute;
  inset: 3rpx;
  border: 1.5rpx solid rgba(46, 158, 143, 0.12);
}

.od-diamond::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 4rpx;
  background: rgba(46, 158, 143, 0.15);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* ═══════════════════════════════════════════
   Section Head — 带装饰
   ═══════════════════════════════════════════ */
.section-head {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.section-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #b0a99f;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  flex-shrink: 0;
}

/* 两侧小菱形装饰 */
.sh-ornament {
  width: 8rpx;
  height: 8rpx;
  border: 1.5rpx solid rgba(46, 158, 143, 0.18);
  transform: rotate(45deg);
  flex-shrink: 0;
}

.sh-ornament--right {
  margin-left: auto;
  width: 6rpx;
  height: 6rpx;
  border-color: rgba(91, 122, 107, 0.15);
}

/* ═══════════════════════════════════════════
   Quick Actions
   ═══════════════════════════════════════════ */
.quick {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.quick-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(28, 25, 23, 0.03);
  transition: background 180ms ease;
  overflow: hidden;
}

/* ── 快捷卡回纹角饰 ── */
.qc-corners {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.qc-corner {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
}

/* 左上角 — 双层 L 形 */
.qc-corner--tl {
  top: 10rpx;
  left: 10rpx;
  border-top: 2rpx solid rgba(46, 158, 143, 0.15);
  border-left: 2rpx solid rgba(46, 158, 143, 0.15);
}

.qc-corner--tl::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 12rpx;
  height: 12rpx;
  border-top: 1.5rpx solid rgba(46, 158, 143, 0.08);
  border-left: 1.5rpx solid rgba(46, 158, 143, 0.08);
}

/* 右下角 — 双层 L 形 */
.qc-corner--br {
  bottom: 10rpx;
  right: 10rpx;
  border-bottom: 2rpx solid rgba(46, 158, 143, 0.15);
  border-right: 2rpx solid rgba(46, 158, 143, 0.15);
}

.qc-corner--br::before {
  content: '';
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 12rpx;
  height: 12rpx;
  border-bottom: 1.5rpx solid rgba(46, 158, 143, 0.08);
  border-right: 1.5rpx solid rgba(46, 158, 143, 0.08);
}

.quick-card:active { background: #f5f2ed; }

.qc-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 300;
  flex-shrink: 0;
}

.qc-icon--add     { background: rgba(91, 122, 107, 0.08); color: #5b7a6b; }
.qc-icon--scan    { background: rgba(100, 120, 180, 0.07); color: #6478b4; }
.qc-icon--pharmacy { background: rgba(46, 158, 143, 0.06); color: #2E9E8F; }

.qc-body { flex: 1; min-width: 0; }

.qc-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1917;
}

.qc-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #c4bfb8;
}

.quick-full {
  position: relative;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  border-left: 4rpx solid rgba(46, 158, 143, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(28, 25, 23, 0.03);
  transition: background 180ms ease;
  overflow: hidden;
}

.quick-full:active { background: #f5f2ed; }

.qc-full-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1917;
}

.qc-full-sub {
  margin-left: auto;
  font-size: 22rpx;
  color: #c4bfb8;
}

/* ═══════════════════════════════════════════
   Empty State
   ═══════════════════════════════════════════ */
.empty {
  padding: 60rpx 32rpx;
  border-radius: 24rpx;
  background: #fffefb;
  border: 1rpx dashed rgba(28, 25, 23, 0.08);
  text-align: center;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(28, 25, 23, 0.03);
  position: relative;
}

/* 空态卡角饰 — 菱形角标 */
.empty::before {
  content: '';
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  width: 10rpx;
  height: 10rpx;
  border: 1.5rpx solid rgba(91, 122, 107, 0.2);
  transform: rotate(45deg);
  pointer-events: none;
}

.empty::after {
  content: '';
  position: absolute;
  bottom: 18rpx;
  right: 18rpx;
  width: 10rpx;
  height: 10rpx;
  border: 1.5rpx solid rgba(91, 122, 107, 0.2);
  transform: rotate(45deg);
  pointer-events: none;
}

.empty-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(91, 122, 107, 0.06);
  color: #5b7a6b;
  font-size: 28rpx;
  font-weight: 300;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1917;
}

.empty-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #b0a99f;
  line-height: 1.6;
}

/* ═══════════════════════════════════════════
   Timeline
   ═══════════════════════════════════════════ */
.tl-section {
  margin-top: 8rpx;
}

.tl-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 22rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.04);
}

.tl-head-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #2E9E8F;
  opacity: 0.4;
  flex-shrink: 0;
}

.tl-head-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b645c;
  letter-spacing: 0.5rpx;
}

.tl-head-count {
  margin-left: auto;
  font-size: 20rpx;
  color: #c4bfb8;
  font-variant-numeric: tabular-nums;
}

/* ─── Row ─── */
.tl-row {
  display: flex;
  align-items: stretch;
  gap: 0;
  margin-bottom: 12rpx;
}

.tl-row:last-child { margin-bottom: 0; }

.tl-time {
  width: 88rpx;
  flex-shrink: 0;
  padding-top: 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #b0a99f;
  font-variant-numeric: tabular-nums;
  letter-spacing: 1rpx;
  text-align: right;
  padding-right: 20rpx;
}

.tl-mid {
  width: 32rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.tl-stem {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 2rpx;
  background: linear-gradient(
    180deg,
    rgba(28, 25, 23, 0.03),
    rgba(28, 25, 23, 0.08) 50%,
    rgba(28, 25, 23, 0.03)
  );
  transform: translateX(-50%);
}

.tl-row:last-child .tl-stem {
  bottom: 50%;
}

/* ── 同心圆时间线节点 ── */
.tl-dot {
  position: relative;
  z-index: 2;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-top: 27rpx;
  flex-shrink: 0;
  background: #f5f2ed;
  border: 2rpx solid #d6d1ca;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.tl-dot-inner {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #d6d1ca;
}

.tl-dot--notYet {
  border-color: #9cb8d0;
}
.tl-dot--notYet .tl-dot-inner { background: #9cb8d0; }

.tl-dot--due {
  border-color: #2E9E8F;
  box-shadow: 0 0 12rpx rgba(46, 158, 143, 0.15);
}
.tl-dot--due .tl-dot-inner { background: #2E9E8F; }

.tl-dot--overdue {
  border-color: #c44d3e;
  box-shadow: 0 0 12rpx rgba(196, 77, 62, 0.2);
}
.tl-dot--overdue .tl-dot-inner { background: #c44d3e; }

.tl-dot--taken {
  border-color: #5b7a6b;
}
.tl-dot--taken .tl-dot-inner { background: #5b7a6b; }

/* ─── Card ─── */
.tl-card {
  flex: 1;
  min-width: 0;
  padding: 24rpx 26rpx;
  border-radius: 20rpx;
  background: #fffefb;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  box-shadow:
    0 6rpx 20rpx rgba(28, 25, 23, 0.03),
    0 1rpx 4rpx rgba(28, 25, 23, 0.02);
  transition: background 160ms ease;
  position: relative;
  overflow: hidden;
}

/* 时间线卡角饰 — 极简角括号 */
.tl-card::before {
  content: '';
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 1.5rpx solid rgba(28, 25, 23, 0.06);
  border-right: 1.5rpx solid rgba(28, 25, 23, 0.06);
  pointer-events: none;
}

.tl-card::after {
  content: '';
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-bottom: 1.5rpx solid rgba(28, 25, 23, 0.06);
  border-left: 1.5rpx solid rgba(28, 25, 23, 0.06);
  pointer-events: none;
}

.tl-card:active { background: #faf8f5; }

.tl-card--overdue {
  border-color: rgba(196, 77, 62, 0.12);
  box-shadow: 0 4rpx 16rpx rgba(196, 77, 62, 0.04);
}

.tl-card--due {
  border-color: rgba(46, 158, 143, 0.1);
}

.tl-card--taken { opacity: 0.6; }

.tl-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.tl-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1c1917;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tl-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
  flex-shrink: 0;
}

.tl-tag--notYet  { color: #7a9ab4; background: rgba(156, 184, 208, 0.1); }
.tl-tag--due     { color: #2E9E8F; background: rgba(46, 158, 143, 0.08); }
.tl-tag--overdue { color: #c44d3e; background: rgba(196, 77, 62, 0.08); }
.tl-tag--taken   { color: #5b7a6b; background: rgba(91, 122, 107, 0.08); }

.tl-bottom {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tl-dose {
  font-size: 22rpx;
  color: #c4bfb8;
}

/* ─── Button ─── */
.tl-btn {
  display: inline-flex;
  align-items: center;
  padding: 0 22rpx;
  height: 52rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
  border: none;
  transition: transform 180ms cubic-bezier(0.22, 1.2, 0.36, 1),
              opacity 160ms ease;
}

.tl-btn:active { transform: scale(0.93); }

.tl-btn--notYet  { background: rgba(156, 184, 208, 0.1); color: #8aa8c0; }
.tl-btn--due     { background: rgba(46, 158, 143, 0.08); color: #2E9E8F; }
.tl-btn--overdue { background: rgba(196, 77, 62, 0.06); color: #c44d3e; }
.tl-btn--taken   { background: rgba(91, 122, 107, 0.06); color: #8aaa9a; }

.tl-btn--pulse {
  animation: subtlePulse 2.5s ease-in-out infinite;
}

.tl-btn--disabled {
  opacity: 0.45;
  pointer-events: none;
}

@keyframes subtlePulse {
  0%, 100% { box-shadow: none; }
  50% { box-shadow: 0 0 16rpx rgba(46, 158, 143, 0.08); }
}

/* ═══ Reduced Motion ═══ */
@media (prefers-reduced-motion: reduce) {
  .card-3d {
    transition: none;
    transform: none;
  }
  .card-3d-shine { display: none; }
  .tl-btn, .tl-btn--pulse {
    animation: none;
    transition: none;
  }
}
